	RunService.Heartbeat:Connect(function(delta)
		ApplySenderRateConfig()
		UpdateVelocityDesync()
		UpdateNetworkDesync()
		UpdateFakePosition()

		if Config.Movement.CFrameSpeed.Enabled and Config.Movement.CFrameSpeed.LoopType == "PING" then
			local character = LocalPlayer.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if character and humanoid and humanoid.MoveDirection.Magnitude > 0 then
				character:TranslateBy(humanoid.MoveDirection * tonumber(Config.Movement.CFrameSpeed.Amount) * delta * 10)
			end
		end

		if Config.PlayerMods.Enabled then
			UpdatePlayerMods(delta)
		end

		if Config.HitboxExpander.Enabled and tostring(Config.HitboxExpander.Method or "v1") == "v2" then
			UpdateHitboxExpander()
		end

		if Config.Velocity.Enabled then
			UpdateVelocity()
		end

		local he = Config.ESP.HitEffects
		local hitEffectsEnabled = he and (
			he.HitOverlay.Enabled
			or he.DamageNumber.Enabled
			or he.HitMarker2D.Enabled
			or he.HitMarker3D.Enabled
			or he.HitChams.Enabled
		)

		if (Config.Combat.HitSound.Enabled or hitEffectsEnabled) then
			local now = os.clock()
			if (now - lastHitDetectUpdate) >= HIT_DETECT_UPDATE_INTERVAL then
				lastHitDetectUpdate = now
				local targets = GetHitDetectTargets()
				local nowTick = tick()
				for i = 1, #targets do
					repeat
						local targetChar = targets[i]
						local hitPart = GetHitEffectPart(targetChar)
						if hitPart and Config.Combat.WallCheck and not IsVisibleToCamera(hitPart, targetChar) then
							break
						end

						if targetChar then
							local currentHealth = nil
							local maxHealth = nil
							currentHealth, maxHealth = GetCurrentHealth(targetChar)
							if currentHealth ~= nil then
								local cache = HitDetectCache[targetChar]
								if not cache then
									cache = { health = currentHealth, last = nowTick }
									HitDetectCache[targetChar] = cache
								else
									cache.last = nowTick
									local lastHealth = cache.health
									if currentHealth < lastHealth then
										local damage = lastHealth - currentHealth
										local isLethal = currentHealth <= 0
										local recentShot = HasRecentShot()
										if recentShot then
											RegisterRagebotDamageFeedback(targetChar, damage)
										end
										if recentShot and Config.Combat.HitSound.Enabled then
											PlayHitSound()
										end
										if recentShot and hitEffectsEnabled and damage > 0 then
											TriggerHitEffects(targetChar, damage, isLethal)
										end
										cache.health = currentHealth
									elseif currentHealth <= 0 and lastHealth > 0 then
										local damage = lastHealth
										local recentShot = HasRecentShot()
										if recentShot then
											RegisterRagebotDamageFeedback(targetChar, damage)
										end
										if recentShot and Config.Combat.HitSound.Enabled then
											PlayHitSound()
										end
										if recentShot and hitEffectsEnabled and damage > 0 then
											TriggerHitEffects(targetChar, damage, true)
										end
										cache.health = currentHealth
									else
										cache.health = currentHealth
									end
								end
							end
						end
					until true
				end
			end
			if (tick() - lastHitDetectCleanup) > 2 then
				lastHitDetectCleanup = tick()
				for model, data in pairs(HitDetectCache) do
					if not model or not model.Parent or (tick() - (data.last or 0)) > 5 then
						HitDetectCache[model] = nil
					end
				end
				CleanKalmanStates()  -- add this line
			end
		else
			table.clear(HitDetectCache)
		end
	end)

	RunService.RenderStepped:Connect(function(dt)
		local nowHit = os.clock()
		MainAimInit()
		if Config.Movement.CFrameSpeed.Enabled and Config.Movement.CFrameSpeed.LoopType ~= "PING" then
			local character = LocalPlayer.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if character and humanoid and humanoid.MoveDirection.Magnitude > 0 then
				character:TranslateBy(humanoid.MoveDirection * tonumber(Config.Movement.CFrameSpeed.Amount) * (dt or 0) * 10)
			end
		end

		if Config.Movement.ForceThirdPerson then
			local character = LocalPlayer and LocalPlayer.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			local rootPart = humanoid and humanoid.RootPart
			if rootPart and Camera then
				set_force_third_person_enabled(true)

				local focusPos = rootPart.Position + Vector3.new(0, 2.1, 0)
				local flatLook = Vector3.new(rootPart.CFrame.LookVector.X, 0, rootPart.CFrame.LookVector.Z)
				if flatLook.Magnitude < 0.001 then
					flatLook = Vector3.new(0, 0, -1)
				end
				flatLook = flatLook.Unit

				local flatRight = Vector3.new(flatLook.Z, 0, -flatLook.X)
				local desiredPos = focusPos - flatLook * 6.75 + Vector3.new(0, 1.9, 0) + flatRight * 1.25
				local lookAtPos = rootPart.Position + Vector3.new(0, 1.6, 0)

				local rayParams = RaycastParams.new()
				rayParams.FilterType = Enum.RaycastFilterType.Exclude
				rayParams.FilterDescendantsInstances = {character}
				rayParams.IgnoreWater = true

				local castDirection = desiredPos - focusPos
				local hit = Workspace:Raycast(focusPos, castDirection, rayParams)
				if hit then
					desiredPos = hit.Position + hit.Normal * 0.35
				end

				Camera.CFrame = CFrame.new(desiredPos, lookAtPos)
				Camera.Focus = CFrame.new(lookAtPos)
			end
		else
			set_force_third_person_enabled(false)
		end

		TryTriggerBulletTracer()

		UpdateRagebot(dt)
		UpdateRagebotFollowTarget(dt)
		UpdateRagebotViewTarget()
		UpdateRagebotTracer()
		UpdateRagebotPredictionDisplay()
		UpdateTriggerBot()
		UpdateFlickBot()
		last_frame_dt = dt or 0
		anim_t = anim_t + (dt or 0)
		draw_crosshair()
		local fov_rate = Config.fov.update_rate or 0
		if fov_rate <= 0 then
			draw_fov()
			draw_trigger_fov()
		else
			local interval = 1 / math.clamp(fov_rate, 1, 120)
			if (nowHit - last_fov_draw) >= interval then
				last_fov_draw = nowHit
				draw_fov()
				draw_trigger_fov()
			end
		end
		if (nowHit - lastHitEffectsUpdate) >= HIT_EFFECTS_UPDATE_INTERVAL then
			UpdateHitEffects(dt)
			lastHitEffectsUpdate = nowHit
		end

		UpdateLockedTargetIndicators()

	end)

