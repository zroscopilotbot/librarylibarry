		pcall(function()
			setfflag("DFIntTextureQualityOverride", tostring(OptimizationConfig.MeshDetailOverride))
		end)
	end

function apply_optimization_fflags()
		if OptimizationState.FFlagsApplied then
			apply_optimization_fflag_overrides()
			return
		end
		for flag, value in pairs(OPTIMIZATION_FFLAGS) do
			pcall(function()
				setfflag(tostring(flag), tostring(value))
			end)
		end
		OptimizationState.FFlagsApplied = true
		apply_optimization_fflag_overrides()
	end

