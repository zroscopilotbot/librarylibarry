function NormalizeAnimId(animId)
		if type(animId) ~= "string" then return animId end
		if animId:find("rbxassetid://") then
			return animId
		end
		local id = animId:match("id=(%d+)")
		if id then
			return "rbxassetid://" .. id
		end
		local looseId = animId:match("asset/%?id=(%d+)") or animId:match("asset/%?(%d+)")
		if looseId then
			return "rbxassetid://" .. looseId
		end
		return animId
	end
	function CaptureAnimationSetFromCharacter(character)
		local animate = character and character:FindFirstChild("Animate")
		if not animate then
			return nil
		end
		local function getAnimId(nodeName, childName)
			local node = animate:FindFirstChild(nodeName)
			local anim = node and node:FindFirstChild(childName)
			if anim and anim:IsA("Animation") and type(anim.AnimationId) == "string" and anim.AnimationId ~= "" then
				return NormalizeAnimId(anim.AnimationId)
			end
			return nil
		end
		local currentDefault = AnimationSets["Default"] or {}
		return {
			idle1 = getAnimId("idle", "Animation1") or currentDefault.idle1,
			idle2 = getAnimId("idle", "Animation2") or currentDefault.idle2,
			walk = getAnimId("walk", "WalkAnim") or currentDefault.walk,
			run = getAnimId("run", "RunAnim") or currentDefault.run,
			jump = getAnimId("jump", "JumpAnim") or currentDefault.jump,
			climb = getAnimId("climb", "ClimbAnim") or currentDefault.climb,
			fall = getAnimId("fall", "FallAnim") or currentDefault.fall,
		}
	end
	function CaptureCurrentDefaultAnimations(character, force)
		if DefaultAnimationCaptured and not force then
			return AnimationSets["Default"]
		end
		local captured = CaptureAnimationSetFromCharacter(character)
		if not captured then
			return AnimationSets["Default"]
		end
		AnimationSets["Default"] = captured
		if not force then
			AnimationOptions["Idle1"] = captured.idle1
			AnimationOptions["Idle2"] = captured.idle2
			AnimationOptions["Walk"] = captured.walk
			AnimationOptions["Run"] = captured.run
			AnimationOptions["Jump"] = captured.jump
			AnimationOptions["Climb"] = captured.climb
			AnimationOptions["Fall"] = captured.fall
		end
		DefaultAnimationCaptured = true
		return captured
	end

function BuildAnimSignature()
		return table.concat({
			AnimationOptions["Idle1"] or "",
			AnimationOptions["Idle2"] or "",
			AnimationOptions["Walk"] or "",
			AnimationOptions["Run"] or "",
			AnimationOptions["Jump"] or "",
			AnimationOptions["Climb"] or "",
			AnimationOptions["Fall"] or "",
		}, "|")
	end

function ClearAnimationTracks(character)
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if not humanoid then return end
		local animator = humanoid:FindFirstChildOfClass("Animator")
		if not animator then return end
		for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
			pcall(function()
				track:Stop(0)
				track:Destroy()
			end)
		end
	end

function ApplyCustomAnimations(character)
		if not character then return end
		local animate = character:FindFirstChild("Animate")
		if not animate then return end
		if not AnimationsDirty then return end
		local sig = BuildAnimSignature()
		if sig == LastAppliedAnimSig and LastAppliedCharacter == character then return end

		ClearAnimationTracks(character)
		local cloned = animate:Clone()
		local function setAnim(node, childName, animId)
			if not node then return end
			local anim = node:FindFirstChild(childName)
			if anim and anim:IsA("Animation") then
				anim.AnimationId = NormalizeAnimId(animId)
			end
		end

		setAnim(cloned:FindFirstChild("idle"), "Animation1", AnimationOptions["Idle1"])
		setAnim(cloned:FindFirstChild("idle"), "Animation2", AnimationOptions["Idle2"])
		setAnim(cloned:FindFirstChild("walk"), "WalkAnim", AnimationOptions["Walk"])
		setAnim(cloned:FindFirstChild("run"), "RunAnim", AnimationOptions["Run"])
		setAnim(cloned:FindFirstChild("jump"), "JumpAnim", AnimationOptions["Jump"])
		setAnim(cloned:FindFirstChild("climb"), "ClimbAnim", AnimationOptions["Climb"])
		setAnim(cloned:FindFirstChild("fall"), "FallAnim", AnimationOptions["Fall"])

		animate:Destroy()
		cloned.Parent = character
		LastAppliedAnimSig = sig
		LastAppliedCharacter = character
	end

function ApplyAnimationSet(setName)
		if setName == "Default" then
			CaptureCurrentDefaultAnimations(LocalPlayer and LocalPlayer.Character, true)
		end
		local set = AnimationSets[setName]
		if not set then return end
		if AnimationOptions["Idle1"] == set.idle1
			and AnimationOptions["Idle2"] == set.idle2
			and AnimationOptions["Walk"] == set.walk
			and AnimationOptions["Run"] == set.run
			and AnimationOptions["Jump"] == set.jump
			and AnimationOptions["Climb"] == set.climb
			and AnimationOptions["Fall"] == set.fall then
			return
		end
		AnimationOptions["Idle1"] = set.idle1
		AnimationOptions["Idle2"] = set.idle2
		AnimationOptions["Walk"] = set.walk
		AnimationOptions["Run"] = set.run
		AnimationOptions["Jump"] = set.jump
		AnimationOptions["Climb"] = set.climb
		AnimationOptions["Fall"] = set.fall
		AnimationsDirty = true
		ApplyCustomAnimations(LocalPlayer.Character)
	end

