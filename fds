	function clone_path(path)
		local copy = {}
		for i = 1, #path do
			copy[i] = path[i]
		end
		return copy
	end

	function path_to_feature_id(path, fieldName)
		local parts = {}
		for i = 1, #path do
			parts[#parts + 1] = tostring(path[i]):gsub("%s+", "_"):gsub("[^%w_]", "_"):lower()
		end
		local suffix = nil
		if fieldName and fieldName ~= "Enabled" then
			suffix = tostring(fieldName):gsub("%s+", "_"):gsub("[^%w_]", "_"):lower()
			suffix = suffix:gsub("_enabled$", "")
			if suffix == "enabled" or suffix == "flying" then
				suffix = nil
			end
			if suffix and #parts > 0 then
				local last = parts[#parts]
				if suffix == (last .. "enabled") then
					suffix = last
				end
			end
		end
		if suffix and suffix ~= parts[#parts] then
			parts[#parts + 1] = suffix
		end
		return table.concat(parts, ".")
	end

	function path_to_feature_name(path)
		local parts = {}
		for i = 1, #path do
			local part = tostring(path[i])
			part = part:gsub("_", " ")
			part = part:gsub("(%l)(%u)", "%1 %2")
			parts[#parts + 1] = part
		end
		return table.concat(parts, " > ")
	end

	function get_config_path_value(root, path)
		local node = root
		for i = 1, #path do
			if type(node) ~= "table" then
				return nil
			end
			node = node[path[i]]
			if node == nil then
				return nil
			end
		end
		return node
	end

	function set_config_path_value(root, path, value)
		local node = root
		for i = 1, #path - 1 do
			if type(node) ~= "table" then
				return false
			end
			node = node[path[i]]
			if type(node) ~= "table" then
				return false
			end
		end
		if type(node) ~= "table" then
			return false
		end
		node[path[#path]] = value
		return true
	end

	function register_feature_entry(categoryName, path, fieldName)
		local togglePath = clone_path(path)
		togglePath[#togglePath + 1] = fieldName

		local entry = {
			id = path_to_feature_id(path, fieldName),
			name = path_to_feature_name(path),
			category = tostring(categoryName or path[1] or "Misc"),
			toggle_field = fieldName,
			path = clone_path(path),
			toggle_path = togglePath,
			default = get_config_path_value(Config, togglePath),
		}

		FeatureManifest[#FeatureManifest + 1] = entry
		FeatureManifestLookup[entry.id] = entry
	end

	function scan_feature_manifest(node, path, depth)
		if type(node) ~= "table" then
			return
		end
		if depth > 6 then
			return
		end

		local registered = false
		for fieldName in pairs(FEATURE_TOGGLE_FIELDS) do
			if type(node[fieldName]) == "boolean" then
				register_feature_entry(path[1], path, fieldName)
				registered = true
				break
			end
		end

		for key, value in pairs(node) do
			if type(key) == "string" and type(value) == "table" and key ~= "Colors" and key ~= "Args" then
				local nextPath = clone_path(path)
				nextPath[#nextPath + 1] = key
				scan_feature_manifest(value, nextPath, depth + 1)
			end
		end
	end

	function rebuild_feature_manifest()
		FeatureManifest = {}
		FeatureManifestLookup = {}

		for key, value in pairs(Config) do
			if type(key) == "string" and type(value) == "table" then
				scan_feature_manifest(value, {key}, 1)
			end
		end

		table.sort(FeatureManifest, function(a, b)
			return a.id < b.id
		end)

		if getgenv then
			getgenv().XYLO_FEATURE_MANIFEST = FeatureManifest
		end
		return FeatureManifest
	end

	function get_feature_manifest()
		if not FeatureManifest or #FeatureManifest == 0 then
			rebuild_feature_manifest()
		end
		return FeatureManifest
	end

	function is_feature_blocked(featureId)
		return BlockedFeatures[tostring(featureId)] == true
	end

	function register_feature_ui_control(featureId, control)
		if not featureId or control == nil then
			return control
		end
		FeatureUiRegistry[featureId] = FeatureUiRegistry[featureId] or {}
		table.insert(FeatureUiRegistry[featureId], control)
		if is_feature_blocked(featureId) then
			set_feature_control_visible(control, false)
		end
		return control
	end

	function set_feature_control_visible(control, visible)
		if control == nil then
			return
		end

		if typeof(control) == "Instance" then
			pcall(function()
				control.Visible = visible
			end)
			return
		end

		if type(control) ~= "table" then
			return
		end

		if type(control.set_visible) == "function" then
			pcall(function()
				control:set_visible(visible)
			end)
			return
		end

		for _, key in ipairs({"Visible", "visible"}) do
			pcall(function()
				control[key] = visible
			end)
		end

		for _, key in ipairs({"frame", "Frame", "holder", "Holder", "button", "Button", "object", "Object"}) do
			local child = rawget(control, key)
			if child ~= nil then
				set_feature_control_visible(child, visible)
			end
		end
	end

	function apply_feature_ui_blocklist()
		for featureId, controls in pairs(FeatureUiRegistry) do
			local visible = not is_feature_blocked(featureId)
			for _, control in ipairs(controls) do
				set_feature_control_visible(control, visible)
			end
		end
	end

	function create_feature_ui_proxy(featureId, container, registerContainer)
		if not container then
			return container
		end
		if registerContainer ~= false then
			register_feature_ui_control(featureId, container)
		end

		local wrappedMethods = {
			toggle = true,
			slider = true,
			dropdown = true,
			button = true,
			textbox = true,
			colorpicker = true,
			keybind = true,
		}

		return setmetatable({}, {
			__index = function(_, key)
				local value = container[key]
				if type(value) ~= "function" then
					return value
				end

				if wrappedMethods[key] then
					return function(_, ...)
						local control = value(container, ...)
						register_feature_ui_control(featureId, control)
						return control
					end
				end

				return function(_, ...)
					return value(container, ...)
				end
			end
		})
	end

	function normalize_blocked_feature_ids(blocked)
		local ids = {}
		if type(blocked) == "table" then
			local isArray = (#blocked > 0)
			if isArray then
				for _, value in ipairs(blocked) do
					ids[tostring(value)] = true
				end
			else
				for key, value in pairs(blocked) do
					if value then
						ids[tostring(key)] = true
					end
				end
			end
		end
		return ids
	end

	function apply_blocked_features(blocked)
		BlockedFeatures = normalize_blocked_feature_ids(blocked)

		for _, entry in ipairs(get_feature_manifest()) do
			if BlockedFeatures[entry.id] then
				set_config_path_value(Config, entry.toggle_path, false)
			end
		end

		if getgenv then
			getgenv().XYLO_BLOCKED_FEATURES = BlockedFeatures
		end
		apply_feature_ui_blocklist()
	end

	rebuild_feature_manifest()
