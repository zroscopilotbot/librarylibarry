function ResolveNpcRoot()
		local getter = NPC_GAME_FOLDERS[GameID]
		if not getter then
			return nil
		end

		local ok, root = pcall(getter)
		if ok and root and root.Parent then
			return root
		end

		return nil
	end

function IsNpcModel(model)
		if not model or not model:IsA("Model") then return false end
		if LocalPlayer.Character and model == LocalPlayer.Character then return false end
		if Players:GetPlayerFromCharacter(model) then return false end
		if model:FindFirstAncestorOfClass("Tool") then return false end
		local humanoid = model:FindFirstChildOfClass("Humanoid")
		if not humanoid then return false end
		local head = model:FindFirstChild("Head") or model:FindFirstChild("Head", true)
		if not head then return false end
		return true
	end

	function GetNpcModelsCached()
		if not (
			(Config.Combat and Config.Combat.TargetNPCs)
			or (Config.Combat and Config.Combat.Aimbot and Config.Combat.Aimbot.TargetNPCs)
			or (Config.Combat and Config.Combat.SilentAim and Config.Combat.SilentAim.TargetNPCs)
			or (Config.ESP and Config.ESP.TargetNPCs)
			or (Config.HitboxExpander and Config.HitboxExpander.TargetNPCs)
		) then
			return {}
		end

		local function collect_models_from_root(root)
			local models = {}
			if not root then
				return models
			end

			local seen = {}
			local function tryAddModel(candidate)
				if candidate and candidate:IsA("Model") and not seen[candidate] and IsNpcModel(candidate) then
					seen[candidate] = true
					table.insert(models, candidate)
				end
			end

			for _, child in ipairs(root:GetChildren()) do
				tryAddModel(child)
			end

			return models
		end

		local now = tick()
		local root = ResolveNpcRoot()
		if NpcModelCache.Models and (now - NpcModelCache.Stamp) < NPC_MODEL_CACHE_TTL then
			return NpcModelCache.Models
		end

		local models = collect_models_from_root(root)

		NpcModelCache.Models = models
		NpcModelCache.Stamp = now
		return models
	end

