function IsWeaponLikeName(name)
		name = string.lower(tostring(name or ""))
		if name == "" then
			return false
		end
		local keywords = {
			"gun", "weapon", "rifle", "shotgun", "smg", "pistol",
			"revolver", "sniper", "carbine", "musket", "uzi",
			"ak", "ar", "glock", "deagle", "blade", "sword",
			"katana", "knife", "viewmodel", "view model", "vm_",
			"firearm", "launcher", "cannon", "bow", "crossbow",
			"primary", "secondary", "melee"
		}
		for _, keyword in ipairs(keywords) do
			if name:find(keyword, 1, true) then
				return true
			end
		end
		return false
	end

function GetWeaponLikeScore(obj)
		if not obj or not obj.Parent then
			return -math.huge
		end

		local score = 0
		if obj:IsA("Tool") then
			score = score + 100
		end
		if obj:IsA("Model") then
			score = score + 15
		end
		if obj:IsA("Folder") then
			score = score + 8
		end
		if IsWeaponLikeName(obj.Name) then
			score = score + 20
		end

		for _, name in ipairs({
			"Handle", "Barrel", "Muzzle", "MuzzleFlash", "FirePoint", "ShootPos",
			"FirePos", "FirePoint", "MuzzlePoint", "MuzzleAttachment", "AimPart",
			"BulletOrigin", "BulletStart", "ProjectileOrigin", "Gun", "Weapon",
			"WeaponModel", "GunModel", "ViewModel"
		}) do
			if obj:FindFirstChild(name, true) then
				score = score + 10
			end
		end

		local basePartCount = 0
		local constraintScore = 0
		for _, desc in ipairs(obj:GetDescendants()) do
			if desc:IsA("BasePart") then
				basePartCount = basePartCount + 1
				local lowerName = string.lower(desc.Name)
				if lowerName == "handle" then
					score = score + 10
				elseif lowerName:find("muzzle") or lowerName:find("barrel") or lowerName:find("fire") then
					score = score + 12
				end
			elseif desc:IsA("Attachment") then
				local lowerName = string.lower(desc.Name)
				if lowerName:find("muzzle") or lowerName:find("fire") or lowerName:find("shoot")
					or lowerName:find("bullet") or lowerName:find("projectile") then
					score = score + 15
				end
			elseif desc:IsA("AnimationController") or desc:IsA("Animator") then
				score = score + 5
			elseif desc:IsA("Weld") or desc:IsA("WeldConstraint") or desc:IsA("Motor6D") then
				constraintScore = constraintScore + 1
			end
		end

		if basePartCount >= 1 then
			score = score + math.min(basePartCount, 8)
		end
		if constraintScore > 0 then
			score = score + math.min(constraintScore * 4, 20)
		end

		if obj.Parent == LocalPlayer.Character then
			score = score + 25
		end

		return score
	end

function FindBestWeaponLikeObjectIn(root, minScore)
		if not root then
			return nil, 0
		end

		local bestObject = nil
		local bestScore = minScore or 0
		local ok, descendants = pcall(function()
			return root:GetDescendants()
		end)
		if not ok or type(descendants) ~= "table" then
			return nil, bestScore
		end

		for _, desc in ipairs(descendants) do
			if desc:IsA("Model") or desc:IsA("Tool") or desc:IsA("Folder") then
				local score = GetWeaponLikeScore(desc)
				if score > bestScore then
					bestScore = score
					bestObject = desc
				end
			end
		end

		return bestObject, bestScore
	end

function GetEquippedWeaponObject()
		local character = LocalPlayer and LocalPlayer.Character
		if not character then
			return nil
		end

		local tool = GetEquippedTool()
		if tool then
			return tool
		end

		local bestObject = nil
		local bestScore = 0

		for _, child in ipairs(character:GetChildren()) do
			if child:IsA("Model") or child:IsA("Folder") or child:IsA("Tool") then
				local score = GetWeaponLikeScore(child)
				if score > bestScore then
					bestScore = score
					bestObject = child
				end
			end
		end

		if bestObject and bestScore >= 25 then
			return bestObject
		end

		local nestedCharacterObject, nestedCharacterScore = FindBestWeaponLikeObjectIn(character, bestScore)
		if nestedCharacterObject and nestedCharacterScore > bestScore then
			bestObject = nestedCharacterObject
			bestScore = nestedCharacterScore
		end

		local cam = Workspace and Workspace.CurrentCamera
		if cam then
			local cameraObject, cameraScore = FindBestWeaponLikeObjectIn(cam, bestScore)
			if cameraObject and cameraScore > bestScore then
				bestObject = cameraObject
				bestScore = cameraScore
			end
		end

		local backpack = LocalPlayer and LocalPlayer:FindFirstChildOfClass("Backpack")
		if backpack and bestScore < 60 then
			for _, child in ipairs(backpack:GetChildren()) do
				if child:IsA("Tool") then
					local score = GetWeaponLikeScore(child) - 25
					if score > bestScore then
						bestScore = score
						bestObject = child
					end
				end
			end
		end

		if bestScore >= 30 then
			return bestObject
		end

		return nil
	end

function ResolveAmmoValueFromObject(obj, depth)
		if not obj or depth > 4 then
			return nil
		end

		local directNames = {
			"Ammo", "AMMO", "ammo",
			"AmmoValue", "AMMOValue",
			"Clip", "clip", "ClipAmmo",
			"Mag", "MAG", "Magazine", "CurrentAmmo",
			"StoredAmmo", "ReserveAmmo", "LoadedAmmo",
			"Bullets", "Shells", "AmmoInClip", "ClipLoaded",
			"Loaded", "AmmoCount", "AmmoLeft", "CurrentBullets",
			"StoredBullets", "Amount", "Capacity", "Rounds",
			"ClipAmount", "MagAmount"
		}

		for _, name in ipairs(directNames) do
			local child = obj:FindFirstChild(name)
			if child and (child:IsA("IntValue") or child:IsA("NumberValue") or child:IsA("StringValue")) then
				return tonumber(child.Value)
			end
		end

		for _, child in ipairs(obj:GetChildren()) do
			if child:IsA("IntValue") or child:IsA("NumberValue") or child:IsA("StringValue") then
				local lowerName = string.lower(child.Name)
				if lowerName:find("ammo")
					or lowerName:find("clip")
					or lowerName:find("mag")
					or lowerName:find("bullet")
					or lowerName:find("shell")
					or lowerName:find("loaded")
					or lowerName:find("round") then
					return tonumber(child.Value)
				end
			elseif child:IsA("Folder")
				or child:IsA("Configuration")
				or child:IsA("Tool")
				or child:IsA("Model")
				or child:IsA("ScreenGui")
				or child:IsA("Frame") then
				local nested = ResolveAmmoValueFromObject(child, depth + 1)
				if nested ~= nil then
					return nested
				end
			end
		end

		local ammoAttributes = {
			"Ammo", "AMMO", "ammo",
			"Clip", "clip", "Magazine",
			"CurrentAmmo", "StoredAmmo", "ReserveAmmo",
			"AmmoInClip", "ClipLoaded", "Loaded", "AmmoCount",
			"AmmoLeft", "CurrentBullets", "Rounds", "ClipAmount", "MagAmount"
		}
		for _, attr in ipairs(ammoAttributes) do
			local value = obj:GetAttribute(attr)
			if type(value) == "number" then
				return value
			end
		end

		return nil
	end

function GetEquippedWeaponAmmo(weaponObject)
		weaponObject = weaponObject or GetEquippedWeaponObject()
		if not weaponObject then
			return nil
		end

		local ammo = ResolveAmmoValueFromObject(weaponObject, 0)
		if ammo ~= nil then
			return ammo
		end

		local handle = weaponObject:FindFirstChild("Handle", true) or weaponObject:FindFirstChildWhichIsA("BasePart", true)
		if handle then
			ammo = ResolveAmmoValueFromObject(handle, 0)
			if ammo ~= nil then
				return ammo
			end
		end

		local character = LocalPlayer and LocalPlayer.Character
		if character then
			local bodyEffects = character:FindFirstChild("BodyEffects")
				or character:FindFirstChild("BD")
				or character:FindFirstChild("WeaponStats")
				or character:FindFirstChild("GunData")
				or character:FindFirstChild("BodyEffects", true)
			if bodyEffects then
				ammo = ResolveAmmoValueFromObject(bodyEffects, 0)
				if ammo ~= nil then
					return ammo
				end
			end

			ammo = ResolveAmmoValueFromObject(character, 0)
			if ammo ~= nil then
				return ammo
			end
		end

		local cam = Workspace and Workspace.CurrentCamera
		if cam then
			ammo = ResolveAmmoValueFromObject(cam, 0)
			if ammo ~= nil then
				return ammo
			end
		end

		local backpack = LocalPlayer and LocalPlayer:FindFirstChildOfClass("Backpack")
		if backpack then
			ammo = ResolveAmmoValueFromObject(backpack, 0)
			if ammo ~= nil then
				return ammo
			end
		end

		return nil
	end

	function HasEquippedWeaponAmmo(weaponObject)
		local ammo = GetEquippedWeaponAmmo(weaponObject)
		if ammo == nil then
			return true
		end
		return ammo > 0
	end

function ResolveBulletTracerOrigin()
		local character = LocalPlayer and LocalPlayer.Character
		if not character then
			return Camera.CFrame.Position
		end

		local weaponObject = GetEquippedWeaponObject()
		if weaponObject then
			for _, name in ipairs({
				"Muzzle", "MuzzleFlash", "Barrel", "Tip", "FirePoint", "ShootPos",
				"FirePos", "MuzzlePoint", "MuzzleAttachment", "BulletOrigin",
				"BulletStart", "ProjectileOrigin", "EmitPoint", "Nozzle"
			}) do
				local attachment = weaponObject:FindFirstChild(name, true)
				if attachment and attachment:IsA("Attachment") then
					return attachment.WorldPosition
				end
				if attachment and attachment:IsA("BasePart") then
					return attachment.Position
				end
			end

			local handle = weaponObject:FindFirstChild("Handle", true) or weaponObject:FindFirstChildWhichIsA("BasePart", true)
			if handle and handle:IsA("BasePart") then
				return handle.Position
			end
		end

		local cam = Workspace and Workspace.CurrentCamera
		if cam then
			for _, name in ipairs({
				"Muzzle", "MuzzleFlash", "Barrel", "Tip", "FirePoint", "ShootPos",
				"FirePos", "MuzzlePoint", "MuzzleAttachment", "BulletOrigin",
				"BulletStart", "ProjectileOrigin", "EmitPoint", "Nozzle"
			}) do
				local attachment = cam:FindFirstChild(name, true)
				if attachment and attachment:IsA("Attachment") then
					return attachment.WorldPosition
				end
				if attachment and attachment:IsA("BasePart") then
					return attachment.Position
				end
			end
		end

		local head = character:FindFirstChild("Head")
		if head then
			return head.Position
		end
		local root = character:FindFirstChild("HumanoidRootPart")
		if root then
			return root.Position
		end

		return Camera.CFrame.Position
	end

function ResolveBulletTracerTargetPosition(origin)
		local lockedTarget = Config.Combat and Config.Combat.lockedTarget
		if lockedTarget and lockedTarget.Parent then
			local aimPart = GetSelectedAimPart(lockedTarget, Config.Combat.AimPart)
				or GetHitEffectPart(lockedTarget)
				or lockedTarget:FindFirstChild("HumanoidRootPart")
			if aimPart then
				return aimPart.Position
			end
		end

		local mouseCFrame = Config.Combat and Config.Combat.MousePosition
		if typeof(mouseCFrame) == "CFrame" then
			return mouseCFrame.Position
		end

		if mouse and mouse.Hit then
			return mouse.Hit.Position
		end

		local rayDirection = Camera.CFrame.LookVector * 1000
		local result = Workspace:Raycast(origin, rayDirection, hitRaycastParams)
		if result then
			return result.Position
		end

		return origin + rayDirection
	end

function TriggerBulletTracer(origin, targetPosition)
		local he = Config.ESP.HitEffects and Config.ESP.HitEffects.BulletTracer
		if not he or not he.Enabled then return end
		if not origin or not targetPosition then return end

		local maxDistance = math.max(50, tonumber(he.MaxDistance) or 2500)
		local direction = targetPosition - origin
		if direction.Magnitude <= 0.001 then
			return
		end
		if direction.Magnitude > maxDistance then
			targetPosition = origin + direction.Unit * maxDistance
		end

		local outline = Drawing.new("Line")
		outline.Visible = true
		outline.Color = he.OutlineColor or Color3.fromRGB(20, 20, 20)
		outline.Thickness = (he.Thickness or 2) + 2
		outline.Transparency = he.Opacity or 1

		local line = Drawing.new("Line")
		line.Visible = true
		line.Color = he.Color or Color3.fromRGB(255, 255, 255)
		line.Thickness = he.Thickness or 2
		line.Transparency = he.Opacity or 1

		table.insert(HitEffectsState.tracers, {
			line = line,
			outline = outline,
			start = os.clock(),
			life = he.Lifetime or 0.18,
			opacity = he.Opacity or 1,
			from = origin,
			to = targetPosition,
		})
		TrimHitEffects()
	end

function TryTriggerBulletTracer()
		local he = Config.ESP.HitEffects and Config.ESP.HitEffects.BulletTracer
		if not he or not he.Enabled then
			return
		end
		local equippedWeapon = GetEquippedWeaponObject()
		if not equippedWeapon then
			return
		end
		if not HasEquippedWeaponAmmo(equippedWeapon) then
			return
		end
		if not LeftMouseButtonDown then
			return
		end

		local currentTime = tick()
		local fireRate = math.max(0.01, tonumber(he.FireRate) or 0.06)
		if (currentTime - lastBulletTracerTime) < fireRate then
			return
		end

		local origin = ResolveBulletTracerOrigin()
		local targetPosition = ResolveBulletTracerTargetPosition(origin)
		if not origin or not targetPosition then
			return
		end

		lastBulletTracerTime = currentTime
		TriggerBulletTracer(origin, targetPosition)
	end

function ClearHitEffects()
		ClearHitOverlay()
		ClearDamageNumbers()
		ClearHitMarkers2D()
		ClearHitMarkers3D()
		ClearBulletTracers()
		ClearHitChams()
	end

function UpdateHitEffects(dt)
		local now = os.clock()
		if not (HitEffectsState.overlay.active or #HitEffectsState.numbers > 0 or #HitEffectsState.markers2d > 0 or #HitEffectsState.markers3d > 0 or #HitEffectsState.tracers > 0 or #HitEffectsState.chams > 0) then
			return
		end

		local overlay = EnsureHitOverlayState()
		if overlay.active and overlay.drawing then
			local life = math.max(overlay.life or 0.35, 0.01)
			local t = now - overlay.start
			if t >= life then
				overlay.drawing.Visible = false
				overlay.drawing.Transparency = 0
				overlay.active = false
			else
				local viewport = Camera.ViewportSize
				overlay.drawing.Size = Vector2.new(viewport.X, viewport.Y)
				overlay.drawing.Position = Vector2.new(0, 0)
				local fadeIn = math.min(life * 0.2, 0.08)
				local opacity = overlay.opacity or 0.35
				local alpha
				if t <= fadeIn then
					alpha = opacity * (t / fadeIn)
				else
					alpha = opacity * (1 - ((t - fadeIn) / (life - fadeIn)))
				end
				overlay.drawing.Transparency = math.clamp(alpha, 0, 1)
			end
		end

		for i = #HitEffectsState.numbers, 1, -1 do
			local item = HitEffectsState.numbers[i]
			local drawing = item.drawing
			if not drawing then
				table.remove(HitEffectsState.numbers, i)
			else
				local life = item.life or 0.9
				local t = now - item.start
				if t >= life or not item.part or not item.part.Parent then
					drawing.Visible = false
					HitEffectPools.numbers[#HitEffectPools.numbers + 1] = item
					table.remove(HitEffectsState.numbers, i)
				else
					local rise = item.rise or 1.5
					local pos, onScreen = Camera:WorldToViewportPoint(item.part.Position + Vector3.new(0, rise * (t / life), 0))
					if onScreen then
						drawing.Visible = true
						drawing.Position = Vector2.new(pos.X, pos.Y)
						drawing.Transparency = (item.opacity or 1) * (1 - (t / life))
					else
						drawing.Visible = false
					end
				end
			end
		end

		local function UpdateMarker(marker, position2d)
			local size = marker.size or 10
			local gap = marker.gap or 5
			local cx = position2d.X
			local cy = position2d.Y
			local from1 = Vector2.new(cx - gap - size, cy - gap - size)
			local to1 = Vector2.new(cx - gap, cy - gap)
			local from2 = Vector2.new(cx + gap + size, cy - gap - size)
			local to2 = Vector2.new(cx + gap, cy - gap)
			local from3 = Vector2.new(cx - gap - size, cy + gap + size)
			local to3 = Vector2.new(cx - gap, cy + gap)
			local from4 = Vector2.new(cx + gap + size, cy + gap + size)
			local to4 = Vector2.new(cx + gap, cy + gap)
			local pairs = {
				{from1, to1},
				{from2, to2},
				{from3, to3},
				{from4, to4},
			}
			for idx = 1, 4 do
				local line = marker.lines[idx]
				local outline = marker.outlines[idx]
				if line then
					line.From = pairs[idx][1]
					line.To = pairs[idx][2]
				end
				if outline then
					outline.From = pairs[idx][1]
					outline.To = pairs[idx][2]
				end
			end
		end

		for i = #HitEffectsState.markers2d, 1, -1 do
			local marker = HitEffectsState.markers2d[i]
			local life = marker.life or 0.2
			local t = now - marker.start
			if t >= life then
				for _, line in pairs(marker.lines or {}) do line.Visible = false end
				for _, line in pairs(marker.outlines or {}) do line.Visible = false end
				HitEffectPools.markers2d[#HitEffectPools.markers2d + 1] = marker
				table.remove(HitEffectsState.markers2d, i)
			else
				local viewport = Camera.ViewportSize
				UpdateMarker(marker, Vector2.new(viewport.X / 2, viewport.Y / 2))
				local alpha = (marker.opacity or 1) * (1 - (t / life))
				for _, line in pairs(marker.lines or {}) do line.Transparency = alpha end
				for _, line in pairs(marker.outlines or {}) do line.Transparency = alpha end
			end
		end

		for i = #HitEffectsState.markers3d, 1, -1 do
			local marker = HitEffectsState.markers3d[i]
			local life = marker.life or 0.3
			local t = now - marker.start
			if t >= life or not marker.part or not marker.part.Parent then
				for _, line in pairs(marker.lines or {}) do line.Visible = false end
				for _, line in pairs(marker.outlines or {}) do line.Visible = false end
				HitEffectPools.markers3d[#HitEffectPools.markers3d + 1] = marker
				table.remove(HitEffectsState.markers3d, i)
			else
				local pos, onScreen = Camera:WorldToViewportPoint(marker.part.Position)
				if onScreen then
					UpdateMarker(marker, Vector2.new(pos.X, pos.Y))
					local alpha = (marker.opacity or 1) * (1 - (t / life))
					for _, line in pairs(marker.lines or {}) do line.Transparency = alpha; line.Visible = true end
					for _, line in pairs(marker.outlines or {}) do line.Transparency = alpha; line.Visible = true end
				else
					for _, line in pairs(marker.lines or {}) do line.Visible = false end
					for _, line in pairs(marker.outlines or {}) do line.Visible = false end
				end
			end
		end

		for i = #HitEffectsState.tracers, 1, -1 do
			local tracer = HitEffectsState.tracers[i]
			local life = tracer.life or 0.18
			local t = now - tracer.start
			if t >= life then
				if tracer.line then pcall(function() tracer.line:Remove() end) end
				if tracer.outline then pcall(function() tracer.outline:Remove() end) end
				table.remove(HitEffectsState.tracers, i)
			else
				local fromPos, fromOnScreen = Camera:WorldToViewportPoint(tracer.from)
				local toPos, toOnScreen = Camera:WorldToViewportPoint(tracer.to)
				local visible = fromOnScreen and toOnScreen and fromPos.Z > 0 and toPos.Z > 0
				local alpha = (tracer.opacity or 1) * (1 - (t / life))
				if tracer.line then
					tracer.line.Visible = visible
					tracer.line.Transparency = alpha
					if visible then
						tracer.line.From = Vector2.new(fromPos.X, fromPos.Y)
						tracer.line.To = Vector2.new(toPos.X, toPos.Y)
					end
				end
				if tracer.outline then
					tracer.outline.Visible = visible
					tracer.outline.Transparency = alpha
					if visible then
						tracer.outline.From = Vector2.new(fromPos.X, fromPos.Y)
						tracer.outline.To = Vector2.new(toPos.X, toPos.Y)
					end
				end
			end
		end

		for i = #HitEffectsState.chams, 1, -1 do
			local item = HitEffectsState.chams[i]
			local highlight = item.highlight
			local life = item.life or 0.5
			local t = now - item.start
			if t >= life or not highlight or not highlight.Parent then
				if highlight then pcall(function() highlight:Destroy() end) end
				table.remove(HitEffectsState.chams, i)
			else
				local alpha = math.clamp(t / life, 0, 1)
				highlight.FillTransparency = (item.fill or 0.35) + (1 - (item.fill or 0.35)) * alpha
				highlight.OutlineTransparency = (item.outline or 0.1) + (1 - (item.outline or 0.1)) * alpha
			end
		end
	end

