			fakePosDotOutline.Transparency = 0.9
			fakePosDotOutline.Visible = true

			fakePosDot.Position = center
			fakePosDot.Radius = LKP_DOT_RADIUS
			fakePosDot.Color = UIColors.Bright
			fakePosDot.Filled = true
			fakePosDot.Transparency = 1
			fakePosDot.Visible = true
