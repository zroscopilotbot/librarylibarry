function is_player_descendant(inst)
		for _, plr in ipairs(PlayersService:GetPlayers()) do
			local char = plr.Character
			if char and inst:IsDescendantOf(char) then
				return true
			end
		end
		return false
	end

function cache_instance(inst, props)
		OptimizationState.Cache[inst] = props
	end

function apply_optimization_to_instance(inst)
		if OptimizationState.Cache[inst] then
			return
		end
		if is_player_descendant(inst) then
			return
		end

		if inst:IsA("MeshPart") then
			if not OptimizationConfig.DisableMeshTextures and not OptimizationConfig.DisablePartMaterials then
				return
			end
			cache_instance(inst, {
				Material = inst.Material,
				Reflectance = inst.Reflectance,
				CastShadow = inst.CastShadow,
				TextureID = inst.TextureID,
			})
			if OptimizationConfig.DisableMeshTextures then
				inst.TextureID = ""
			end
			if OptimizationConfig.DisablePartMaterials then
				inst.Material = Enum.Material.SmoothPlastic
				inst.Reflectance = 0
				inst.CastShadow = false
			end
			return
		end

		if inst:IsA("BasePart") then
			if not OptimizationConfig.DisablePartMaterials then
				return
			end
			cache_instance(inst, {
				Material = inst.Material,
				Reflectance = inst.Reflectance,
				CastShadow = inst.CastShadow,
			})
			inst.Material = Enum.Material.SmoothPlastic
			inst.Reflectance = 0
			inst.CastShadow = false
			return
		end

		if inst:IsA("Decal") or inst:IsA("Texture") then
			if not OptimizationConfig.DisableDecals then
				return
			end
			cache_instance(inst, {
				Transparency = inst.Transparency,
				Texture = inst.Texture,
			})
			inst.Transparency = 1
			return
		end

		if inst:IsA("SurfaceAppearance") then
			if not OptimizationConfig.DisableSurfaceAppearance then
				return
			end
			cache_instance(inst, {
				ColorMap = inst.ColorMap,
				NormalMap = inst.NormalMap,
				MetalnessMap = inst.MetalnessMap,
				RoughnessMap = inst.RoughnessMap,
			})
			inst.ColorMap = ""
			inst.NormalMap = ""
			inst.MetalnessMap = ""
			inst.RoughnessMap = ""
			return
		end

		if inst:IsA("SpecialMesh") then
			if not OptimizationConfig.DisableSpecialMeshTextures then
				return
			end
			cache_instance(inst, {
				TextureId = inst.TextureId,
			})
			inst.TextureId = ""
			return
		end

		if inst:IsA("ParticleEmitter")
			or inst:IsA("Trail")
			or inst:IsA("Beam")
			or inst:IsA("Fire")
			or inst:IsA("Smoke")
			or inst:IsA("Sparkles") then
			if not OptimizationConfig.DisableParticles then
				return
			end
			cache_instance(inst, {
				Enabled = inst.Enabled,
			})
			inst.Enabled = false
			return
		end

		if inst:IsA("PointLight")
			or inst:IsA("SpotLight")
			or inst:IsA("SurfaceLight") then
			if not OptimizationConfig.DisableLights then
				return
			end
			cache_instance(inst, {
				Enabled = inst.Enabled,
				Brightness = inst.Brightness,
				Range = inst.Range,
			})
			inst.Enabled = false
			return
		end

		if inst:IsA("PostEffect") then
			if not OptimizationConfig.DisablePostEffects then
				return
			end
			cache_instance(inst, {
				Enabled = inst.Enabled,
			})
			inst.Enabled = false
			return
		end
	end

function apply_optimization()
		if OptimizationState.Enabled or OptimizationState.Applying then
			return
		end

		OptimizationState.Enabled = true
		OptimizationState.Applying = true
		OptimizationState.Cache = {}
		OptimizationState.ApplyToken = (OptimizationState.ApplyToken or 0) + 1
		local token = OptimizationState.ApplyToken

		task.spawn(function()
			local function should_abort()
				return OptimizationState.ApplyToken ~= token or not OptimizationState.Enabled
			end

			local function process_descendants(root)
				local list = root:GetDescendants()
				for i = 1, #list do
					if should_abort() then return end
					apply_optimization_to_instance(list[i])
					if (i % 200) == 0 then
						task.wait()
					end
				end
			end

			process_descendants(workspace)
			process_descendants(lighting)

			if should_abort() then return end

			local terrain = workspace:FindFirstChildOfClass("Terrain")
			if terrain and OptimizationConfig.DisableTerrainWater then
				OptimizationState.Terrain = OptimizationState.Terrain or {}
				OptimizationState.Terrain.WaterWaveSize = terrain.WaterWaveSize
				OptimizationState.Terrain.WaterWaveSpeed = terrain.WaterWaveSpeed
				OptimizationState.Terrain.WaterReflectance = terrain.WaterReflectance
				OptimizationState.Terrain.WaterTransparency = terrain.WaterTransparency
				terrain.WaterWaveSize = 0
				terrain.WaterWaveSpeed = 0
				terrain.WaterReflectance = 0
				terrain.WaterTransparency = 1
				task.wait()
			end

			if terrain and OptimizationConfig.DisableTerrainDecoration then
				OptimizationState.Terrain = OptimizationState.Terrain or {}
				local ok, decoration = pcall(function()
					return terrain.Decoration
				end)
				if ok then
					OptimizationState.Terrain.Decoration = decoration
					pcall(function()
						terrain.Decoration = false
					end)
				end
				task.wait()
			end

			local clouds = lighting:FindFirstChildOfClass("Clouds")
			if clouds and OptimizationConfig.DisableClouds then
				OptimizationState.Clouds = {
					Enabled = clouds.Enabled,
				}
				clouds.Enabled = false
				task.wait()
			end

			local sky = lighting:FindFirstChildOfClass("Sky")
			if sky and OptimizationConfig.DisableSky then
				OptimizationState.Sky = {
					CelestialBodiesShown = sky.CelestialBodiesShown,
					MoonAngularSize = sky.MoonAngularSize,
					MoonTextureId = sky.MoonTextureId,
					SkyboxBk = sky.SkyboxBk,
					SkyboxDn = sky.SkyboxDn,
					SkyboxFt = sky.SkyboxFt,
					SkyboxLf = sky.SkyboxLf,
					SkyboxRt = sky.SkyboxRt,
					SkyboxUp = sky.SkyboxUp,
					StarCount = sky.StarCount,
					SunAngularSize = sky.SunAngularSize,
					SunTextureId = sky.SunTextureId,
				}
				sky.CelestialBodiesShown = false
				sky.MoonAngularSize = 0
				sky.MoonTextureId = ""
				sky.SkyboxBk = ""
				sky.SkyboxDn = ""
				sky.SkyboxFt = ""
				sky.SkyboxLf = ""
				sky.SkyboxRt = ""
				sky.SkyboxUp = ""
				sky.StarCount = 0
				sky.SunAngularSize = 0
				sky.SunTextureId = ""
				task.wait()
			end

			if OptimizationConfig.DisableLighting then
				OptimizationState.Lighting = {
					GlobalShadows = lighting.GlobalShadows,
					ShadowSoftness = lighting.ShadowSoftness,
					EnvironmentSpecularScale = lighting.EnvironmentSpecularScale,
					EnvironmentDiffuseScale = lighting.EnvironmentDiffuseScale,
				}
				lighting.GlobalShadows = false
				lighting.ShadowSoftness = 0
				lighting.EnvironmentSpecularScale = 0
				lighting.EnvironmentDiffuseScale = 0
				task.wait()
			end

			if OptimizationConfig.ForceQualityLevel then
				pcall(function()
					OptimizationState.QualityLevel = settings().Rendering.QualityLevel
					local target = QualityLevels[OptimizationConfig.QualityIndex]
					if target then
						settings().Rendering.QualityLevel = target
					end
				end)
				task.wait()
			end

			if should_abort() then return end

			if OptimizationState.WorkspaceConn then
				OptimizationState.WorkspaceConn:Disconnect()
			end
			OptimizationState.WorkspaceConn = workspace.DescendantAdded:Connect(function(inst)
				if OptimizationState.Enabled then
					apply_optimization_to_instance(inst)
				end
			end)

			if OptimizationState.LightingConn then
				OptimizationState.LightingConn:Disconnect()
			end
			OptimizationState.LightingConn = lighting.DescendantAdded:Connect(function(inst)
				if OptimizationState.Enabled then
					apply_optimization_to_instance(inst)
				end
			end)

			OptimizationState.Applying = false
		end)
	end

function restore_optimization()
		if not OptimizationState.Enabled then
			return
		end

		OptimizationState.ApplyToken = (OptimizationState.ApplyToken or 0) + 1
		OptimizationState.Applying = false
		OptimizationState.Enabled = false
		OptimizationState.FFlagsApplied = false
		disable_optimization_focus_mode()

		if OptimizationState.WorkspaceConn then
			OptimizationState.WorkspaceConn:Disconnect()
			OptimizationState.WorkspaceConn = nil
		end

		if OptimizationState.LightingConn then
			OptimizationState.LightingConn:Disconnect()
			OptimizationState.LightingConn = nil
		end

		for inst, props in pairs(OptimizationState.Cache) do
			if inst and inst.Parent then
				for prop, val in pairs(props) do
					pcall(function()
						inst[prop] = val
					end)
				end
			end
		end

		if OptimizationState.Terrain then
			local terrain = workspace:FindFirstChildOfClass("Terrain")
			if terrain then
				if OptimizationState.Terrain.WaterWaveSize ~= nil then
					terrain.WaterWaveSize = OptimizationState.Terrain.WaterWaveSize
				end
				if OptimizationState.Terrain.WaterWaveSpeed ~= nil then
					terrain.WaterWaveSpeed = OptimizationState.Terrain.WaterWaveSpeed
				end
				if OptimizationState.Terrain.WaterReflectance ~= nil then
					terrain.WaterReflectance = OptimizationState.Terrain.WaterReflectance
				end
				if OptimizationState.Terrain.WaterTransparency ~= nil then
					terrain.WaterTransparency = OptimizationState.Terrain.WaterTransparency
				end
				if OptimizationState.Terrain.Decoration ~= nil then
					pcall(function()
						terrain.Decoration = OptimizationState.Terrain.Decoration
					end)
				end
			end
			OptimizationState.Terrain = nil
		end

		if OptimizationState.Clouds then
			local clouds = lighting:FindFirstChildOfClass("Clouds")
			if clouds then
				clouds.Enabled = OptimizationState.Clouds.Enabled
			end
			OptimizationState.Clouds = nil
		end

		if OptimizationState.Sky then
			local sky = lighting:FindFirstChildOfClass("Sky")
			if sky then
				sky.CelestialBodiesShown = OptimizationState.Sky.CelestialBodiesShown
				sky.MoonAngularSize = OptimizationState.Sky.MoonAngularSize
				sky.MoonTextureId = OptimizationState.Sky.MoonTextureId
				sky.SkyboxBk = OptimizationState.Sky.SkyboxBk
				sky.SkyboxDn = OptimizationState.Sky.SkyboxDn
				sky.SkyboxFt = OptimizationState.Sky.SkyboxFt
				sky.SkyboxLf = OptimizationState.Sky.SkyboxLf
				sky.SkyboxRt = OptimizationState.Sky.SkyboxRt
				sky.SkyboxUp = OptimizationState.Sky.SkyboxUp
				sky.StarCount = OptimizationState.Sky.StarCount
				sky.SunAngularSize = OptimizationState.Sky.SunAngularSize
				sky.SunTextureId = OptimizationState.Sky.SunTextureId
			end
			OptimizationState.Sky = nil
		end

		if OptimizationState.Lighting then
			lighting.GlobalShadows = OptimizationState.Lighting.GlobalShadows
			lighting.ShadowSoftness = OptimizationState.Lighting.ShadowSoftness
			lighting.EnvironmentSpecularScale = OptimizationState.Lighting.EnvironmentSpecularScale
			lighting.EnvironmentDiffuseScale = OptimizationState.Lighting.EnvironmentDiffuseScale
			OptimizationState.Lighting = nil
		end

		if OptimizationState.QualityLevel then
			pcall(function()
				settings().Rendering.QualityLevel = OptimizationState.QualityLevel
			end)
			OptimizationState.QualityLevel = nil
		end

		OptimizationState.Cache = {}
	end


function should_enable_optimization()
		return OptimizationConfig.DisableMeshTextures
			or OptimizationConfig.DisablePartMaterials
			or OptimizationConfig.DisableDecals
			or OptimizationConfig.DisableSurfaceAppearance
			or OptimizationConfig.DisableSpecialMeshTextures
			or OptimizationConfig.DisableParticles
			or OptimizationConfig.DisableLights
			or OptimizationConfig.DisablePostEffects
			or OptimizationConfig.DisableTerrainWater
			or OptimizationConfig.DisableTerrainDecoration
			or OptimizationConfig.DisableClouds
			or OptimizationConfig.DisableSky
			or OptimizationConfig.DisableLighting
			or OptimizationConfig.ForceQualityLevel
	end

function refresh_optimization()
		if OptimizationState.Enabled then
			restore_optimization()
		end
		if should_enable_optimization() then
			apply_optimization()
		end
	end

