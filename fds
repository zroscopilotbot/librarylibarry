	function draw_crosshair()
		local c = Config.crosshair
		if not c.enabled then
			hide_ch()
			return
		end

		local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
		if c.follow_mouse and getMousePos then
			local target = getMousePos()
			smoothed_crosshair_center = smooth_follow(smoothed_crosshair_center, target, c.follow_lerp)
			center = smoothed_crosshair_center
		else
			smoothed_crosshair_center = nil
		end
		local style    = c.style
		local rot = math.rad(c.rotation or 0)
		if c.rotation_anim then
			rot = rot + (anim_t * (c.rotation_speed or 1) * math.pi * 2)
		end
		local anim_off = ch_anim_offset()
		local size     = math.max(1, c.size + anim_off)
		local gap      = math.max(0, c.gap + get_spread() + anim_off * 0.5)
		local thick    = c.thickness
		local used_lines = 0
		ch_drawings.dot.Visible = false
		ch_drawings.dot_outline.Visible = false
		ch_drawings.center_dot.Visible = false
		ch_drawings.center_dot_outline.Visible = false
		ch_drawings.circle.Visible = false
		ch_drawings.circle_outline.Visible = false
		ch_drawings.ring.Visible = false
		ch_drawings.ring_outline.Visible = false
		ch_drawings.square.Visible = false
		ch_drawings.square_outline.Visible = false
		ch_drawings.triangle.Visible = false
		ch_drawings.triangle_outline.Visible = false
		ch_drawings.ammo_text.Visible = false

		if style == "cross" or style == "t-style" then
			local ln = {
				{ from = center + Vector2.new(gap, 0),  to = center + Vector2.new(gap + size, 0),  t0 = 0.5,  t1 = 0.75 },
				{ from = center - Vector2.new(gap, 0),  to = center - Vector2.new(gap + size, 0),  t0 = 0.25, t1 = 0    },
				{ from = center - Vector2.new(0, gap),  to = center - Vector2.new(0, gap + size),  t0 = 0.75, t1 = 1    },
			}
			if style ~= "t-style" then
				table.insert(ln, { from = center + Vector2.new(0, gap), to = center + Vector2.new(0, gap + size), t0 = 0.25, t1 = 0 })
			end
			for i, l in ipairs(ln) do
				set_line(ch_drawings.lines[i], ch_drawings.outlines[i], l.from, l.to, center, rot)
				used_lines = i
			end

		elseif style == "x" then
			local d, s2 = gap * 0.707, size * 0.707
			local ln = {
				{ from = center + Vector2.new(d,  d),  to = center + Vector2.new(d+s2,  d+s2),  t0 = 0.5,  t1 = 0.75 },
				{ from = center - Vector2.new(d,  d),  to = center - Vector2.new(d+s2,  d+s2),  t0 = 0.25, t1 = 0    },
				{ from = center + Vector2.new(-d, d),  to = center + Vector2.new(-d-s2, d+s2),  t0 = 0.5,  t1 = 0.25 },
				{ from = center - Vector2.new(-d, d),  to = center - Vector2.new(-d-s2, d+s2),  t0 = 0.75, t1 = 1    },
			}
			for i, l in ipairs(ln) do
				set_line(ch_drawings.lines[i], ch_drawings.outlines[i], l.from, l.to, center, rot)
				used_lines = i
			end

		elseif style == "dot" then
			local r = c.dot_radius + anim_off * 0.5
			ch_drawings.dot.Position     = center
			ch_drawings.dot.Radius       = r
			ch_drawings.dot.Color        = ch_get_color(0.5)
			ch_drawings.dot.Filled       = c.dot_filled
			ch_drawings.dot.Transparency = c.opacity
			ch_drawings.dot.NumSides     = 30
			ch_drawings.dot.Visible      = true
			if c.show_outline then
				ch_drawings.dot_outline.Position     = center
				ch_drawings.dot_outline.Radius       = r + c.outline_thickness
				ch_drawings.dot_outline.Color        = c.outline_color
				ch_drawings.dot_outline.Filled       = false
				ch_drawings.dot_outline.Transparency = c.outline_opacity
				ch_drawings.dot_outline.NumSides     = 30
				ch_drawings.dot_outline.ZIndex       = ch_drawings.dot.ZIndex - 1
				ch_drawings.dot_outline.Visible      = true
			end

		elseif style == "circle" then
			local r = c.circle_radius + anim_off
			ch_drawings.circle.Position     = center
			ch_drawings.circle.Radius       = r
			ch_drawings.circle.Color        = ch_get_color(0.5)
			ch_drawings.circle.Filled       = false
			ch_drawings.circle.Thickness    = thick
			ch_drawings.circle.Transparency = c.opacity
			ch_drawings.circle.NumSides     = c.circle_segments
			ch_drawings.circle.Visible      = true
			if c.show_outline then
				ch_drawings.circle_outline.Position     = center
				ch_drawings.circle_outline.Radius       = r + c.outline_thickness
				ch_drawings.circle_outline.Color        = c.outline_color
				ch_drawings.circle_outline.Filled       = false
				ch_drawings.circle_outline.Thickness    = thick + c.outline_thickness * 2
				ch_drawings.circle_outline.Transparency = c.outline_opacity
				ch_drawings.circle_outline.NumSides     = c.circle_segments
				ch_drawings.circle_outline.ZIndex       = ch_drawings.circle.ZIndex - 1
				ch_drawings.circle_outline.Visible      = true
			end

		elseif style == "sniper" then
			local sg = gap * c.sniper_gap_scale
			local ss = size * 1.5
			local ln = {
				{ from = center + Vector2.new(sg,  0), to = center + Vector2.new(sg+ss, 0),  t0 = 0.5,  t1 = 0.75 },
				{ from = center - Vector2.new(sg,  0), to = center - Vector2.new(sg+ss, 0),  t0 = 0.25, t1 = 0    },
				{ from = center - Vector2.new(0,  sg), to = center - Vector2.new(0,  sg+ss), t0 = 0.75, t1 = 1    },
				{ from = center + Vector2.new(0,  sg), to = center + Vector2.new(0,  sg+ss), t0 = 0.25, t1 = 0    },
			}
			for i, l in ipairs(ln) do
				set_line(ch_drawings.lines[i], ch_drawings.outlines[i], l.from, l.to, center)
				used_lines = i
			end
			ch_drawings.center_dot.Position     = center
			ch_drawings.center_dot.Radius       = 1.5
			ch_drawings.center_dot.Color        = ch_get_color(0.5)
			ch_drawings.center_dot.Filled       = true
			ch_drawings.center_dot.Transparency = c.opacity
			ch_drawings.center_dot.NumSides     = 10
			ch_drawings.center_dot.Visible      = true

		elseif style == "arrow" then
			local tip   = center - Vector2.new(0, gap + size * 0.6)
			local left  = center + Vector2.new(-size, -gap)
			local right = center + Vector2.new(size,  -gap)
			set_line(ch_drawings.lines[1], ch_drawings.outlines[1], tip, left, center, rot)
			set_line(ch_drawings.lines[2], ch_drawings.outlines[2], tip, right, center, rot)
			used_lines = 2

		elseif style == "triangle" then
			local r2 = size + gap
			local p1 = center + Vector2.new(math.cos(math.rad(-90))       * r2, math.sin(math.rad(-90))       * r2)
			local p2 = center + Vector2.new(math.cos(math.rad(30))        * r2, math.sin(math.rad(30))        * r2)
			local p3 = center + Vector2.new(math.cos(math.rad(150))       * r2, math.sin(math.rad(150))       * r2)
			set_line(ch_drawings.lines[1], ch_drawings.outlines[1], p1, p2, center, rot)
			set_line(ch_drawings.lines[2], ch_drawings.outlines[2], p2, p3, center, rot)
			set_line(ch_drawings.lines[3], ch_drawings.outlines[3], p3, p1, center, rot)
			used_lines = 3

		elseif style == "square" then
			local r2  = size + gap
			ch_drawings.square.Size         = Vector2.new(r2*2, r2*2)
			ch_drawings.square.Position     = center - Vector2.new(r2, r2)
			ch_drawings.square.Color        = ch_get_color(0.5)
			ch_drawings.square.Filled       = false
			ch_drawings.square.Thickness    = thick
			ch_drawings.square.Transparency = c.opacity
			ch_drawings.square.Visible      = true
			if c.show_outline then
				local ot = c.outline_thickness
				ch_drawings.square_outline.Size         = Vector2.new(r2*2 + ot*2, r2*2 + ot*2)
				ch_drawings.square_outline.Position     = center - Vector2.new(r2 + ot, r2 + ot)
				ch_drawings.square_outline.Color        = c.outline_color
				ch_drawings.square_outline.Filled       = false
				ch_drawings.square_outline.Thickness    = thick + ot*2
				ch_drawings.square_outline.Transparency = c.outline_opacity
				ch_drawings.square_outline.ZIndex       = ch_drawings.square.ZIndex - 1
				ch_drawings.square_outline.Visible      = true
			end
		end
		if c.ring_enabled then
			local ring_col = c.ring_use_gradient and ch_get_color(0.5) or c.ring_color
			local r = math.max(1, c.ring_radius + anim_off * 0.5)
			ch_drawings.ring.Position     = center
			ch_drawings.ring.Radius       = r
			ch_drawings.ring.Color        = ring_col
			ch_drawings.ring.Filled       = false
			ch_drawings.ring.Thickness    = c.ring_thickness
			ch_drawings.ring.Transparency = c.ring_opacity
			ch_drawings.ring.NumSides     = c.ring_segments
			ch_drawings.ring.Visible      = true
			if c.show_outline then
				ch_drawings.ring_outline.Position     = center
				ch_drawings.ring_outline.Radius       = r + c.outline_thickness
				ch_drawings.ring_outline.Color        = c.outline_color
				ch_drawings.ring_outline.Filled       = false
				ch_drawings.ring_outline.Thickness    = c.ring_thickness + c.outline_thickness * 2
				ch_drawings.ring_outline.Transparency = c.outline_opacity
				ch_drawings.ring_outline.NumSides     = c.ring_segments
				ch_drawings.ring_outline.ZIndex       = ch_drawings.ring.ZIndex - 1
				ch_drawings.ring_outline.Visible      = true
			end
		end
		if c.show_center_dot and style ~= "dot" and style ~= "sniper" then
			local col = c.center_dot_gradient and ch_get_color(0.5) or c.center_dot_color
			ch_drawings.center_dot.Position     = center
			ch_drawings.center_dot.Radius       = c.center_dot_size
			ch_drawings.center_dot.Color        = col
			ch_drawings.center_dot.Filled       = true
			ch_drawings.center_dot.Transparency = c.opacity
			ch_drawings.center_dot.NumSides     = 20
			ch_drawings.center_dot.Visible      = true
			if c.show_outline then
				ch_drawings.center_dot_outline.Position     = center
				ch_drawings.center_dot_outline.Radius       = c.center_dot_size + c.outline_thickness
				ch_drawings.center_dot_outline.Color        = c.outline_color
				ch_drawings.center_dot_outline.Filled       = false
				ch_drawings.center_dot_outline.Transparency = c.outline_opacity
				ch_drawings.center_dot_outline.NumSides     = 20
				ch_drawings.center_dot_outline.ZIndex       = ch_drawings.center_dot.ZIndex - 1
				ch_drawings.center_dot_outline.Visible      = true
			end
		end

		for i = used_lines + 1, 8 do
			ch_drawings.lines[i].Visible = false
			ch_drawings.outlines[i].Visible = false
		end

		if c.ammo_text_enabled then
			local ammo = GetEquippedWeaponAmmo()
			if ammo ~= nil then
				local text = tostring(math.max(0, math.floor(tonumber(ammo) or 0)))
				local yOffset = math.max(size + gap + (c.ammo_text_offset or 14), 12)
				if c.ring_enabled then
					yOffset = math.max(yOffset, (c.ring_radius or 18) + (c.ammo_text_offset or 14))
				end
				ch_drawings.ammo_text.Text = text
				ch_drawings.ammo_text.Size = c.ammo_text_size or 13
				ch_drawings.ammo_text.Color = c.use_gradient and ch_get_color(0.5) or c.color
				ch_drawings.ammo_text.Transparency = c.opacity
				ch_drawings.ammo_text.Position = center + Vector2.new(0, yOffset)
				ch_drawings.ammo_text.Visible = true
			end
		end
	end

	--========================================================--
	--  draw fov
	--========================================================--

function update_fov_glow(f, center, radius, fov_sides, glow)
		if not f.glow_enabled then
			hide_fov_glow(glow)
			return
		end
		local layers = math.clamp(tonumber(f.glow_layers) or 15, 1, MAX_FOV_GLOW_LAYERS)
		local size = 1
		local thickness = 1
		local glow_color = f.glow_color or f.color
		for i = 1, layers do
			local g = glow[i]
			g.Position = center
			g.Radius = radius + (size * i)
			g.Transparency = math.clamp(1 - (i / (layers + 1)), 0, 1)
			g.Color = glow_color
			g.Thickness = thickness
			g.Filled = false
			g.NumSides = fov_sides
			g.Visible = true
		end
		for i = layers + 1, MAX_FOV_GLOW_LAYERS do
			glow[i].Visible = false
		end
	end

	function draw_fov()
		local function draw_fov_mode(mode, f, circle_outline, circle_fill, lines, double_lines, dash_lines, markers, ring_lines, fill_tris, points_cache, glow)
			if not f.ShowFov then
				circle_outline.Visible = false
				circle_fill.Visible = false
				hide_fov_glow(glow)
				hide_fov_fill_tris(fill_tris)
				hide_fov_extra_set(lines, double_lines, dash_lines, markers, ring_lines)
				return
			end

			local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
			if f.follow_mouse and getMousePos then
				local target = getMousePos()
				if mode == "silent" then
					smoothed_fov_center_silent = smooth_follow(smoothed_fov_center_silent, target, f.follow_lerp)
					center = smoothed_fov_center_silent
				else
					smoothed_fov_center_aimbot = smooth_follow(smoothed_fov_center_aimbot, target, f.follow_lerp)
					center = smoothed_fov_center_aimbot
				end
			else
				if mode == "silent" then
					smoothed_fov_center_silent = center
				else
					smoothed_fov_center_aimbot = center
				end
			end

			local ring_enabled = (f.ring_enabled ~= nil and f.ring_enabled) or f.double_ring
			local use_custom = f.use_gradient or f.dashed or f.shape ~= "circle"
				or ring_enabled or f.markers or f.anim_style ~= "none"

			local radius = f.FovSize
			if use_custom then
				radius = math.max(1, f.FovSize + fov_anim_offset_for(f))
			end

			local fov_sides = math.min(f.FovSegments or 64, MAX_FOV_SEG)
			circle_outline.Position = center
			circle_outline.Radius = f.FovSize
			circle_outline.Transparency = f.FovTransparency
			circle_outline.Filled = false
			circle_outline.NumSides = fov_sides
			circle_outline.Color = f.color
			circle_outline.Thickness = f.line_thickness or 2
			circle_outline.Visible = not use_custom

			local fill_alpha = f.FovFillTransparency or f.FovTransparency
			local fill_with_tris = (f.FovFilled == true) and (f.shape ~= "circle")
			local fill_color = (f.fill_use_color and f.fill_color) or f.color

			circle_fill.Position = center
			circle_fill.Radius = ((use_custom and f.shape == "circle") and radius) or f.FovSize
			circle_fill.Transparency = fill_alpha
			circle_fill.Filled = true
			circle_fill.NumSides = fov_sides
			circle_fill.Color = fill_color
			circle_fill.Visible = (f.FovFilled == true) and (f.shape == "circle")

			update_fov_glow(f, center, radius, fov_sides, glow)

			if not fill_with_tris then
				hide_fov_fill_tris(fill_tris)
			end

			if not use_custom then
				hide_fov_extra_set(lines, double_lines, dash_lines, markers, ring_lines)
				return
			end

			circle_outline.Visible = false

			local rot_off  = math.rad(f.shape_rotation) + fov_anim_angle_for(f) + math.rad(f.gradient_angle)
			local segments = math.min(f.segments or f.FovSegments or 64, MAX_FOV_SEG)

			local function shape_point(angle, r)
				local sh = f.shape
				if sh == "circle" then
					return center + Vector2.new(math.cos(angle) * r, math.sin(angle) * r)

				elseif sh == "square" then
					local a  = ((angle % (math.pi*2)) + math.pi*2) % (math.pi*2)
					local q  = math.floor(a / (math.pi/2))
					local t2 = (a % (math.pi/2)) / (math.pi/2) * 2 - 1
					local nx, ny
					if     q == 0 then nx, ny =  r,  t2*r
					elseif q == 1 then nx, ny = -t2*r,  r
					elseif q == 2 then nx, ny = -r, -t2*r
					else               nx, ny =  t2*r, -r end
					return center + Vector2.new(nx, ny)

				elseif sh == "triangle" then
					local a = angle + rot_off
					local p1 = center + Vector2.new(math.cos(a) * r, math.sin(a) * r)
					local p2 = center + Vector2.new(math.cos(a + (2 * math.pi / 3)) * r, math.sin(a + (2 * math.pi / 3)) * r)
					local p3 = center + Vector2.new(math.cos(a + (4 * math.pi / 3)) * r, math.sin(a + (4 * math.pi / 3)) * r)
					local t = ((a % (math.pi*2)) + math.pi*2) % (math.pi*2)
					if t < (2 * math.pi / 3) then
						return p1:Lerp(p2, t / (2 * math.pi / 3))
					elseif t < (4 * math.pi / 3) then
						return p2:Lerp(p3, (t - (2 * math.pi / 3)) / (2 * math.pi / 3))
					else
						return p3:Lerp(p1, (t - (4 * math.pi / 3)) / (2 * math.pi / 3))
					end

				elseif sh == "diamond" then
					local a  = ((angle % (math.pi*2)) + math.pi*2) % (math.pi*2)
					local q  = math.floor(a / (math.pi/2))
					local t2 = (a % (math.pi/2)) / (math.pi/2)
					if     q == 0 then return center + Vector2.new( r*(1-t2),  r*t2)
					elseif q == 1 then return center + Vector2.new(-r*t2,      r*(1-t2))
					elseif q == 2 then return center + Vector2.new(-r*(1-t2), -r*t2)
					else               return center + Vector2.new( r*t2,     -r*(1-t2)) end

				elseif sh == "hexagon" then
					local sides  = 6
					local slice  = math.pi * 2 / sides
					local norm_a = ((angle + rot_off) % (math.pi*2) + math.pi*2) % (math.pi*2)
					local q      = math.floor(norm_a / slice)
					local t2     = (norm_a - q * slice) / slice
					local a1     = q * slice - rot_off
					local a2     = (q+1) * slice - rot_off
					local p1     = center + Vector2.new(math.cos(a1)*r, math.sin(a1)*r)
					local p2     = center + Vector2.new(math.cos(a2)*r, math.sin(a2)*r)
					return p1:Lerp(p2, t2)
				end

				return center + Vector2.new(math.cos(angle) * r, math.sin(angle) * r)
			end

			local function get_fov_color(t)
				if f.use_gradient then
					local adjusted = ((t or 0) + (f.gradient_angle / 360)) % 1
					return lerp_color(f.gradient_a, f.gradient_b, adjusted)
				end
				return f.color
			end

			local points = points_cache
			local needs_points = fill_with_tris or (not f.dashed)
			if needs_points then
				for i = 1, segments do
					local angle = rot_off + ((i - 1) / segments) * TWO_PI
					points[i] = shape_point(angle, radius)
				end
			end

			if fill_with_tris then
				for i = 1, segments do
					local tri = fill_tris[i]
					local p1 = points[i]
					local p2 = points[(i % segments) + 1]
					tri.PointA = center
					tri.PointB = p1
					tri.PointC = p2
					tri.Color = (f.fill_use_color and f.fill_color) or get_fov_color((i - 0.5) / segments)
					tri.Transparency = fill_alpha
					tri.Visible = true
				end
				for i = segments + 1, MAX_FOV_SEG do
					fill_tris[i].Visible = false
				end
			end

			if f.dashed then
				for i = 1, MAX_FOV_SEG do
					lines[i].Visible = false
				end
				local count = math.min(f.dash_count, 32)
				for i = 1, count do
					local sa = rot_off + (i-1) * (TWO_PI / count)
					local ea = sa + (TWO_PI / count) * (1 - f.dash_gap)
					dash_lines[i].From         = shape_point(sa, radius)
					dash_lines[i].To           = shape_point(ea, radius)
					dash_lines[i].Color        = get_fov_color((i - 0.5) / count)
					dash_lines[i].Thickness    = f.dash_thickness or 2
					dash_lines[i].Transparency = f.FovTransparency
					dash_lines[i].Visible      = true
				end
				for i = count + 1, 32 do
					dash_lines[i].Visible = false
				end
			else
				for i = 1, 32 do
					dash_lines[i].Visible = false
				end
				for i = 1, segments do
					local prev = points[i]
					local nxt = points[(i % segments) + 1]
					lines[i].From         = prev
					lines[i].To           = nxt
					lines[i].Color        = get_fov_color((i - 0.5) / segments)
					lines[i].Thickness    = f.line_thickness or 2
					lines[i].Transparency = f.FovTransparency
					lines[i].Visible      = true
				end
				for i = segments + 1, MAX_FOV_SEG do
					lines[i].Visible = false
				end
			end

			if ring_enabled then
				local ring_count = math.clamp(tonumber(f.ring_count) or (f.double_ring and 2 or 1), 1, MAX_FOV_RINGS)
				local ring_spacing = tonumber(f.ring_spacing) or f.double_ring_offset or 10
				local ring_opacity = tonumber(f.ring_opacity) or f.double_ring_opacity or 0.4
				local ring_thickness = tonumber(f.ring_thickness) or f.double_ring_thickness or 1
				for r = 1, ring_count do
					local r2   = radius + ring_spacing * r
					for i = 1, segments do
						local angle = rot_off + ((i - 1) / segments) * TWO_PI
						local prev = shape_point(angle, r2)
						local nxt = shape_point(angle + (TWO_PI / segments), r2)
						local line = ring_lines[r][i]
						line.From         = prev
						line.To           = nxt
						line.Color        = get_fov_color((i - 0.5) / segments)
						line.Thickness    = ring_thickness
						line.Transparency = ring_opacity
						line.Visible      = true
					end
					for i = segments + 1, MAX_FOV_SEG do
						ring_lines[r][i].Visible = false
					end
				end
				for r = ring_count + 1, MAX_FOV_RINGS do
					for i = 1, MAX_FOV_SEG do
						ring_lines[r][i].Visible = false
					end
				end
			else
				for r = 1, MAX_FOV_RINGS do
					for i = 1, MAX_FOV_SEG do
						ring_lines[r][i].Visible = false
					end
				end
			end

			if f.markers then
				local count = math.min(f.marker_count, 32)
				for i = 1, count do
					local angle = rot_off + (i-1) * (TWO_PI / count)
					markers[i].From         = shape_point(angle, radius - f.marker_length)
					markers[i].To           = shape_point(angle, radius + f.marker_length)
					markers[i].Color        = f.marker_color
					markers[i].Thickness    = f.marker_thickness or 2
					markers[i].Transparency = f.marker_opacity
					markers[i].Visible      = true
				end
				for i = count + 1, 32 do
					markers[i].Visible = false
				end
			else
				for i = 1, 32 do
					markers[i].Visible = false
				end
			end
		end

		draw_fov_mode(
			"silent",
			Config.Combat.SilentAim,
			silentCircle,
			silentCircleFill,
			fov_lines_silent,
			fov_double_lines_silent,
			fov_dash_lines_silent,
			fov_markers_silent,
			fov_ring_lines_silent,
			fov_fill_tris_silent,
			fov_points_cache_silent,
			fov_glow_silent
		)

		draw_fov_mode(
			"aimbot",
			Config.Combat.Aimbot,
			aimbotCircle,
			aimbotCircleFill,
			fov_lines_aimbot,
			fov_double_lines_aimbot,
			fov_dash_lines_aimbot,
			fov_markers_aimbot,
			fov_ring_lines_aimbot,
			fov_fill_tris_aimbot,
			fov_points_cache_aimbot,
			fov_glow_aimbot
		)

		local deadzoneRadius = getCurrentDeadzoneSize()
		if Config.Combat.DeadzoneFovShow and deadzoneRadius > 0 then
			local center = getDeadzoneCenter()
			deadzoneCircle.Position = center
			deadzoneCircle.Radius = deadzoneRadius
			deadzoneCircle.Transparency = 1
			deadzoneCircle.Filled = false
			deadzoneCircle.NumSides = math.min(64, MAX_FOV_SEG)
			deadzoneCircle.Color = Color3.fromRGB(255, 0, 0)
			deadzoneCircle.Thickness = 1
			deadzoneCircle.Visible = true
		else
			deadzoneCircle.Visible = false
		end

		if Config.Combat.SilentAim.ShowFov or Config.Combat.Aimbot.ShowFov then
			circle.Visible = false
			hide_fov_glow(fov_glow)
			hide_fov_extra()
			hide_fov_fill_tris(fov_fill_tris)
			return
		end

		local f = getCurrentFovConfig()
		local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
		if f.follow_mouse and getMousePos then
			local target = getMousePos()
			smoothed_fov_center = smooth_follow(smoothed_fov_center, target, f.follow_lerp)
			center = smoothed_fov_center
		else
			smoothed_fov_center = center
		end
		local radius   = math.max(1, getCurrentFovSize() + fov_anim_offset())
		local rot_off  = math.rad(f.shape_rotation) + fov_anim_angle() + math.rad(f.gradient_angle)
		local segments = math.min(f.segments, MAX_FOV_SEG)

		circle.Position = center
		circle.Radius = getCurrentFovSize()
		circle.Transparency = getCurrentFovTransparency()
		circle.Filled = getCurrentFovFilled()
		circle.NumSides = getCurrentFovSegments()
		circle.Color = getCurrentFovColor()

		update_fov_glow(f, center, radius, getCurrentFovSegments(), fov_glow)

		if not getCurrentShowFov() then
			circle.Visible = false
			hide_fov_glow(fov_glow)
			hide_fov_extra()
			hide_fov_fill_tris(fov_fill_tris)
			return
		end

		local ring_enabled = (f.ring_enabled ~= nil and f.ring_enabled) or f.double_ring
		local use_custom = f.use_gradient or f.dashed or f.shape ~= "circle"
			or ring_enabled or f.markers or f.anim_style ~= "none"

		circle.Visible = not use_custom

		if not use_custom then
			hide_fov_extra()
			hide_fov_fill_tris(fov_fill_tris)
			return
		end

		circle.Visible = false

		local function shape_point(angle, r)
			local sh = f.shape
			if sh == "circle" then
				return center + Vector2.new(math.cos(angle) * r, math.sin(angle) * r)

			elseif sh == "square" then
				local a  = ((angle % (math.pi*2)) + math.pi*2) % (math.pi*2)
				local q  = math.floor(a / (math.pi/2))
				local t2 = (a % (math.pi/2)) / (math.pi/2) * 2 - 1
				local nx, ny
				if     q == 0 then nx, ny =  r,  t2*r
				elseif q == 1 then nx, ny = -t2*r,  r
				elseif q == 2 then nx, ny = -r, -t2*r
				else               nx, ny =  t2*r, -r end
				return center + Vector2.new(nx, ny)

			elseif sh == "diamond" then
				local a  = ((angle % (math.pi*2)) + math.pi*2) % (math.pi*2)
				local q  = math.floor(a / (math.pi/2))
				local t2 = (a % (math.pi/2)) / (math.pi/2)
				if     q == 0 then return center + Vector2.new( r*(1-t2),  r*t2)
				elseif q == 1 then return center + Vector2.new(-r*t2,      r*(1-t2))
				elseif q == 2 then return center + Vector2.new(-r*(1-t2), -r*t2)
				else               return center + Vector2.new( r*t2,     -r*(1-t2)) end

			elseif sh == "hexagon" then
				local sides  = 6
				local slice  = math.pi * 2 / sides
				local norm_a = ((angle + rot_off) % (math.pi*2) + math.pi*2) % (math.pi*2)
				local q      = math.floor(norm_a / slice)
				local t2     = (norm_a - q * slice) / slice
				local a1     = q * slice - rot_off
				local a2     = (q+1) * slice - rot_off
				local p1     = center + Vector2.new(math.cos(a1)*r, math.sin(a1)*r)
				local p2     = center + Vector2.new(math.cos(a2)*r, math.sin(a2)*r)
				return p1:Lerp(p2, t2)
			end

			return center + Vector2.new(math.cos(angle) * r, math.sin(angle) * r)
		end

		local function get_fov_color(t)
			if f.use_gradient then
				local adjusted = ((t or 0) + (f.gradient_angle / 360)) % 1
				return lerp_color(f.gradient_a, f.gradient_b, adjusted)
			end
			return f.color
		end

			local points = fov_points_cache
			local needs_points = (getCurrentFovFilled() and f.shape ~= "circle") or (not f.dashed)
			if needs_points then
				for i = 1, segments do
					local angle = rot_off + ((i - 1) / segments) * TWO_PI
					points[i] = shape_point(angle, radius)
				end
			end

		if getCurrentFovFilled() and f.shape ~= "circle" then
			for i = 1, segments do
				local tri = fov_fill_tris[i]
				local p1 = points[i]
				local p2 = points[(i % segments) + 1]
				tri.PointA = center
				tri.PointB = p1
				tri.PointC = p2
				tri.Color = get_fov_color((i - 0.5) / segments)
				tri.Transparency = getCurrentFovTransparency()
				tri.Visible = true
			end
			for i = segments + 1, MAX_FOV_SEG do
				fov_fill_tris[i].Visible = false
			end
		else
			hide_fov_fill_tris(fov_fill_tris)
		end

		if f.dashed then
			for i = 1, MAX_FOV_SEG do
				fov_lines[i].Visible = false
			end
			local count = math.min(f.dash_count, 32)
			for i = 1, count do
				local sa = rot_off + (i-1) * (TWO_PI / count)
				local ea = sa + (TWO_PI / count) * (1 - f.dash_gap)
				fov_dash_lines[i].From         = shape_point(sa, radius)
				fov_dash_lines[i].To           = shape_point(ea, radius)
				fov_dash_lines[i].Color        = get_fov_color((i - 0.5) / count)
				fov_dash_lines[i].Thickness    = f.dash_thickness or 2
				fov_dash_lines[i].Transparency = f.FovTransparency or getCurrentFovTransparency()
				fov_dash_lines[i].Visible      = true
			end
			for i = count + 1, 32 do
				fov_dash_lines[i].Visible = false
			end
		else
			for i = 1, 32 do
				fov_dash_lines[i].Visible = false
			end
			for i = 1, segments do
				local prev = points[i]
				local nxt = points[(i % segments) + 1]
				fov_lines[i].From         = prev
				fov_lines[i].To           = nxt
				fov_lines[i].Color        = get_fov_color((i - 0.5) / segments)
				fov_lines[i].Thickness    = f.line_thickness or 2
				fov_lines[i].Transparency = f.FovTransparency or getCurrentFovTransparency()
				fov_lines[i].Visible      = true
			end
			for i = segments + 1, MAX_FOV_SEG do
				fov_lines[i].Visible = false
			end
		end

		if ring_enabled then
			local ring_count = math.clamp(tonumber(f.ring_count) or (f.double_ring and 2 or 1), 1, MAX_FOV_RINGS)
			local ring_spacing = tonumber(f.ring_spacing) or f.double_ring_offset or 10
			local ring_opacity = tonumber(f.ring_opacity) or f.double_ring_opacity or 0.4
			local ring_thickness = tonumber(f.ring_thickness) or f.double_ring_thickness or 1
			for r = 1, ring_count do
				local r2   = radius + ring_spacing * r
				for i = 1, segments do
					local angle = rot_off + ((i - 1) / segments) * TWO_PI
					local prev = shape_point(angle, r2)
					local nxt = shape_point(angle + (TWO_PI / segments), r2)
					local line = fov_ring_lines[r][i]
					line.From         = prev
					line.To           = nxt
					line.Color        = get_fov_color((i - 0.5) / segments)
					line.Thickness    = ring_thickness
					line.Transparency = ring_opacity
					line.Visible      = true
				end
				for i = segments + 1, MAX_FOV_SEG do
					fov_ring_lines[r][i].Visible = false
				end
			end
			for r = ring_count + 1, MAX_FOV_RINGS do
				for i = 1, MAX_FOV_SEG do
					fov_ring_lines[r][i].Visible = false
				end
			end
		else
			for r = 1, MAX_FOV_RINGS do
				for i = 1, MAX_FOV_SEG do
					fov_ring_lines[r][i].Visible = false
				end
			end
		end

		if f.markers then
			local count = math.min(f.marker_count, 32)
			for i = 1, count do
				local angle = rot_off + (i-1) * (TWO_PI / count)
				fov_markers[i].From         = shape_point(angle, radius - f.marker_length)
				fov_markers[i].To           = shape_point(angle, radius + f.marker_length)
				fov_markers[i].Color        = f.marker_color
				fov_markers[i].Thickness    = f.marker_thickness or 2
				fov_markers[i].Transparency = f.marker_opacity
				fov_markers[i].Visible      = true
			end
			for i = count + 1, 32 do
				fov_markers[i].Visible = false
			end
		else
			for i = 1, 32 do
				fov_markers[i].Visible = false
			end
		end
	end

