			fakePosWorldPos = nil
			if fakePosDot then fakePosDot.Visible = false end
			if fakePosDotOutline then fakePosDotOutline.Visible = false end
			return
		end

		fakePosWorldPos = FakePositionState.Position
		if fakePosRenderConn then
			return
		end

		if not fakePosDot then
			fakePosDot = new_circle()
			fakePosDot.ZIndex = 9
		end

		if not fakePosDotOutline then
			fakePosDotOutline = new_circle()
			fakePosDotOutline.ZIndex = 8
		end

		fakePosRenderConn = RunService.RenderStepped:Connect(function()
			if not fakePosWorldPos or not Camera then
