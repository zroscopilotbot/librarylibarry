	local function get_hitbox_expander_part_names()
		local selected = Config.HitboxExpander.SelectedParts
		if type(selected) ~= "table" then
			selected = selected and {selected} or {"all"}
		end

		local useAll = #selected == 0
		local unique = {}
		local parts = {}

		for _, option in ipairs(selected) do
			if tostring(option):lower() == "all" then
				useAll = true
				break
			end
		end

		local groupsToUse = useAll and {"all"} or selected
		for _, groupName in ipairs(groupsToUse) do
			local group = HITBOX_EXPANDER_PART_GROUPS[tostring(groupName):lower()]
			if group then
				for _, partName in ipairs(group) do
					if not unique[partName] then
						unique[partName] = true
						parts[#parts + 1] = partName
					end
				end
			end
		end

		return parts
	end

	local function get_hitbox_size_vector()
		local sizeX = math.max(1, tonumber(Config.HitboxExpander.SizeX) or 10)
		local sizeY = math.max(1, tonumber(Config.HitboxExpander.SizeY) or 10)
		return Vector3.new(sizeX, sizeY, sizeX)
	end

	local function store_hitbox_part_state(playerState, part)
		if not playerState or not part or playerState.OriginalParts[part] then
			return
		end
		playerState.OriginalParts[part] = {
			Size = part.Size,
			Transparency = part.Transparency,
			CanCollide = part.CanCollide,
		}
	end

	local function restore_hitbox_target_state(targetKey, targetState)
		if not targetState then
			return
		end
		for part, original in pairs(targetState.OriginalParts) do
			if part and part.Parent then
				part.Size = original.Size
				part.Transparency = original.Transparency
				part.CanCollide = original.CanCollide
			end
		end
		targetState.OriginalParts = {}
		targetState.Character = nil
	end

	local function ensure_hitbox_target_state(targetKey, character)
		local targetState = HitboxExpanderState.Targets[targetKey]
		if not targetState then
			targetState = {
				Character = character,
				OriginalParts = {},
			}
			HitboxExpanderState.Targets[targetKey] = targetState
			return targetState
		end
		if targetState.Character ~= character then
			restore_hitbox_target_state(targetKey, targetState)
			targetState.Character = character
		end
		return targetState
	end

	local function get_hitbox_expander_targets()
		local targets = {}

		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character then
				if (not Config.HitboxExpander.TeamCheck) or IsPlayerEnemy(player) then
					targets[#targets + 1] = {
						Key = player,
						Character = player.Character,
					}
				end
			end
		end

		if Config.HitboxExpander.TargetNPCs then
			for _, model in ipairs(GetNpcModelsCached()) do
				if model and model.Parent then
					targets[#targets + 1] = {
						Key = model,
						Character = model,
					}
				end
			end
		end

		return targets
	end

	function RestoreHitboxExpander()
		for targetKey, targetState in pairs(HitboxExpanderState.Targets) do
			restore_hitbox_target_state(targetKey, targetState)
			if not targetKey or not targetKey.Parent then
				HitboxExpanderState.Targets[targetKey] = nil
			end
		end
	end

	local function stop_hitbox_expander_loop()
		if HitboxExpanderState.Loop then
			task.cancel(HitboxExpanderState.Loop)
			HitboxExpanderState.Loop = nil
		end
		if HitboxExpanderState.Connection then
			HitboxExpanderState.Connection:Disconnect()
			HitboxExpanderState.Connection = nil
		end
	end

	function UpdateHitboxExpander()
		if not Config.HitboxExpander.Enabled or not LocalPlayer.Character then
			RestoreHitboxExpander()
			return
		end

		local targetSize = get_hitbox_size_vector()
		local method = tostring(Config.HitboxExpander.Method or "v1")
		local selectedPartNames = get_hitbox_expander_part_names()

		if method == "v1" then
			local targetTransparency = Config.HitboxExpander.Visible and 0.45 or 5
			local activeTargets = {}

			for _, targetInfo in ipairs(get_hitbox_expander_targets()) do
				local targetKey = targetInfo.Key
				local character = targetInfo.Character
				activeTargets[targetKey] = true
				if character then
					local targetState = ensure_hitbox_target_state(targetKey, character)

					for _, partName in ipairs(selectedPartNames) do
						local part = character:FindFirstChild(partName)
						if part and part:IsA("BasePart") then
							store_hitbox_part_state(targetState, part)
							part.CanCollide = false
							part.Transparency = targetTransparency
							part.Size = targetSize
						end
					end
				end
			end

			for targetKey, targetState in pairs(HitboxExpanderState.Targets) do
				if not targetKey or not targetKey.Parent or not activeTargets[targetKey] then
					restore_hitbox_target_state(targetKey, targetState)
					HitboxExpanderState.Targets[targetKey] = nil
				end
			end

			return
		end

		local targetTransparency = Config.HitboxExpander.Visible and 0.45 or 1
		local activeTargets = {}

		for _, targetInfo in ipairs(get_hitbox_expander_targets()) do
			local targetKey = targetInfo.Key
			local character = targetInfo.Character
			activeTargets[targetKey] = true
			if character then
				local targetState = ensure_hitbox_target_state(targetKey, character)
				local partsToExpand = {}

				for _, partName in ipairs(selectedPartNames) do
					local part = character:FindFirstChild(partName)
					if part and part:IsA("BasePart") then
						partsToExpand[#partsToExpand + 1] = part
					end
				end

				local activeParts = {}
				for i = 1, #partsToExpand do
					local part = partsToExpand[i]
					activeParts[part] = true
					store_hitbox_part_state(targetState, part)
					part.CanCollide = false
					part.Transparency = targetTransparency
					part.Size = targetSize
				end

				for part, original in pairs(targetState.OriginalParts) do
					if not activeParts[part] then
						if part and part.Parent then
							part.Size = original.Size
							part.Transparency = original.Transparency
							part.CanCollide = original.CanCollide
						end
						targetState.OriginalParts[part] = nil
					end
				end
			end
		end

		for targetKey, targetState in pairs(HitboxExpanderState.Targets) do
			if not targetKey or not targetKey.Parent or not activeTargets[targetKey] then
				restore_hitbox_target_state(targetKey, targetState)
				HitboxExpanderState.Targets[targetKey] = nil
			end
		end
	end

	function RefreshHitboxExpanderState()
		stop_hitbox_expander_loop()

		if not Config.HitboxExpander.Enabled then
			RestoreHitboxExpander()
			return
		end

		if tostring(Config.HitboxExpander.Method or "v1") == "v1" then
			UpdateHitboxExpander()
			HitboxExpanderState.Connection = RunService.Stepped:Connect(function()
				if Config.HitboxExpander.Enabled and tostring(Config.HitboxExpander.Method or "v1") == "v1" then
					UpdateHitboxExpander()
				end
			end)
			HitboxExpanderState.Loop = task.spawn(function()
				while HitboxExpanderState.Connection and Config.HitboxExpander.Enabled and tostring(Config.HitboxExpander.Method or "v1") == "v1" do
					task.wait(0.25)
				end
			end)
		else
			UpdateHitboxExpander()
		end
	end

	function ToggleInfiniteJump(enabled)
		if enabled then
			if Config.Movement.InfiniteJump.Connection then
				Config.Movement.InfiniteJump.Connection:Disconnect()
			end
			local debounce = false
			Config.Movement.InfiniteJump.Connection = UserInputService.JumpRequest:Connect(function()
				local humanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildWhichIsA("Humanoid")
				if not humanoid then
					return
				end

				if Config.Movement.InfiniteJump.Type == "Classic" then
					if debounce then
						return
					end
					debounce = true
					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
					task.wait()
					debounce = false
				else
					humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end)
		else
			if Config.Movement.InfiniteJump.Connection then
				Config.Movement.InfiniteJump.Connection:Disconnect()
				Config.Movement.InfiniteJump.Connection = nil
			end
		end
	end

	function StartLegacyFly(vfly)
		local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid")

		if flyKeyDown then
			flyKeyDown:Disconnect()
			flyKeyDown = nil
		end
		if flyKeyUp then
			flyKeyUp:Disconnect()
			flyKeyUp = nil
		end

		local root = character:WaitForChild("HumanoidRootPart")
		local control = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
		local lastControl = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
		local speed = 0

		local function FLY()
			FLYING = true
			local gyro = Instance.new("BodyGyro")
			local velocity = Instance.new("BodyVelocity")
			gyro.P = 9e4
			gyro.Parent = root
			velocity.Parent = root
			gyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
			gyro.CFrame = root.CFrame
			velocity.Velocity = Vector3.new(0, 0, 0)
			velocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
			task.spawn(function()
				repeat task.wait()
					local camera = workspace.CurrentCamera
					if not vfly and humanoid then
						humanoid.PlatformStand = true
					end

					if control.L + control.R ~= 0 or control.F + control.B ~= 0 or control.Q + control.E ~= 0 then
						speed = 50
					elseif speed ~= 0 then
						speed = 0
					end

					if (control.L + control.R) ~= 0 or (control.F + control.B) ~= 0 or (control.Q + control.E) ~= 0 then
						velocity.Velocity = ((camera.CFrame.LookVector * (control.F + control.B))
							+ ((camera.CFrame * CFrame.new(control.L + control.R, (control.F + control.B + control.Q + control.E) * 0.2, 0).Position)
								- workspace.CurrentCamera.CFrame.Position)) * speed
						lastControl = {F = control.F, B = control.B, L = control.L, R = control.R, Q = control.Q, E = control.E}
					elseif speed ~= 0 then
						velocity.Velocity = ((camera.CFrame.LookVector * (lastControl.F + lastControl.B))
							+ ((camera.CFrame * CFrame.new(lastControl.L + lastControl.R, (lastControl.F + lastControl.B + control.Q + control.E) * 0.2, 0).Position)
								- workspace.CurrentCamera.CFrame.Position)) * speed
					else
						velocity.Velocity = Vector3.new(0, 0, 0)
					end
					gyro.CFrame = camera.CFrame
				until not FLYING
				control = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
				lastControl = {F = 0, B = 0, L = 0, R = 0, Q = 0, E = 0}
				speed = 0
				gyro:Destroy()
				velocity:Destroy()

				if humanoid then humanoid.PlatformStand = false end
			end)
		end

		flyKeyDown = UserInputService.InputBegan:Connect(function(input, processed)
			if processed then return end
			local flySpeed = vfly and Config.Movement.Fly.vehicleflyspeed or Config.Movement.Fly.iyflyspeed
			if input.KeyCode == Enum.KeyCode.W then
				control.F = flySpeed
			elseif input.KeyCode == Enum.KeyCode.S then
				control.B = -flySpeed
			elseif input.KeyCode == Enum.KeyCode.A then
				control.L = -flySpeed
			elseif input.KeyCode == Enum.KeyCode.D then
				control.R = flySpeed
			elseif input.KeyCode == Enum.KeyCode.E and Config.Movement.Fly.QEfly then
				control.Q = flySpeed * 2
			elseif input.KeyCode == Enum.KeyCode.Q and Config.Movement.Fly.QEfly then
				control.E = -flySpeed * 2
			end
			pcall(function() Camera.CameraType = Enum.CameraType.Track end)
		end)

		flyKeyUp = UserInputService.InputEnded:Connect(function(input, processed)
			if processed then return end
			if input.KeyCode == Enum.KeyCode.W then
				control.F = 0
			elseif input.KeyCode == Enum.KeyCode.S then
				control.B = 0
			elseif input.KeyCode == Enum.KeyCode.A then
				control.L = 0
			elseif input.KeyCode == Enum.KeyCode.D then
				control.R = 0
			elseif input.KeyCode == Enum.KeyCode.E then
				control.Q = 0
			elseif input.KeyCode == Enum.KeyCode.Q then
				control.E = 0
			end
		end)

		FLY()
	end

	function StartDefaultFly()
		local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
		local humanoid = character:WaitForChild("Humanoid")
		local root = character:WaitForChild("HumanoidRootPart")
		local floatVelocity = Vector3.new(0, math.pi - 2, 0)

		FLYING = true

		if flyLoop then
			flyLoop:Disconnect()
			flyLoop = nil
		end

		flyLoop = RunService.Heartbeat:Connect(function(dt)
			if not FLYING then
				return
			end

			if not character.Parent or not humanoid.Parent or not root.Parent then
				StopFly()
				return
			end

			local moveDirection = humanoid.MoveDirection
			local camera = workspace.CurrentCamera
			if not camera then
				return
			end

			local verticalInput = 0
			if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
				verticalInput = 1
			elseif UserInputService:IsKeyDown(Enum.KeyCode.S) then
				verticalInput = -camera.CFrame.LookVector.Y * math.clamp(moveDirection.Magnitude, 0, 1)
			elseif UserInputService:IsKeyDown(Enum.KeyCode.W) then
				verticalInput = camera.CFrame.LookVector.Y * math.clamp(moveDirection.Magnitude, 0, 1)
			end

			root.Velocity = floatVelocity
			root.CFrame = root.CFrame + (Vector3.new(
				moveDirection.X,
				verticalInput,
				moveDirection.Z
			) * dt * (Config.Movement.Fly.iyflyspeed * 50))
		end)
	end

	function StartFly(vfly)
		StopFly()
		if tostring(Config.Movement.Fly.Method or "Default") == "Classic" then
			StartLegacyFly(vfly)
			return
		end
		StartDefaultFly()
	end

	function StopFly()
		FLYING = false
		if flyKeyDown then
			flyKeyDown:Disconnect()
			flyKeyDown = nil
		end
		if flyKeyUp then
			flyKeyUp:Disconnect()
			flyKeyUp = nil
		end
		if flyLoop then
			flyLoop:Disconnect()
			flyLoop = nil
		end
		if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
			LocalPlayer.Character:FindFirstChildOfClass("Humanoid").PlatformStand = false
		end
	end

