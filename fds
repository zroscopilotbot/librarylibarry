	function queue_auto_execute_for_next_teleport()
		local queueHandler = get_queue_on_teleport_handler()
		if type(queueHandler) ~= "function" then
			return false, "Your executor does not support queue_on_teleport."
		end

		local ok, result = prepare_auto_execute_payload()
		if not ok then
			return false, result
		end

		local queuedSource = string.format([[
		pcall(function()
			if getgenv then
				getgenv().XYLO_UNIVERSAL_RUNNING = false
			end
			local flagPath = "%s"
			if isfile and loadstring and game and isfile(flagPath) then
				local players = game:GetService("Players")
				if not game:IsLoaded() then
					game.Loaded:Wait()
				end
				while not players.LocalPlayer do
					task.wait()
				end
				loadstring(game:HttpGet("https://raw.githubusercontent.com/zroscopilotbot/librarylibarry/refs/heads/main/fds"))()
			end
		end)
		]], escape_lua_string(teleportAutoExecuteFlagPath))

		queueHandler(queuedSource)
		return true
	end

