	function ResolveKeybindActiveValue(currentState, callbackValue)
		if type(callbackValue) == "table" then
			if type(callbackValue.active) == "boolean" then
				return callbackValue.active
			end
			return currentState
		end
		if typeof(callbackValue) == "EnumItem" and callbackValue.EnumType == Enum.UserInputState then
			return callbackValue == Enum.UserInputState.Begin
		end
		if type(callbackValue) == "boolean" then
			return callbackValue
		end
		return not currentState
	end

	function ResolveKeybindAssignedKey(callbackValue)
		if typeof(callbackValue) == "EnumItem" and (callbackValue.EnumType == Enum.KeyCode or callbackValue.EnumType == Enum.UserInputType) then
			return callbackValue
		end
		return nil
	end

	function ResolveKeybindStoredKey(callbackValue)
		local directKey = ResolveKeybindAssignedKey(callbackValue)
		if directKey then
			return directKey
		end
		if type(callbackValue) == "table" then
			local key = callbackValue.key
			if typeof(key) == "EnumItem" and (key.EnumType == Enum.KeyCode or key.EnumType == Enum.UserInputType) then
				return key
			end
		end
		return nil
	end

	function IsMatchingBoundInput(input, boundKey)
		if not input or not boundKey or typeof(boundKey) ~= "EnumItem" then
			return false
		end
		if boundKey.EnumType == Enum.KeyCode then
			return input.KeyCode == boundKey
		end
		if boundKey.EnumType == Enum.UserInputType then
			return input.UserInputType == boundKey
		end
		return false
	end

