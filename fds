	anim_t = 0
	last_frame_dt = 0
	last_fov_draw = 0
	TWO_PI = math.pi * 2

	function lerp_color(a, b, t)
		return Color3.new(
			a.R + (b.R - a.R) * t,
			a.G + (b.G - a.G) * t,
			a.B + (b.B - a.B) * t
		)
	end

function smooth_follow(prev, target, slow)
		if not prev then return target end
		local s = math.max(0, slow or 0)
		if s <= 0 then
			return target
		end
		local t = math.clamp(s / 5, 0, 1)
		local speed = 25 - (t * 22)
		local dt = last_frame_dt or (1 / 60)
		local alpha = 1 - math.exp(-dt * speed)
		alpha = math.clamp(alpha, 0.02, 1)
		return prev:Lerp(target, alpha)
	end

function rotate_point(point, center, angle)
		if not angle or angle == 0 then return point end
		local dx = point.X - center.X
		local dy = point.Y - center.Y
		local ca = math.cos(angle)
		local sa = math.sin(angle)
		return Vector2.new(
			center.X + dx * ca - dy * sa,
			center.Y + dx * sa + dy * ca
		)
	end

