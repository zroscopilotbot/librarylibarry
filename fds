function resolve_flag_color(value, fallback)
		if typeof(value) == "Color3" then
			return value
		end
		if type(value) == "table" then
			if value.__type == "Color3" and value.value then
				local ok, c = pcall(Color3.fromHex, value.value)
				if ok then return c end
			end
			if value.Color then
				if typeof(value.Color) == "Color3" then
					return value.Color
				end
				if type(value.Color) == "string" then
					local ok, c = pcall(Color3.fromHex, value.Color)
					if ok then return c end
				end
			end
		end
		return fallback
	end

