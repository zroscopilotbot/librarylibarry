	function GetWhitelistTargetPriority(target)
		if not (Config and Config.Combat and Config.Combat.WhitelistCheck) then
			return 0
		end
		local targetPlayer = nil
		if typeof(target) == "Instance" and target:IsA("Model") then
			targetPlayer = Players:GetPlayerFromCharacter(target)
		end
		if not targetPlayer then
			return 0
		end
		local status = GetPlayerWhitelistStatus(targetPlayer)
		if status == "Enemy" then
			return 2
		end
		if status == "Friendly" then
			return -1
		end
		return 1
	end
	function ShouldPreferTargetCandidate(candidate, candidateDistance, bestTarget, bestDistance)
		if not candidate then
			return false
		end
		if not bestTarget then
			return true
		end
		local candidatePriority = GetWhitelistTargetPriority(candidate)
		local bestPriority = GetWhitelistTargetPriority(bestTarget)
		if candidatePriority ~= bestPriority then
			return candidatePriority > bestPriority
		end
		return candidateDistance < bestDistance
	end
