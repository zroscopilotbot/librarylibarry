	function UpdateLockedTargetIndicators()
		if not (Config.Combat.lockedTarget and Config.ESP.LockedTargetIndicators) then
			if lockedTargetESP.Avatar then lockedTargetESP.Avatar.Enabled = false end
			if lockedTargetESP.Highlight then lockedTargetESP.Highlight.Enabled = false end
			lockedTargetESP.currentPlayer = nil
			lockedTargetESP.currentKey = nil
			return
		end
		local target = Config.Combat.lockedTarget
		local player = Players:GetPlayerFromCharacter(target)
		local character = nil
		if player then
			character = player.Character
		elseif typeof(target) == "Instance" then
			if target:IsA("Model") then
				character = target
			elseif target:IsA("BasePart") then
				character = target:FindFirstAncestorOfClass("Model")
			end
		end
		if not character then return end
		local headPart = character:FindFirstChild("Head") or character:FindFirstChild("Head", true)
		if not headPart then return end
		local distance = (headPart.Position - Camera.CFrame.Position).Magnitude
		local size = 50 / math.clamp(distance / 20, 0.5, 5)
		local key = player or character
		local targetChanged = key ~= lockedTargetESP.currentKey
		if not lockedTargetESP.Avatar or targetChanged then
			if lockedTargetESP.Avatar then
				lockedTargetESP.Avatar:Destroy()
			end
			lockedTargetESP.Avatar = Instance.new("BillboardGui")
			lockedTargetESP.Avatar.Parent = headPart
			lockedTargetESP.Avatar.Adornee = headPart
			lockedTargetESP.Avatar.StudsOffset = Vector3.new(0, 2, 0)
			lockedTargetESP.Avatar.AlwaysOnTop = true
			local image = Instance.new("ImageLabel")
			image.Parent = lockedTargetESP.Avatar
			image.Size = UDim2.new(1, 0, 1, 0)
			image.BackgroundTransparency = 0
			image.BackgroundColor3 = Config.ESP.LockedTargetAvatarBackgroundColor
			image.Image = ""
			local corner = Instance.new("UICorner")
			corner.CornerRadius = UDim.new(0.5, 0)
			corner.Parent = image
			local stroke = Instance.new("UIStroke")
			stroke.Parent = image
			if player then
				task.spawn(function()
					local success, thumb = pcall(function()
						return Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
					end)
					if success then
						image.Image = thumb
					end
				end)
			else
				image.Image = ""
			end
		end
		lockedTargetESP.currentPlayer = player
		lockedTargetESP.currentKey = key
		lockedTargetESP.Avatar.Size = UDim2.new(0, size, 0, size)
		lockedTargetESP.Avatar.Enabled = Config.ESP.LockedTargetAvatar
		local image = lockedTargetESP.Avatar:FindFirstChild("ImageLabel")
		if image then
			local stroke = image:FindFirstChild("UIStroke")
			if stroke then
				stroke.Color = Config.ESP.LockedTargetAvatarBorderColor
				stroke.Thickness = Config.ESP.LockedTargetAvatarBorderThickness
			end
		end
		if Config.ESP.LockedTargetGlow then
			if not lockedTargetESP.Highlight or targetChanged then
				if lockedTargetESP.Highlight then
					lockedTargetESP.Highlight:Destroy()
				end
				lockedTargetESP.Highlight = Instance.new("Highlight")
				lockedTargetESP.Highlight.Parent = character
				lockedTargetESP.Highlight.FillColor = Config.ESP.LockedTargetGlowColor
				lockedTargetESP.Highlight.OutlineColor = Config.ESP.LockedTargetGlowColor
				lockedTargetESP.Highlight.FillTransparency = Config.ESP.LockedTargetGlowTransparency
				lockedTargetESP.Highlight.OutlineTransparency = 0
			end
			lockedTargetESP.Highlight.Enabled = true
		else
			if lockedTargetESP.Highlight then
				lockedTargetESP.Highlight.Enabled = false
			end
		end
	end

	function GetHealthColor(health, maxHealth)
		local percentage = health / maxHealth
		if percentage > 0.5 then
			return Config.ESP.Colors.HealthHigh
		elseif percentage > 0.2 then
			return Config.ESP.Colors.HealthMedium
		else
			return Config.ESP.Colors.HealthLow
		end
	end

	function GetTracerOrigin()
		local viewportSize = Camera.ViewportSize
		
		if Config.ESP.TracerOrigin == "Bottom" then
			return Vector2.new(viewportSize.X / 2, viewportSize.Y)
		elseif Config.ESP.TracerOrigin == "Top" then
			return Vector2.new(viewportSize.X / 2, 0)
		elseif Config.ESP.TracerOrigin == "Mouse" then
			local mousePos = UserInputService:GetMouseLocation()
			return mousePos
		else
			return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
		end
	end

	function IsESPPointInExpandedViewport(point, viewportSize)
		if not point or point.Z <= 0 then
			return false
		end
		return point.X >= -ESP_SCREEN_MARGIN_X
			and point.X <= (viewportSize.X + ESP_SCREEN_MARGIN_X)
			and point.Y >= -ESP_SCREEN_MARGIN_Y
			and point.Y <= (viewportSize.Y + ESP_SCREEN_MARGIN_Y)
	end

	function BuildESPVisibilityState(rootPart, headPart)
		local viewportSize = ESPFrameState.ViewportSize or Camera.ViewportSize
		local rootScreenPos, rootOnScreen = Camera:WorldToViewportPoint(rootPart.Position)
		local headScreenPos, headOnScreen = nil, false
		local headBoxPos, headBoxOnScreen = nil, false
		local rootBoxPos, rootBoxOnScreen = Camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
		if headPart then
			headScreenPos, headOnScreen = Camera:WorldToViewportPoint(headPart.Position)
			headBoxPos, headBoxOnScreen = Camera:WorldToViewportPoint(headPart.Position + Vector3.new(0, 0.5, 0))
		end

		local rootVisible = rootOnScreen and IsESPPointInExpandedViewport(rootScreenPos, viewportSize)
		local headVisible = headOnScreen and headScreenPos and IsESPPointInExpandedViewport(headScreenPos, viewportSize)
		local headBoxVisible = headBoxOnScreen and headBoxPos and IsESPPointInExpandedViewport(headBoxPos, viewportSize)
		local rootBoxVisible = rootBoxOnScreen and rootBoxPos and IsESPPointInExpandedViewport(rootBoxPos, viewportSize)

		return {
			RootPoint = rootScreenPos,
			RootOnScreen = rootOnScreen and rootScreenPos.Z > 0,
			HeadPoint = headScreenPos,
			HeadOnScreen = headOnScreen and headScreenPos and headScreenPos.Z > 0,
			HeadBoxPoint = headBoxPos,
			HeadBoxOnScreen = headBoxOnScreen and headBoxPos and headBoxPos.Z > 0,
			RootBoxPoint = rootBoxPos,
			RootBoxOnScreen = rootBoxOnScreen and rootBoxPos and rootBoxPos.Z > 0,
			DetailedVisible = rootVisible or headVisible or headBoxVisible or rootBoxVisible,
		}
	end

