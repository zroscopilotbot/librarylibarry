	uis = UserInputService or game:GetService("UserInputService")
	uis.InputBegan:Connect(function(input, gameProcessed)
		local now = tick()
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local keyName = KeyLogger.keycode_to_key[input.KeyCode]
			if keyName then
				set_keylogger_state(keyName, true)
			end
		end
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			set_keylogger_state("M1", true)
			table.insert(KeyLogger.cps.M1, now)

			local mousePos = getMousePos()
			local keySize = 30
			local spacing = 6
			local spaceWidth = keySize * 3 + spacing * 2
			local keyloggerHeight = keySize * 3 + spacing * 2
			local x = KeyLogger.position.X
			local y = KeyLogger.position.Y

			if mousePos.X >= x and mousePos.X <= x + spaceWidth and mousePos.Y >= y and mousePos.Y <= y + keyloggerHeight then
				KeyLogger.dragging = true
				KeyLogger.dragOffset = mousePos - KeyLogger.position
			end

			if KeybindList.visible and KeybindList.initialized then
				local bx = KeybindList.position.X
				local by = KeybindList.position.Y
				local bw = KeybindList.width
				local bh = KeybindList.titleHeight
				if mousePos.X >= bx and mousePos.X <= bx + bw and mousePos.Y >= by and mousePos.Y <= by + bh then
					KeybindList.dragging = true
					KeybindList.dragOffset = mousePos - KeybindList.position
				end
			end

			if FPSPing.enabled and FPSPing.initialized then
				local fx = FPSPing.position.X
				local fy = FPSPing.position.Y
				if mousePos.X >= fx and mousePos.X <= fx + FPSPing.width
				and mousePos.Y >= fy and mousePos.Y <= fy + FPSPing.height then
					FPSPing.dragging = true
					FPSPing.dragOffset = mousePos - FPSPing.position
				end
			end

		elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
			set_keylogger_state("M2", true)
			table.insert(KeyLogger.cps.M2, now)
		end

		if gameProcessed then return end

		local triggerBoundKey = (TriggerKeybind and TriggerKeybind.key) or (Config and Config.TriggerBot and Config.TriggerBot.Key)
		local flickBoundKey = (FlickKeybind and FlickKeybind.key) or (Config and Config.Combat and Config.Combat.FlickBot and Config.Combat.FlickBot.Key)
		local orbitBoundKey = (OrbitKeybind and OrbitKeybind.key) or (Config and Config.Combat and Config.Combat.OrbitKeybind)
		local cframeBoundKey = (CFrameKeybind and CFrameKeybind.key) or (Config and Config.Movement and Config.Movement.CFrameSpeed and Config.Movement.CFrameSpeed.Keybind)

		if IsMatchingBoundInput(input, triggerBoundKey) then
			triggerKeyDown = true
		end
		if IsMatchingBoundInput(input, flickBoundKey) then
			flickKeyDown = true
		end
		if IsMatchingBoundInput(input, orbitBoundKey) then
			orbitKeyDown = true
		end
		if IsMatchingBoundInput(input, cframeBoundKey) then
			cframeKeyDown = true
		end

		if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == ui_toggle_hotkey then
			set_ui_visibility()
		end
	end)

	uis.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			local mousePos = getMousePos()

			if KeyLogger.dragging then
				local keySize = 30
				local spacing = 6
				local spaceWidth = keySize * 3 + spacing * 2
				local keyloggerHeight = keySize * 3 + spacing * 2
				local targetX = math.clamp(mousePos.X - KeyLogger.dragOffset.X, 0, math.max(Camera.ViewportSize.X - spaceWidth, 0))
				local targetY = math.clamp(mousePos.Y - KeyLogger.dragOffset.Y, 0, math.max(Camera.ViewportSize.Y - keyloggerHeight, 0))
				KeyLogger.position = Vector2.new(targetX, targetY)
				Config.Overlays.KeyloggerX = targetX
				Config.Overlays.KeyloggerY = targetY
				if flags then
					flags["ui_keylogger_x"] = targetX
					flags["ui_keylogger_y"] = targetY
				end
			end

			if KeybindList.dragging then
				local targetX = math.clamp(mousePos.X - KeybindList.dragOffset.X, 0, Camera.ViewportSize.X - KeybindList.width)
				local targetY = math.clamp(mousePos.Y - KeybindList.dragOffset.Y, 0, Camera.ViewportSize.Y - 60)
				KeybindList.position = Vector2.new(targetX, targetY)
				Config.Overlays.KeybindListX = targetX
    			Config.Overlays.KeybindListY = targetY
			end

			if FPSPing.dragging then
				local targetX = math.clamp(mousePos.X - FPSPing.dragOffset.X, 0, Camera.ViewportSize.X - FPSPing.width)
				local targetY = math.clamp(mousePos.Y - FPSPing.dragOffset.Y, 0, Camera.ViewportSize.Y - FPSPing.height)
				FPSPing.position = Vector2.new(targetX, targetY)
				Config.Overlays.FPSPingX = targetX
    			Config.Overlays.FPSPingY = targetY
			end
		end
	end)

