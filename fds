	function CreateLKPIndicator(frozenCFrame, labelText)
		if Config.Desync.Mode ~= "desync v2" and Config.Desync.Mode ~= "desync v3" then return end

		lkpWorldPos = frozenCFrame.Position

		if not lkpDot then
			lkpDot = new_circle()
			lkpDot.ZIndex = 7
		end

		if not lkpDotOutline then
			lkpDotOutline = new_circle()
			lkpDotOutline.ZIndex = 6
		end

		if lkpRenderConn then
			lkpRenderConn:Disconnect()
			lkpRenderConn = nil
		end

		lkpDot.Color = UIColors.Accent
		lkpDot.Filled = true
		lkpDot.Visible = false
		lkpDot.Transparency = 1
		lkpDot.Radius = LKP_DOT_RADIUS

		lkpDotOutline.Color = UIColors.Outline
		lkpDotOutline.Filled = true
		lkpDotOutline.Visible = false
		lkpDotOutline.Transparency = 0.9
		lkpDotOutline.Radius = LKP_DOT_RADIUS + LKP_OUTLINE_PAD

		lkpRenderConn = RunService.RenderStepped:Connect(function()
			if not lkpWorldPos or not Camera then
				if lkpDot then lkpDot.Visible = false end
				if lkpDotOutline then lkpDotOutline.Visible = false end
				return
			end

			local screenPos, onScreen = Camera:WorldToViewportPoint(lkpWorldPos)
			if not onScreen or screenPos.Z <= 0 then
				if lkpDot then lkpDot.Visible = false end
				if lkpDotOutline then lkpDotOutline.Visible = false end
				return
			end

			local center = Vector2.new(screenPos.X, screenPos.Y)
			lkpDotOutline.Position = center
			lkpDotOutline.Radius = LKP_DOT_RADIUS + LKP_OUTLINE_PAD
			lkpDotOutline.Visible = true

			lkpDot.Position = center
			lkpDot.Radius = LKP_DOT_RADIUS
			lkpDot.Visible = true
		end)
	end

