	function serialize_value(v)
		local t = typeof(v)
		if t == "Color3" then
			return { __type = "Color3", value = v:ToHex() }
		elseif t == "Vector3" then
			return { __type = "Vector3", x = v.X, y = v.Y, z = v.Z }
		elseif t == "Vector2" then
			return { __type = "Vector2", x = v.X, y = v.Y }
		elseif t == "EnumItem" then
			return { __type = "EnumItem", value = tostring(v) }
		elseif t == "UDim2" then
			return { __type = "UDim2", xScale = v.X.Scale, xOffset = v.X.Offset, yScale = v.Y.Scale, yOffset = v.Y.Offset }
		elseif t == "UDim" then
			return { __type = "UDim", scale = v.Scale, offset = v.Offset }
		elseif t == "CFrame" then
			return { __type = "CFrame", components = { v:GetComponents() } }
		elseif type(v) == "table" then
			local out = {}
			for k, val in pairs(v) do
				local sv = serialize_value(val)
				if sv ~= nil then
					out[k] = sv
				end
			end
			return out
		elseif type(v) == "number" or type(v) == "string" or type(v) == "boolean" then
			return v
		end
		return nil
	end

	function deserialize_value(v)
		if type(v) ~= "table" then
			return v
		end
		if v.__type == "Color3" then
			return Color3.fromHex(v.value or "ffffff")
		elseif v.__type == "Vector3" then
			return Vector3.new(v.x or 0, v.y or 0, v.z or 0)
		elseif v.__type == "Vector2" then
			return Vector2.new(v.x or 0, v.y or 0)
		elseif v.__type == "EnumItem" then
			return (library and library.convert_enum and library:convert_enum(v.value)) or v.value
		elseif v.__type == "UDim2" then
			return UDim2.new(v.xScale or 0, v.xOffset or 0, v.yScale or 0, v.yOffset or 0)
		elseif v.__type == "UDim" then
			return UDim.new(v.scale or 0, v.offset or 0)
		elseif v.__type == "CFrame" then
			local c = v.components
			if type(c) == "table" then
				return CFrame.new(unpack(c))
			end
			return CFrame.new()
		end
		local out = {}
		for k, val in pairs(v) do
			out[k] = deserialize_value(val)
		end
		return out
	end

	function merge_table(dst, src)
		for k, v in pairs(src) do
			if type(v) == "table" and type(dst[k]) == "table" and v.__type == nil then
				merge_table(dst[k], v)
			else
				dst[k] = v
			end
		end
	end

	function build_full_config_json()
		local flags_table = HttpService:JSONDecode(library:get_config())
		CapturePlayerListPriorityConfig()
		local config_table = serialize_value(Config)
		local payload = {
			__format = "xylos_full_v1",
			flags = flags_table,
			config = config_table,
			feature_manifest = get_feature_manifest(),
			blocked_features = BlockedFeatures,
		}
		return HttpService:JSONEncode(payload)
	end
	function load_full_config_json(raw)
		local ok, decoded = pcall(function()
			return HttpService:JSONDecode(raw)
		end)

		if ok and type(decoded) == "table" and decoded.__format == "xylos_full_v1" then
			local flags_payload = decoded.flags or {}
			library:load_config(HttpService:JSONEncode(flags_payload))
			if apply_flags_to_config then
				apply_flags_to_config()
			end
			if AnimationsDirty ~= nil then
				LastAppliedCharacter = nil
				AnimationsDirty = true
				ApplyCustomAnimations(LocalPlayer.Character)
			end

			if decoded.config then
				local restored = deserialize_value(decoded.config)
				if type(restored) == "table" then
					merge_table(Config, restored)
				end
			end
			if Config.ESP and Config.ESP.SoundsRange == nil and Config.ESP.SoundsRadius ~= nil then
				Config.ESP.SoundsRange = Config.ESP.SoundsRadius
			end
			rebuild_feature_manifest()
			apply_blocked_features(decoded.blocked_features)

			if Config.UI and Config.UI.Accent then
				local accent = Config.UI.Accent
				if flags then flags["ui_accent"] = accent end
				if themes and themes.preset then themes.preset.accent = accent end
				if library then library:update_theme("accent", accent) end
			end

			if Config.Overlays then
				KeyLogger.position = Vector2.new(
					Config.Overlays.KeyloggerX or 20,
					Config.Overlays.KeyloggerY or 400
				)
				FPSPing.position = Vector2.new(
					Config.Overlays.FPSPingX or 20,
					Config.Overlays.FPSPingY or 20
				)
				KeybindList.position = Vector2.new(
					Config.Overlays.KeybindListX or 20,
					Config.Overlays.KeybindListY or 140
				)
			end
			ApplySavedPlayerPriorities()
			sync_keybind_active_states()
			return true
		end
		return false
	end

	function normalize_flag_value(v)
		if type(v) ~= "table" then
			return v
		end
		if v.__type then
			return deserialize_value(v)
		end
		if v.Color then
			return normalize_flag_value(v.Color)
		end
		if v.r and v.g and v.b then
			return Color3.new(tonumber(v.r) or 0, tonumber(v.g) or 0, tonumber(v.b) or 0)
		end
		if v.R and v.G and v.B then
			return Color3.new(tonumber(v.R) or 0, tonumber(v.G) or 0, tonumber(v.B) or 0)
		end
		if v.hex or v.Hex or v.value then
			local hex = v.hex or v.Hex or v.value
			if type(hex) == "string" then
				local ok, c = pcall(Color3.fromHex, hex)
				if ok then return c end
			end
		end
		return v
	end

	apply_flags_to_config = function()
		if not library or not library.config_flags then
			return
		end
		for flag, setter in pairs(library.config_flags) do
			local v = flags[flag]
			if v ~= nil then
				setter(normalize_flag_value(v))
			end
		end

		if flags and flags["ui_accent"] then
			local accent = normalize_flag_value(flags["ui_accent"])
			if type(accent) == "string" then
				local ok, parsed = pcall(Color3.fromHex, accent)
				if ok and typeof(parsed) == "Color3" then
					accent = parsed
				end
			end
			if typeof(accent) == "Color3" then
				Config.UI = Config.UI or {}
				Config.UI.Accent = accent
				if themes and themes.preset then themes.preset.accent = accent end
				library:update_theme("accent", accent)
			end
		end

		if AnimationsDirty ~= nil then
			LastAppliedCharacter = nil
			ApplyAnimationFromFlags()
		end
	end

	function sanitize_folder_name(name)
		local s = tostring(name or "")
		-- Remove characters forbidden by Windows path file/folder names.
		s = s:gsub('[<>:"/\\|%?%*]', '')
		-- Remove control chars (newline/tab, etc.).
		s = s:gsub('[%c]', '')
		-- Remove emoji and non-ASCII (keep letters/digits/space/dot/underscore/dash).
		s = s:gsub('[^%w%s%-%_%.]', '')
		-- Normalize spaces.
		s = s:gsub('^%s+', ''):gsub('%s+$', ''):gsub('%s+', ' ')
		if s == '' then
			s = 'UnknownGame'
		end
		-- Limit length to avoid path-size issues.
		if #s > 100 then
			s = s:sub(1, 100)
		end
		return s
	end

	function sanitize_config_name(name)
		local s = tostring(name or "")
		s = s:gsub('[<>:"/\\|%?%*]', '')
		s = s:gsub('[%c]', '')
		s = s:gsub('[^%w%s%-%_%.]', '')
		s = s:gsub('^%s+', ''):gsub('%s+$', ''):gsub('%s+', ' ')
		if s == '' then
			s = 'config'
		end
		if #s > 80 then
			s = s:sub(1, 80)
		end
		return s
	end

