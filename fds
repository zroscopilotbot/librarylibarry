	function RefreshFriendCache()
		local player = LocalPlayer
		if not player then
			FriendCache.Lookup = {}
			FriendCache.Stamp = tick()
			FriendCache.Loaded = true
			return FriendCache.Lookup
		end

		local now = tick()
		if FriendCache.Loaded and (now - FriendCache.Stamp) < FRIEND_CACHE_TTL then
			return FriendCache.Lookup
		end

		local lookup = {}
		local ok, pages = pcall(function()
			return Players:GetFriendsAsync(player.UserId)
		end)
		if ok and pages then
			repeat
				for _, info in ipairs(pages:GetCurrentPage()) do
					local id = tonumber(info.Id)
					if id then
						lookup[id] = true
					end
				end
				if pages.IsFinished then
					break
				end
				ok = pcall(function()
					pages:AdvanceToNextPageAsync()
				end)
			until not ok
		end

		FriendCache.Lookup = lookup
		FriendCache.Stamp = now
		FriendCache.Loaded = true
		return FriendCache.Lookup
	end

