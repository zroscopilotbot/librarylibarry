	function applylightingeffectsfromflags()
		if flags["sunrays_enabled"] then
			sunrays_effect = ensureeffect("SunRays")
			sunrays_effect.Enabled = true
			sunrays_effect.Intensity = flags["sunrays_intensity"] or (Defaults.Effects.SunRays and Defaults.Effects.SunRays.Intensity) or SunRaysTheme.Intensity
			sunrays_effect.Spread = flags["sunrays_spread"] or (Defaults.Effects.SunRays and Defaults.Effects.SunRays.Spread) or SunRaysTheme.Spread
		end

		if flags["bloom_enabled"] then
			bloom_effect = ensureeffect("Bloom")
			bloom_effect.Enabled = true
			bloom_effect.Intensity = flags["bloom_intensity"] or (Defaults.Effects.Bloom and Defaults.Effects.Bloom.Intensity) or BloomTheme.Intensity
			bloom_effect.Size = flags["bloom_size"] or (Defaults.Effects.Bloom and Defaults.Effects.Bloom.Size) or BloomTheme.Size
			bloom_effect.Threshold = flags["bloom_threshold"] or (Defaults.Effects.Bloom and Defaults.Effects.Bloom.Threshold) or BloomTheme.Threshold
		end

		if flags["color_correction_enabled"] then
			color_correction = ensureeffect("ColorCorrection")
			color_correction.Enabled = true
			color_correction.Brightness = flags["cc_brightness"] or (Defaults.Effects.ColorCorrection and Defaults.Effects.ColorCorrection.Brightness) or ColorCorrectionTheme.Brightness
			color_correction.Contrast = flags["cc_contrast"] or (Defaults.Effects.ColorCorrection and Defaults.Effects.ColorCorrection.Contrast) or ColorCorrectionTheme.Contrast
			color_correction.Saturation = flags["cc_saturation"] or (Defaults.Effects.ColorCorrection and Defaults.Effects.ColorCorrection.Saturation) or ColorCorrectionTheme.Saturation
			color_correction.TintColor = resolve_flag_color(
				flags["cc_tint_color"],
				(Defaults.Effects.ColorCorrection and Defaults.Effects.ColorCorrection.TintColor) or ColorCorrectionTheme.TintColor
			)
		end

		if flags["dof_enabled"] then
			dof_effect = ensureeffect("DepthOfField")
			dof_effect.Enabled = true
			dof_effect.FarIntensity = flags["dof_far_intensity"] or (Defaults.Effects.DepthOfField and Defaults.Effects.DepthOfField.FarIntensity) or 0.75
			dof_effect.FocusDistance = flags["dof_focus_distance"] or (Defaults.Effects.DepthOfField and Defaults.Effects.DepthOfField.FocusDistance) or 10
			dof_effect.InFocusRadius = flags["dof_in_focus_radius"] or (Defaults.Effects.DepthOfField and Defaults.Effects.DepthOfField.InFocusRadius) or 20
			dof_effect.NearIntensity = flags["dof_near_intensity"] or (Defaults.Effects.DepthOfField and Defaults.Effects.DepthOfField.NearIntensity) or 0.75
		end

		if flags["blur_enabled"] then
			blur_effect = ensureeffect("Blur")
			blur_effect.Enabled = true
			blur_effect.Size = flags["blur_size"] or (Defaults.Effects.Blur and Defaults.Effects.Blur.Size) or 8
		end

		if flags["atmosphere_enabled"] then
			atmosphere = ensureeffect("Atmosphere")
			atmosphere.Color = resolve_flag_color(
				flags["atmosphere_color"],
				(Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Color) or AtmosphereTheme.Color
			)
			atmosphere.Decay = resolve_flag_color(
				flags["atmosphere_decay"],
				(Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Decay) or AtmosphereTheme.Decay
			)
			atmosphere.Glare = flags["atmosphere_glare"] or (Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Glare) or AtmosphereTheme.Glare
			atmosphere.Haze = flags["atmosphere_haze"] or (Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Haze) or AtmosphereTheme.Haze
			atmosphere.Offset = flags["atmosphere_offset"] or (Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Offset) or AtmosphereTheme.Offset
			atmosphere.Density = flags["atmosphere_density"] or (Defaults.Effects.Atmosphere and Defaults.Effects.Atmosphere.Density) or AtmosphereTheme.Density
		end
	end

