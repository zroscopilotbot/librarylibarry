function clear_self_aura()
		for _, obj in ipairs(SelfAuraState.Objects) do
			if obj and obj.Parent then
				obj:Destroy()
			end
		end
		table.clear(SelfAuraState.Objects)
		if SelfAuraState.ChildConn then
			SelfAuraState.ChildConn:Disconnect()
			SelfAuraState.ChildConn = nil
		end
		SelfAuraState.Character = nil
	end

function track_self_aura_object(obj)
		if obj then
			SelfAuraState.Objects[#SelfAuraState.Objects + 1] = obj
		end
	end

function track_particle_aura_object(obj)
		if obj then
			ParticleAuraState.Objects[#ParticleAuraState.Objects + 1] = obj
		end
	end

function clear_particle_aura()
		for _, obj in ipairs(ParticleAuraState.Objects) do
			pcall(function()
				if obj and obj.Parent then
					obj:Destroy()
				end
			end)
		end
		table.clear(ParticleAuraState.Objects)
	end

local function apply_particle_aura_color_to_instance(instance, colorValue)
		if not instance then
			return
		end
		local colorSequence = ColorSequence.new(colorValue)
		if instance:IsA("PointLight") then
			instance.Color = colorValue
		elseif instance:IsA("ParticleEmitter") or instance:IsA("Beam") or instance:IsA("Trail") then
			instance.Color = colorSequence
		end
		for _, descendant in ipairs(instance:GetDescendants()) do
			if descendant:IsA("PointLight") then
				descendant.Color = colorValue
			elseif descendant:IsA("ParticleEmitter") or descendant:IsA("Beam") or descendant:IsA("Trail") then
				descendant.Color = colorSequence
			end
		end
	end

local function get_particle_aura_template(auraName)
		if not auraName or auraName == "" then
			return nil
		end
		local cached = ParticleAuraState.Templates[auraName]
		if cached then
			return cached
		end
		local assetId = PARTICLE_AURA_ASSET_IDS[auraName]
		if not assetId then
			return nil
		end
		local ok, loaded = pcall(function()
			return game:GetObjects(assetId)
		end)
		if not ok or not loaded or not loaded[1] then
			library:notification({ text = "failed to load particle aura: " .. tostring(auraName) })
			return nil
		end
		local template = loaded[1]
		apply_particle_aura_color_to_instance(template, Config.Visuals.ParticleAuraColor)
		ParticleAuraState.Templates[auraName] = template
		return template
	end

function apply_particle_aura(character)
		clear_particle_aura()
		if not character or not Config.Visuals or not Config.Visuals.ParticleAuraEnabled then
			return
		end
		local template = get_particle_aura_template(Config.Visuals.ParticleAuraType or "angel")
		if not template then
			return
		end
		local cloned = template:Clone()
		for _, auraPart in ipairs(cloned:GetChildren()) do
			if auraPart:IsA("BasePart") then
				local targetPart = character:FindFirstChild(auraPart.Name, true)
				if targetPart and targetPart:IsA("BasePart") then
					for _, child in ipairs(auraPart:GetChildren()) do
						local childClone = child:Clone()
						childClone.Name = "ParticleAuraObject"
						childClone.Parent = targetPart
						track_particle_aura_object(childClone)
					end
				end
			end
		end
		cloned:Destroy()
	end

function refresh_particle_aura()
		local character = LocalPlayer and LocalPlayer.Character
		if not character then
			clear_particle_aura()
			return
		end
		apply_particle_aura(character)
	end

function update_particle_aura_color(colorValue)
		if not Config.Visuals then
			return
		end
		Config.Visuals.ParticleAuraColor = colorValue
		for _, template in pairs(ParticleAuraState.Templates) do
			if template then
				apply_particle_aura_color_to_instance(template, colorValue)
			end
		end
		for _, obj in ipairs(ParticleAuraState.Objects) do
			if obj then
				apply_particle_aura_color_to_instance(obj, colorValue)
			end
		end
	end

