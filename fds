	end

function start_stretch_res()
		if StretchState.Conn then
			return
		end
		StretchState.Conn = RunService.RenderStepped:Connect(function()
			local cam = workspace.CurrentCamera
			if not cam then return end
			local res = getgenv().Resolution
			if type(res) ~= "table" then return end
			local valX = res.x or 1
			local valY = res.y or 1
			valX = valX or 1
			valY = valY or 1
			cam.CFrame = cam.CFrame * CFrame.new(0, 0, 0, valX, 0, 0, 0, valY, 0, 0, 0, 1)
		end)
	end

function stop_stretch_res()
		if StretchState.Conn then
			StretchState.Conn:Disconnect()
			StretchState.Conn = nil
		end
		getgenv().gg_scripters = nil
	end

function refresh_stretch_res()
		if Config.Visuals.StretchEnabled then
			set_stretch_value(Config.Visuals.StretchX, Config.Visuals.StretchY)
			if getgenv().gg_scripters == nil or StretchState.Conn == nil then
				start_stretch_res()
			end
		else
			stop_stretch_res()
		end
	end

