	function ClampToRadarDisc(mapX, mapY, clipRadius)
		local dist2 = mapX * mapX + mapY * mapY
		if dist2 > clipRadius * clipRadius then
			local d = math.sqrt(dist2)
			local scale = clipRadius / d
			return mapX * scale, mapY * scale
		end
		return mapX, mapY
	end

	function RadarPolygonFitsAroundCenter(points, centerX, centerY, clipRadius, scale)
		local clipRadiusSq = clipRadius * clipRadius
		for i = 1, #points do
			local point = points[i]
			local px = centerX + (point.x - centerX) * scale
			local py = centerY + (point.y - centerY) * scale
			if (px * px + py * py) > clipRadiusSq then
				return false
			end
		end
		return true
	end

	function ProjectRadarFootprintPolygon(corners, localPos, flatRight, flatLook, mapScale, clipRadius, radarCenter)
		local offsets = table.create(4)
		local centroidX, centroidY = 0, 0
		local insideCount = 0
		local maxDistSq = 0
		local clipRadiusSq = clipRadius * clipRadius

		for ci = 1, 4 do
			local rel = corners[ci] - localPos
			local flatRel = Vector3.new(rel.X, 0, rel.Z)
			local mapX = flatRel:Dot(flatRight) * mapScale
			local mapY = -flatRel:Dot(flatLook) * mapScale
			offsets[ci] = { x = mapX, y = mapY }
			centroidX = centroidX + mapX
			centroidY = centroidY + mapY
			local distSq = mapX * mapX + mapY * mapY
			if distSq <= clipRadiusSq then
				insideCount = insideCount + 1
			end
			if distSq > maxDistSq then
				maxDistSq = distSq
			end
		end
		if insideCount < 4 then
			return nil
		end

		local projected = table.create(4)
		for ci = 1, 4 do
			local point = offsets[ci]
			projected[ci] = Vector2.new(radarCenter.X + point.x, radarCenter.Y + point.y)
		end

		return projected
	end

