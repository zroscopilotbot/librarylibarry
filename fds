local function enableNoclip()
	local char = LocalPlayer.Character
	if typeof(char) ~= "Instance" or not char:IsA("Model") then return end
	local ok, descendants = pcall(function()
		return char:GetDescendants()
	end)
	if not ok or type(descendants) ~= "table" then return end
	if NoclipState.Character ~= char or type(NoclipState.CollisionStates) ~= "table" then
		NoclipState.Character = char
		NoclipState.CollisionStates = {}
	end
	for _, part in ipairs(descendants) do
		if part:IsA("BasePart") then
			if NoclipState.CollisionStates[part] == nil then
				NoclipState.CollisionStates[part] = part.CanCollide
			end
			part.CanCollide = false
		end
	end
end

local function disableNoclip()
	local char = LocalPlayer.Character
	if typeof(char) ~= "Instance" or not char:IsA("Model") then return end
	if type(NoclipState.CollisionStates) == "table" then
		for part, previousState in pairs(NoclipState.CollisionStates) do
			if part and part.Parent and part:IsDescendantOf(char) and part:IsA("BasePart") then
				part.CanCollide = previousState == true
			end
		end
	end
	NoclipState.CollisionStates = nil
	NoclipState.Character = nil
end

function stop_noclip()
	if NoclipState.Connection then
		NoclipState.Connection:Disconnect()
		NoclipState.Connection = nil
	end
	disableNoclip()
end

function start_noclip()
	stop_noclip()
