			end
			Config.Desync.VoidHide.DisableWhenForcedPosition = false
			Config.Desync.VoidHide.DisableWhenFullHealth = false
			Config.Desync.VoidHide.DisableWhenRagebotActive = false
			Config.Desync.VoidHide.DisableWhenFollowTarget = false
			Config.Desync.VoidHide.DisableWhenReloading = false
			for _, option in ipairs(value) do
				if option == "forced position" then
					Config.Desync.VoidHide.DisableWhenForcedPosition = true
				elseif option == "full health" then
					Config.Desync.VoidHide.DisableWhenFullHealth = true
				elseif option == "ragebot active" then
					Config.Desync.VoidHide.DisableWhenRagebotActive = true
				elseif option == "follow target" then
					Config.Desync.VoidHide.DisableWhenFollowTarget = true
				elseif option == "reloading" then
					Config.Desync.VoidHide.DisableWhenReloading = true
				end
			end
		end
	})

