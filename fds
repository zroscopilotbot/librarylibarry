	function GetPlayerPriorityButtons()
		if not library or not library.get_priority or type(debug) ~= "table" or type(debug.getupvalue) ~= "function" then
			return nil
		end
		for i = 1, 10 do
			local ok, name, value = pcall(debug.getupvalue, library.get_priority, i)
			if ok and name == "player_buttons" and type(value) == "table" then
				return value
			end
		end
		return nil
	end
	function SetPlayerWhitelistStatus(targetPlayer, status)
		if not targetPlayer then
			return
		end
		status = NormalizePlayerPriorityStatus(status)
		Config.PlayerListPriorities = type(Config.PlayerListPriorities) == "table" and Config.PlayerListPriorities or {}
		local userKey = tostring(targetPlayer.UserId)
		if status == "Neutral" then
			Config.PlayerListPriorities[userKey] = nil
			Config.PlayerListPriorities[targetPlayer.Name] = nil
		else
			Config.PlayerListPriorities[userKey] = status
			Config.PlayerListPriorities[targetPlayer.Name] = status
		end
		local buttons = GetPlayerPriorityButtons()
		local entry = buttons and buttons[targetPlayer.Name]
		if entry and entry.priority then
			entry.priority.Text = status
			if status == "Friendly" then
				entry.priority.TextColor3 = rgb(15, 179, 255)
			elseif status == "Enemy" then
				entry.priority.TextColor3 = rgb(255, 44, 44)
			else
				entry.priority.TextColor3 = rgb(180, 180, 180)
			end
		end
	end
	function CapturePlayerListPriorityConfig()
		local captured = {}
		if not Players then
			Config.PlayerListPriorities = captured
			return captured
		end
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				local status = nil
				if library and library.get_priority then
					local ok, priority = pcall(library.get_priority, player)
					if ok then
						status = priority
					end
				end
				status = NormalizePlayerPriorityStatus(status)
				if status ~= "Neutral" then
					captured[tostring(player.UserId)] = status
					captured[player.Name] = status
				end
			end
		end
		Config.PlayerListPriorities = captured
		return captured
	end
	function ApplySavedPlayerPriority(targetPlayer)
		local saved = GetSavedPlayerPriorityStatus(targetPlayer)
		if saved and saved ~= "Neutral" then
			SetPlayerWhitelistStatus(targetPlayer, saved)
		end
	end
	function ApplySavedPlayerPriorities()
		if not Players then
			return
		end
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				ApplySavedPlayerPriority(player)
			end
		end
	end
	function GetPlayerWhitelistStatus(targetPlayer)
		if not targetPlayer then
			return "Neutral"
		end
		if library and library.get_priority then
			local ok, priority = pcall(library.get_priority, targetPlayer)
			if ok and (priority == "Friendly" or priority == "Neutral" or priority == "Enemy") then
				return priority
			end
		end
		return GetSavedPlayerPriorityStatus(targetPlayer) or "Neutral"
	end
	function IsWhitelistedPlayer(targetPlayer)
		return GetPlayerWhitelistStatus(targetPlayer) == "Friendly"
