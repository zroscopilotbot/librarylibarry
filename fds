function TriggerDamageNumber(character, damage, isLethal)
		local he = Config.ESP.HitEffects and Config.ESP.HitEffects.DamageNumber
		if not he or not he.Enabled then return end
		local part = GetHitEffectPart(character)
		if not part then return end
		local pooled = table.remove(HitEffectPools.numbers)
		local text = pooled and pooled.drawing or Drawing.new("Text")
		text.Visible = true
		text.Center = true
		text.Outline = true
		text.Text = tostring(math.floor(damage + 0.5))
		text.Size = he.Size or 14
		text.Font = he.Font or 2
		text.Color = isLethal and he.LethalColor or he.Color
		text.OutlineColor = he.OutlineColor or Color3.fromRGB(25, 25, 25)
		text.Transparency = he.Opacity or 1

		table.insert(HitEffectsState.numbers, pooled or {
			drawing = text,
			start = os.clock(),
			life = he.Lifetime or 0.9,
			rise = he.Rise or 1.5,
			opacity = he.Opacity or 1,
			part = part,
		})
		local item = HitEffectsState.numbers[#HitEffectsState.numbers]
		item.drawing = text
		item.start = os.clock()
		item.life = he.Lifetime or 0.9
		item.rise = he.Rise or 1.5
		item.opacity = he.Opacity or 1
		item.part = part
		TrimHitEffects()
	end

function CreateHitMarkerLines(color, outlineColor, thickness, opacity)
		local lines = {}
		local outlines = {}
		for i = 1, 4 do
			local line = Drawing.new("Line")
			line.Color = color
			line.Thickness = thickness
			line.Transparency = opacity
			line.ZIndex = 200
			line.Visible = true
			lines[i] = line

			local outline = Drawing.new("Line")
			outline.Color = outlineColor
			outline.Thickness = thickness + 2
			outline.Transparency = opacity
			outline.ZIndex = 199
			outline.Visible = true
			outlines[i] = outline
		end
		return lines, outlines
	end

