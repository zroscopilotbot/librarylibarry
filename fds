	function SetupFootstepSounds()
		local soundService = game:GetService("SoundService")
		
		local existing = soundService:FindFirstChild("stepSounds")
		if existing then existing:Destroy() end

		stepFolder = Instance.new("Folder")
		stepFolder.Name = "stepSounds"
		stepFolder.Parent = soundService

		for material, assetId in pairs(WalkSounds.Sounds) do
			local sound = Instance.new("Sound")
			sound.Name = material
			sound.SoundId = assetId
			sound.Looped = true
			sound.Volume = 1
			sound.Parent = stepFolder
		end
	end

	function StartWalkSounds()
		if walkSoundsLoop then
			walkSoundsLoop:Disconnect()
			walkSoundsLoop = nil
		end
		if walkCharacterAddedConn then
			walkCharacterAddedConn:Disconnect()
			walkCharacterAddedConn = nil
		end
		if walkHumanoidRunningConn then
			walkHumanoidRunningConn:Disconnect()
			walkHumanoidRunningConn = nil
		end

		SetupFootstepSounds()

		local plr = LocalPlayer
		local hum = nil
		local walking = false
		local function bindCharacter(char)
			local newHum = char and (char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5))
			if not newHum then
				return
			end

			if walkHumanoidRunningConn then
				walkHumanoidRunningConn:Disconnect()
				walkHumanoidRunningConn = nil
			end

			hum = newHum
			walking = false
			walkHumanoidRunningConn = hum.Running:Connect(function(speed)
				walking = speed > hum.WalkSpeed / 2
			end)
		end

		if plr.Character then
			bindCharacter(plr.Character)
		end

		walkCharacterAddedConn = plr.CharacterAdded:Connect(bindCharacter)

		local lastmat = nil
		walkSoundsLoop = RunService.Heartbeat:Connect(function()
			if not stepFolder then return end
			if hum and hum.Parent and walking then
				local floormat = hum.FloorMaterial
				local matstring = string.split(tostring(floormat), "Enum.Material.")[2] or "Air"
				if matstring ~= lastmat and lastmat ~= nil then
					local prev = stepFolder:FindFirstChild(lastmat)
					if prev then prev.Playing = false end
				end
				local sound = stepFolder:FindFirstChild(matstring)
				if sound then
					sound.PlaybackSpeed = hum.WalkSpeed / 12
					sound.Playing = true
				end
				lastmat = matstring
			else
				for _, sound in pairs(stepFolder:GetChildren()) do
					sound.Playing = false
				end
			end
		end)
	end

	function StopWalkSounds()
		if walkSoundsLoop then
			walkSoundsLoop:Disconnect()
			walkSoundsLoop = nil
		end
		if walkCharacterAddedConn then
			walkCharacterAddedConn:Disconnect()
			walkCharacterAddedConn = nil
		end
		if walkHumanoidRunningConn then
			walkHumanoidRunningConn:Disconnect()
			walkHumanoidRunningConn = nil
		end
		if stepFolder then
			stepFolder:Destroy()
			stepFolder = nil
		end
	end

