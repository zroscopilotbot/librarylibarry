	function MainAimInit()
		local STICKY_SWITCH_TOLERANCE = 6
		if Config.Combat.AutoPrediction then
			UpdateAutoPrediction()
		end

		if not Config.Combat.UsePrediction then
			Config.Combat.Prediction = 0
		end

		local silentActive = isSilentActive()
		local aimbotActive = isAimbotActive()
		local stickyEnabled = getCurrentStickyTarget()

		if not (silentActive or aimbotActive) then
			Config.Combat.lockedTarget = nil
			Config.Combat.locked = false
			Config.Combat.lastValidTarget = nil
			Config.Combat.lastValidTargetPlayer = nil
			Config.Combat.IsSettingPosition = false
			Config.Combat.MousePosition = nil
			lastAimScanTarget = nil
			return
		end

		local function isModeTargetAllowed(mode, target)
			if not target then return false end
			if isCharacterInDeadzone(target) then
				return false
			end
			if mode == "silent" then
				if Config.Combat.SilentAim.IgnoreSC and Config.Combat.SilentAim.StickyTarget then return true end
				if not Config.Combat.SilentAim.UseFov then return true end
				if Config.Combat.SilentAim.StickyTarget then return true end
				return isCharacterInAimFovForMode(target, "silent")
			end
			if Config.Combat.Aimbot.IgnoreSC and Config.Combat.StickyTarget then return true end
			if not Config.Combat.UseFov then return true end
			if Config.Combat.StickyTarget then return true end
			return isCharacterInAimFovForMode(target, "aimbot")
		end

		local function canReuseAimTarget(target)
			if not target or not target.Parent or not isValidTarget(target) then
				return false
			end
			return (silentActive and isModeTargetAllowed("silent", target))
				or (aimbotActive and isModeTargetAllowed("aimbot", target))
		end

		local reusedStickyTarget = false
		if stickyEnabled then
			if Config.Combat.lastValidTarget and Config.Combat.lastValidTarget.Parent and isValidTarget(Config.Combat.lastValidTarget) then
				if canReuseAimTarget(Config.Combat.lastValidTarget) then
					Config.Combat.lockedTarget = Config.Combat.lastValidTarget
					Config.Combat.locked = true
					reusedStickyTarget = true
				end
			elseif Config.Combat.lastValidTargetPlayer then
				local player = Config.Combat.lastValidTargetPlayer
				local character = player and player.Parent and player.Character or nil
				if character and character.Parent and canReuseAimTarget(character) then
					Config.Combat.lockedTarget = character
					Config.Combat.locked = true
					reusedStickyTarget = true
				else
					Config.Combat.lastValidTargetPlayer = nil
					Config.Combat.lastValidTarget = nil
				end
			end
		end

		local closestPlayer, closestDistance = nil, math.huge
		if not reusedStickyTarget then
			closestPlayer, closestDistance = getClosestPlayerInFovCached(
				getCurrentFovSize(),
				getCurrentUseFov(),
				false,
				getCurrentAimCenter()
			)
		end

		if stickyEnabled then
			if not reusedStickyTarget then
				Config.Combat.lockedTarget = closestPlayer
				Config.Combat.locked = closestPlayer ~= nil
			end
		else
			Config.Combat.lockedTarget = closestPlayer
			Config.Combat.locked = closestPlayer ~= nil
		end

		if Config.Combat.lockedTarget then
			Config.Combat.lastValidTarget = Config.Combat.lockedTarget
			local plr = Players:GetPlayerFromCharacter(Config.Combat.lockedTarget)
			Config.Combat.lastValidTargetPlayer = plr
		end

		local silentAllowed = silentActive and isModeTargetAllowed("silent", Config.Combat.lockedTarget)
		local aimbotAllowed = aimbotActive and isModeTargetAllowed("aimbot", Config.Combat.lockedTarget)
		local allowOffscreenAim = (silentAllowed and Config.Combat.SilentAim.IgnoreSC)
			or (aimbotAllowed and Config.Combat.Aimbot.IgnoreSC)

		if Config.Combat.lockedTarget and not (silentAllowed or aimbotAllowed) then
			Config.Combat.lockedTarget = nil
			Config.Combat.locked = false
			Config.Combat.IsSettingPosition = false
			Config.Combat.MousePosition = nil
			HideVelocityIndicator()
			return
		end

		if Config.Combat.lockedTarget and Config.Combat.locked then
			if Config.Combat.UseHitChance and type(ShouldHit) == "function" and not ShouldHit() then
				Config.Combat.IsSettingPosition = false
				Config.Combat.MousePosition = nil
				HideVelocityIndicator()
				return
			end

			local partToAim = nil
			if Config.Combat.AimPart == "Closest Part" then
				partToAim = getClosestPartToMouse(Config.Combat.lockedTarget)
			else
				partToAim = GetSelectedAimPart(Config.Combat.lockedTarget, Config.Combat.AimPart)
			end

			if not partToAim and GetEncryptedHeadPart then
				partToAim = GetEncryptedHeadPart(Config.Combat.lockedTarget)
			end
			if not partToAim then
				partToAim = GetBestBasePart(Config.Combat.lockedTarget, "HumanoidRootPart")
					or Config.Combat.lockedTarget:FindFirstChild("Head", true)
					or GetSelectedAimPart(Config.Combat.lockedTarget, "Torso")
			end
			if not partToAim then
				Config.Combat.IsSettingPosition = false
				Config.Combat.MousePosition = nil
				HideVelocityIndicator()
				return
			end

			local screenPosCheck, onScreenCheck = Camera:WorldToViewportPoint(partToAim.Position)
			if ((not onScreenCheck) or screenPosCheck.Z <= 0) and not allowOffscreenAim then
				Config.Combat.IsSettingPosition = false
				Config.Combat.MousePosition = nil
				HideVelocityIndicator()
				return
			end
			if onScreenCheck and screenPosCheck.Z > 0 then
				local mousePosCheck = getCurrentAimCenter()
				local point2D = Vector2.new(screenPosCheck.X, screenPosCheck.Y)
				local radius = tonumber(getCurrentFovSize()) or 100
				local deadzone = getCurrentDeadzoneSize()
				local deadzoneCenter = getDeadzoneCenter()
				if deadzone > 0 and isInsideCircle(point2D, deadzoneCenter, deadzone) then
					Config.Combat.IsSettingPosition = false
					Config.Combat.MousePosition = nil
					HideVelocityIndicator()
					return
				end
				if getCurrentUseFov() then
					if not isInsideCircle(point2D, mousePosCheck, radius) then
						Config.Combat.IsSettingPosition = false
						Config.Combat.MousePosition = nil
						HideVelocityIndicator()
						return
					end
				end
			end

			local physicsVelocity = partToAim.AssemblyLinearVelocity or partToAim.Velocity or Vector3.new(0, 0, 0)
			local targetPosition = getClosestPointOnPart(partToAim)
			local predictionVelocity = physicsVelocity

			if Config.Combat.UseVelocityPrediction and Config.Velocity.Enabled then
				predictionVelocity = Config.Velocity.Vector
			end

			if Config.Velocity.AutoZero and predictionVelocity.Magnitude < 0.01 then
				predictionVelocity = Vector3.new(0,0,0)
			end

			local predictedBase
			if Config.Combat.UseVelocityPrediction then
				local cameraPos = Camera.CFrame.Position
				local distance = (targetPosition - cameraPos).Magnitude
				local leadTime = math.clamp(distance / 500, 0.03, 0.25)
				local velocityScale = 0.65
				predictedBase = targetPosition + predictionVelocity * (leadTime * velocityScale) + Vector3.new(0, 0.001, 0)
			else
				predictedBase = targetPosition + predictionVelocity * Config.Combat.Prediction + Vector3.new(0, 0.001, 0)
			end

			Config.Combat.IsSettingPosition = silentAllowed

			local function clampDirection(currentDir, targetDir, maxAngleRad)
				currentDir = currentDir.Unit
				targetDir = targetDir.Unit
				local dot = math.clamp(currentDir:Dot(targetDir), -1, 1)
				local angle = math.acos(dot)
				if angle <= 0 or angle <= maxAngleRad then
					return targetDir
				end
				local t = maxAngleRad / angle
				return (currentDir:Lerp(targetDir, t)).Unit
			end

			local function computeLerpAlpha(smooth, speed, curve, power)
				local s = tonumber(smooth) or 1
				if s < 0.1 then s = 0.1 end
				local spd = tonumber(speed) or 1
				local a = math.clamp(1 / s * spd, 0.01, 1)
				local p = tonumber(power) or 1
				if curve == "smoothstep" then
					a = a * a * (3 - 2 * a)
				elseif curve == "easein" then
					a = a ^ p
				elseif curve == "easeout" then
					a = 1 - (1 - a) ^ p
				elseif curve == "easeinout" then
					if a < 0.5 then
						a = 0.5 * (2 * a) ^ p
					else
						a = 1 - 0.5 * (2 * (1 - a)) ^ p
					end
				end
				return a
			end

			local function applyJitter(vec, jitterAmt)
				local j = tonumber(jitterAmt) or 0
				if j <= 0 then
					return vec
				end
				local jx = (math.random() * 2 - 1) * j
				local jy = (math.random() * 2 - 1) * j
				return vec + Vector3.new(jx, jy, 0)
			end

			local silentLerpAlpha = computeLerpAlpha(
				Config.Combat.SilentAim.Smoothness,
				1,
				Config.Combat.SilentAim.CurveStyle,
				Config.Combat.SilentAim.CurvePower
			)
			local aimbotLerpAlpha = computeLerpAlpha(
				Config.Combat.Smoothness,
				Config.Combat.Aimbot.AimSpeed,
				Config.Combat.CurveStyle,
				Config.Combat.CurvePower
			)

			local predictedSilent = predictedBase
			local predictedAimbot = predictedBase
			local velocityIndicatorWorldPos = nil
			if silentActive then
				predictedSilent = applyJitter(predictedSilent, Config.Combat.SilentAim.JitterAmount)
				local sway = getCurrentMicroSway()
				if sway > 0 then
					predictedSilent = predictedSilent + Vector3.new((math.random() * 2 - 1) * sway, (math.random() * 2 - 1) * sway, (math.random() * 2 - 1) * sway)
				end
			end
			if aimbotActive then
				predictedAimbot = applyJitter(predictedAimbot, Config.Combat.JitterAmount)
				local sway = getCurrentMicroSway()
				if sway > 0 then
					predictedAimbot = predictedAimbot + Vector3.new((math.random() * 2 - 1) * sway, (math.random() * 2 - 1) * sway, (math.random() * 2 - 1) * sway)
				end
			end

			if silentAllowed then
				if not current_smoothed_pos then
					local was_setting = Config.Combat.IsSettingPosition
					Config.Combat.IsSettingPosition = false
					local realMouseHit = mouse.Hit
					Config.Combat.IsSettingPosition = was_setting
					current_smoothed_pos = realMouseHit.Position
				end
				local smoothAlpha = math.clamp(1 / (tonumber(Config.Combat.SilentAim.Smoothness) or 1), 0.01, 1)
				current_smoothed_pos = current_smoothed_pos:Lerp(predictedSilent, smoothAlpha)
				Config.Combat.MousePosition = CFrame.new(current_smoothed_pos)
				velocityIndicatorWorldPos = current_smoothed_pos
			end

			if aimbotAllowed and Config.Combat.Aimbot.AimType == "Cam Lock" then
				if not velocityIndicatorWorldPos then
					velocityIndicatorWorldPos = predictedAimbot
				end
				if not silentAllowed then
					Config.Combat.MousePosition = nil
					current_smoothed_pos = nil
				end
				local dt = math.max(last_frame_dt or 0.016, 0.001)
				local desiredDir = (predictedAimbot - Camera.CFrame.Position).Unit
				local maxAngleRad = math.rad(getCurrentMaxAngularSpeed() * dt)
				local clampedDir = clampDirection(Camera.CFrame.LookVector, desiredDir, maxAngleRad)
				local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, Camera.CFrame.Position + clampedDir)
				if (tonumber(Config.Combat.Smoothness) or 1) > 1 then
					Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, aimbotLerpAlpha)
				else
					Camera.CFrame = targetCFrame
				end
			elseif aimbotAllowed and Config.Combat.Aimbot.AimType == "Mouse Lock" then
				if not velocityIndicatorWorldPos then
					velocityIndicatorWorldPos = predictedAimbot
				end
				if not silentAllowed then
					Config.Combat.MousePosition = nil
					current_smoothed_pos = nil
				end
				local screenPos, onScreen = Camera:WorldToViewportPoint(predictedAimbot)
				if onScreen and screenPos.Z > 0 then
					local mousePos = getMousePos()
					local delta = Vector2.new(screenPos.X - mousePos.X, screenPos.Y - mousePos.Y)
					local gain = aimbotLerpAlpha
					delta = delta * gain
					local dt = math.max(last_frame_dt or 0.016, 0.001)
					local maxDelta = getCurrentMaxMouseSpeed() * dt
					if maxDelta > 0 and delta.Magnitude > maxDelta then
						delta = delta.Unit * maxDelta
					end

					if mousemoverel then
						mousemoverel(delta.X, delta.Y)
					elseif mousemoveabs then
						mousemoveabs(mousePos.X + delta.X, mousePos.Y + delta.Y)
					else
						local desiredDir = (predictedAimbot - Camera.CFrame.Position).Unit
						local maxAngleRad = math.rad(getCurrentMaxAngularSpeed() * dt)
						local clampedDir = clampDirection(Camera.CFrame.LookVector, desiredDir, maxAngleRad)
						local targetCFrame = CFrame.lookAt(Camera.CFrame.Position, Camera.CFrame.Position + clampedDir)
						if (tonumber(Config.Combat.Smoothness) or 1) > 1 then
							Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, aimbotLerpAlpha)
						else
							Camera.CFrame = targetCFrame
						end
					end
				else
					Config.Combat.IsSettingPosition = false
					Config.Combat.MousePosition = nil
				end
			end

			UpdateVelocityIndicator(velocityIndicatorWorldPos)
		else
			Config.Combat.IsSettingPosition = false
			Config.Combat.MousePosition = nil
			current_smoothed_pos = nil
			HideVelocityIndicator()
		end

		lockedTarget = Config.Combat.lockedTarget
		locked = Config.Combat.locked
		lastValidTarget = Config.Combat.lastValidTarget
		lastValidTargetPlayer = Config.Combat.lastValidTargetPlayer
	end

	--========================================================--
	--  TRIGGER BOT
	--========================================================--
	

	nextTriggerShot = 0
	nextTriggerScan = 0
	lastTriggerPart = nil
	triggerHoverStart = 0

	function TriggerbotHitboxAllowed(partName, mode)
		if mode == "Closest" or not mode then
			return true
		end
		if mode == "Head" then
			return partName == "Head"
		end
		if mode == "Torso" then
			return partName == "UpperTorso"
				or partName == "LowerTorso"
				or partName == "HumanoidRootPart"
				or partName == "Torso"
		end
		if mode == "Arms" then
			return partName == "LeftUpperArm"
				or partName == "RightUpperArm"
				or partName == "LeftLowerArm"
				or partName == "RightLowerArm"
				or partName == "LeftHand"
				or partName == "RightHand"
				or partName == "Left Arm"
				or partName == "Right Arm"
		end
		if mode == "Legs" then
			return partName == "LeftUpperLeg"
				or partName == "RightUpperLeg"
				or partName == "LeftLowerLeg"
				or partName == "RightLowerLeg"
				or partName == "LeftFoot"
				or partName == "RightFoot"
				or partName == "Left Leg"
				or partName == "Right Leg"
		end
		return true
	end
	function GetTriggerbotTargetPart(character, mode, mousePos, useFov, radius)
		if not character then
			return nil
		end
		local parts = GetCharacterPartsCached(character)
		if not parts or #parts == 0 then
			return nil
		end
		local bestPart = nil
		local bestDistance = math.huge
		for _, part in ipairs(parts) do
			if part and part.Parent and TriggerbotHitboxAllowed(part.Name, mode) then
				local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
				if onScreen and screenPos.Z > 0 then
					local pos2D = Vector2.new(screenPos.X, screenPos.Y)
					local distance = (pos2D - mousePos).Magnitude
					if ((not useFov) or distance <= radius) and ((not Config.Combat.WallCheck) or IsVisibleToCamera(part, character)) then
						if distance < bestDistance then
							bestDistance = distance
							bestPart = part
						end
					end
				end
			end
		end
		return bestPart
	end

	function UpdateTriggerBot()
		if not Config.TriggerBot.Enabled then return end
		if Config.TriggerBot.UseKeybind and not IsTriggerKeyActive() then return end
		if type(mouse1click) ~= "function" then return end

		local now = tick()
		if now < nextTriggerShot then return end
		if now < nextTriggerScan then return end
		nextTriggerScan = now + math.max(0, tonumber(Config.TriggerBot.ScanInterval) or 0.04)

		local mousePos = getMousePos()
		local radius = tonumber(Config.TriggerBot.FovSize) or 70
		local hitboxMode = Config.TriggerBot.Hitbox

		if Config.Combat.ToolCheck and not GetCharacterToolName(LocalPlayer.Character) then
			return
		end

		local character = nil
		local closestTarget = getClosestPlayerInFov(radius, Config.TriggerBot.UseFov, true)
		if closestTarget and isValidTarget(closestTarget) then
			character = closestTarget
		end

		if not character then
			lastTriggerPart = nil
			return
		end

		local core = RefreshCharacterCoreCache(character)
		local targetRoot = core and core.RootPart
		if Config.Combat.DistanceCheck and targetRoot then
			local localRoot = GetLocalRootPartForESP()
			if localRoot then
				local maxDistance = tonumber(Config.Combat.MaxDistance) or 1000
				if (targetRoot.Position - localRoot.Position).Magnitude > maxDistance then
					lastTriggerPart = nil
					return
				end
			end
		end

		local hitPart = nil
		if Config.TriggerBot.UseFov then
			hitPart = GetTriggerbotTargetPart(character, hitboxMode, mousePos, true, radius)
			if not hitPart then
				lastTriggerPart = nil
				return
			end
		else
			local ray = Camera:ViewportPointToRay(mousePos.X, mousePos.Y)
			local params = RaycastParams.new()
			params.FilterType = Enum.RaycastFilterType.Exclude
			params.FilterDescendantsInstances = {LocalPlayer.Character}
			params.IgnoreWater = true
			local maxCast = Config.Combat.DistanceCheck and (tonumber(Config.Combat.MaxDistance) or 1000) or 2500
			local result = workspace:Raycast(ray.Origin, ray.Direction * maxCast, params)
			if not result or not result.Instance then
				lastTriggerPart = nil
				return
			end

			hitPart = result.Instance
			local hitModel = hitPart:FindFirstAncestorOfClass("Model")
			if hitModel ~= character then
				lastTriggerPart = nil
				return
			end

			if not TriggerbotHitboxAllowed(hitPart.Name, hitboxMode) then
				lastTriggerPart = nil
				return
			end
		end

		if lastTriggerPart ~= hitPart then
			lastTriggerPart = hitPart
			triggerHoverStart = now
		end

		if (now - triggerHoverStart) < (tonumber(Config.TriggerBot.HoverTime) or 0) then
			return
		end

		mouse1click()
		MarkRecentShot()
		nextTriggerShot = now + math.max(0, tonumber(Config.TriggerBot.ClickDelay) or 0.05)
	end

	--========================================================--
	--  FLICK BOT
	--========================================================--

	function UpdateFlickBot()
		if not Config.Combat.FlickBot.Enabled then return end
		if Config.Combat.FlickBot.UseKeybind and not IsFlickKeyActive() then return end

		local localChar = LocalPlayer.Character
		local localRoot = localChar and localChar:FindFirstChild("HumanoidRootPart")
		if not localRoot then return end

		local bestChar = nil
		local bestDist = math.huge
		for _, player in ipairs(GetPlayersListCached()) do
			if player ~= LocalPlayer then
				local char = GetPlayerCharacter(player)
				if char and isValidTarget(char) then
					local core = RefreshCharacterCoreCache(char)
					local root = core and core.RootPart
					if root then
						local dist = (root.Position - localRoot.Position).Magnitude
						if dist < bestDist then
							bestDist = dist
							bestChar = char
						end
					end
				end
			end
		end
		if Config.Combat.TargetNPCs then
			for _, model in ipairs(GetNpcModelsCached()) do
				if model and model.Parent and isValidTarget(model) then
					local root = GetBestBasePart(model, "HumanoidRootPart") or model:FindFirstChild("Head", true)
					if root then
						local dist = (root.Position - localRoot.Position).Magnitude
						if dist < bestDist then
							bestDist = dist
							bestChar = model
						end
					end
				end
			end
		end

		if bestChar then
			local aimPart = bestChar:FindFirstChild(Config.Combat.AimPart, true)
			if not aimPart and GetEncryptedHeadPart then
				aimPart = GetEncryptedHeadPart(bestChar)
			end
			if not aimPart then
				aimPart = GetBestBasePart(bestChar, Config.Combat.AimPart)
			end
			if not aimPart then
				aimPart = GetBestBasePart(bestChar, "HumanoidRootPart")
			end
			if aimPart then
				Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, aimPart.Position)
			end
		end
	end

	function GetRagebotHitboxSize(basePart)
		if not basePart then
			return Vector3.new(1, 1, 1)
		end
		local size = basePart.Size
		local cfg = Config and Config.Ragebot
		if cfg and cfg.UseHitboxExpander and Config.HitboxExpander and Config.HitboxExpander.Enabled then
			local sizeX = math.max(size.X, tonumber(Config.HitboxExpander.SizeX) or size.X)
			local sizeY = math.max(size.Y, tonumber(Config.HitboxExpander.SizeY) or size.Y)
			local depth = math.max(size.Z, math.min(sizeX, sizeY))
			return Vector3.new(sizeX, sizeY, depth)
		end
		return size
	end

	function GetClosestPointOnExpandedPart(basePart, referencePosition)
		if not basePart then
			return nil
		end
		local localPoint = basePart.CFrame:PointToObjectSpace(referencePosition or Camera.CFrame.Position)
		local half = GetRagebotHitboxSize(basePart) * 0.5
		return basePart.CFrame:PointToWorldSpace(Vector3.new(
			math.clamp(localPoint.X, -half.X, half.X),
			math.clamp(localPoint.Y, -half.Y, half.Y),
			math.clamp(localPoint.Z, -half.Z, half.Z)
		))
	end

	function GetRagebotFireTool()
		local tool = GetEquippedTool()
		if tool then
			return tool
		end
		local weaponObject = GetEquippedWeaponObject()
		if not weaponObject then
			return nil
		end
		if weaponObject:IsA("Tool") then
			return weaponObject
		end
		return weaponObject:FindFirstChildWhichIsA("Tool", true)
	end
	-- ========================================================
	-- RESOLVER + VELOCITY (full replacement)
	-- ========================================================

	local TargetKalmanStates    = {}
	local ResolverPerPlayer     = {}   -- per-player prediction state
	local ResolverLastHealth    = {}   -- last known health per player
	local ResolverShotTimers    = {}   -- when we last fired at each player
	local ResolverHitTimers     = {}   -- when we last confirmed a hit
	local ResolverLockedPred    = {}   -- locked prediction after confirmed hit
	local HIT_LOCK_DURATION     = 1.0  -- seconds to hold a confirmed prediction
	local RESOLVER_RESET_TIME   = 12.0 -- seconds before full resolver reset per player
	local ResolverLastActivity  = {}   -- track last engagement time per player

	-- ========================================================
	-- KALMAN VELOCITY
	-- ========================================================

	function GetOrCreateKalmanState(targetPart)
		if not TargetKalmanStates[targetPart] then
			local physVel = targetPart.AssemblyLinearVelocity or targetPart.Velocity or Vector3.new()
			TargetKalmanStates[targetPart] = {
				position       = targetPart.Position,
				velocity       = physVel,
				acceleration   = Vector3.new(),
				lastTime       = tick(),
				posUncertainty = 1,
			}
		end
		return TargetKalmanStates[targetPart]
	end

	function UpdateKalmanState(targetPart)
		if not targetPart or not targetPart.Parent then
			return Vector3.new()
		end

		local state = GetOrCreateKalmanState(targetPart)
		local now   = tick()
		local dt    = now - state.lastTime

		if dt < 0.001 or dt > 0.35 then
			state.lastTime = now
			return state.velocity
		end
		state.lastTime = now

		local measuredPos = targetPart.Position
		local physVel     = targetPart.AssemblyLinearVelocity or targetPart.Velocity or Vector3.new()
		local speed       = physVel.Magnitude

		-- Predict forward using current state
		local predictedPos = state.position
			+ state.velocity * dt
			+ state.acceleration * (0.5 * dt * dt)

		local posError = measuredPos - predictedPos

		-- Adaptive noise: trust measurements more at high speed
		local measureNoise   = math.max(0.04, 0.18 - speed * 0.001)
		local processNoise   = 0.06

		state.posUncertainty = state.posUncertainty + processNoise * dt
		local gain = state.posUncertainty / (state.posUncertainty + measureNoise)
		state.posUncertainty = (1 - gain) * state.posUncertainty

		local correctedPos  = predictedPos + posError * gain
		local rawVelFromPos = (correctedPos - state.position) / dt

		-- Speed-aware blend: trust physics more at high speed
		local cfg        = Config and Config.Ragebot
		local userBlend  = math.clamp(tonumber(cfg and cfg.VelocityBlend) or 0.65, 0, 1)
		local speedBlend = math.clamp(speed / 80, 0, 1)
		local finalBlend = userBlend * (1 - speedBlend * 0.5)

		local blendedVel
		if speed < 0.15 then
			blendedVel = rawVelFromPos * 0.15
		elseif rawVelFromPos.Magnitude < 0.15 then
			blendedVel = physVel
		else
			blendedVel = physVel:Lerp(rawVelFromPos, finalBlend)
		end

		-- Acceleration with heavier smoothing at high speed
		local accelSmooth  = math.clamp(0.15 - speed * 0.0008, 0.04, 0.15)
		local rawAccel     = (blendedVel - state.velocity) / dt
		state.acceleration = state.acceleration:Lerp(rawAccel, accelSmooth)

		if state.acceleration.Magnitude > 280 then
			state.acceleration = state.acceleration.Unit * 280
		end

		-- Smooth factor slows down at high speed to avoid yanking aim
		local smoothRate   = 14 * (1 - math.clamp(speed / 60, 0, 1) * 0.55)
		local smoothFactor = math.clamp(1 - math.exp(-dt * smoothRate), 0.03, 0.88)

		state.velocity = state.velocity:Lerp(blendedVel, smoothFactor)
		state.position = correctedPos

		return state.velocity
	end

	function GetSmoothedTargetVelocity(targetPart)
		if not targetPart then return Vector3.new() end
		local cfg = Config and Config.Ragebot
		if not cfg or cfg.UseVelocityPrediction == false then
			return targetPart.AssemblyLinearVelocity or targetPart.Velocity or Vector3.new()
		end
		return UpdateKalmanState(targetPart)
	end

	function CleanKalmanStates()
		for part in pairs(TargetKalmanStates) do
			if not part or not part.Parent then
				TargetKalmanStates[part] = nil
			end
		end
	end

	-- ========================================================
	-- PER-PLAYER RESOLVER STATE
	-- ========================================================

	function GetResolverState(player)
		local name = player.Name
		if not ResolverPerPlayer[name] then
			local cfg = Config and Config.Ragebot
			ResolverPerPlayer[name] = {
				prediction = tonumber(cfg and cfg.Prediction) or 0,
				increment  = 0,
			}
		end
		return ResolverPerPlayer[name]
	end

	function RecordRagebotShot(targetCharacter)
		local player = Players:GetPlayerFromCharacter(targetCharacter)
		if not player then return end
		ResolverShotTimers[player.Name] = tick()
		ResolverLastActivity[player.Name] = tick()
	end

	-- Call this from RegisterRagebotDamageFeedback
	function ResolverOnHit(targetCharacter)
		local player = Players:GetPlayerFromCharacter(targetCharacter)
		if not player then return end
		local name  = player.Name
		local state = GetResolverState(player)

		-- Lock in the prediction that got the hit
		ResolverLockedPred[name]   = state.prediction + state.increment
		ResolverHitTimers[name]    = tick()
		ResolverLastActivity[name] = tick()

		-- Reset climbing increment since current pred is working
		state.increment = 0
	end

	-- Call this from RegisterRagebotDamageFeedback when shot didn't hit
	function ResolverOnMiss(targetCharacter)
		local player = Players:GetPlayerFromCharacter(targetCharacter)
		if not player then return end
		local name  = player.Name
		local state = GetResolverState(player)
		local cfg   = Config and Config.Ragebot

		-- Only increment if we actually fired recently
		local shotTime = ResolverShotTimers[name]
		if not shotTime or (tick() - shotTime) > 0.5 then return end

		-- Dynamic increment: scales with target speed so fast targets climb faster
		local targetChar = targetCharacter
		local hrp        = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
		local speed      = hrp and (hrp.AssemblyLinearVelocity or hrp.Velocity or Vector3.new()).Magnitude or 0
		local baseStep   = tonumber(cfg and cfg.Forgiveness) or 10
		local speedStep  = math.log(1 + speed / 15) * (baseStep * 0.4)
		local step       = (baseStep + speedStep) / 1000  -- convert ms to seconds

		state.increment            = state.increment + step
		ResolverLastActivity[name] = tick()
	end

	function GetResolverPrediction(targetCharacter)
		local cfg    = Config and Config.Ragebot
		local player = Players:GetPlayerFromCharacter(targetCharacter)

		-- Fallback for NPCs (no player object)
		if not player then
			local basePredMs = tonumber(cfg and cfg.Prediction) or 0
			return basePredMs / 1000
		end

		local name  = player.Name
		local state = GetResolverState(player)

		-- Return locked prediction if we had a recent confirmed hit
		if ResolverLockedPred[name] then
			if (tick() - (ResolverHitTimers[name] or 0)) <= HIT_LOCK_DURATION then
				return ResolverLockedPred[name]
			else
				-- Lock expired, clear it and let the increment resume
				ResolverLockedPred[name] = nil
				ResolverHitTimers[name]  = nil
			end
		end

		-- Idle decay: if not engaging this target, bleed off accumulated increment
		local lastActive = ResolverLastActivity[name]
		if lastActive and (tick() - lastActive) > 1.5 then
			state.increment = state.increment * 0.94
		end

		-- Auto-reset if we've been fighting long enough that something is clearly wrong
		if lastActive and (tick() - lastActive) > RESOLVER_RESET_TIME then
			ResetResolverForTarget(player)
		end

		local basePredMs = tonumber(cfg and cfg.Prediction) or 0
		return (basePredMs / 1000) + state.increment
	end

	function ResetResolverForTarget(player)
		if not player then return end
		local name = player.Name
		local cfg  = Config and Config.Ragebot
		ResolverPerPlayer[name]   = {
			prediction = tonumber(cfg and cfg.Prediction) or 0,
			increment  = 0,
		}
		ResolverLockedPred[name]   = nil
		ResolverHitTimers[name]    = nil
		ResolverShotTimers[name]   = nil
		ResolverLastActivity[name] = nil
	end

	function ResetAllResolvers()
		ResolverPerPlayer    = {}
		ResolverLockedPred   = {}
		ResolverHitTimers    = {}
		ResolverShotTimers   = {}
		ResolverLastActivity = {}
		ResolverLastHealth   = {}
	end

	-- ========================================================
	-- PREDICTION COMPUTE + APPLY
	-- ========================================================

	function ComputeRagebotPrediction(targetPart, velocity, targetCharacter)
		local cfg = Config and Config.Ragebot
		if not cfg or cfg.UsePrediction == false then
			return 0
		end

		-- Now delegates to per-player resolver instead of the old forgiveness system
		local predSec    = GetResolverPrediction(targetCharacter)
		local speed      = (velocity or Vector3.new()).Magnitude
		local hitboxSize = GetRagebotHitboxSize(targetPart)
		local avgHitbox  = math.max((hitboxSize.X + hitboxSize.Y + hitboxSize.Z) / 3, 0.5)

		-- Logarithmic dynamic offset on top of resolver prediction
		local speedFactor   = math.log(1 + speed / 20) * 0.04
		local hitboxFactor  = math.clamp(1.5 / avgHitbox, 0.5, 2.5)
		local dynamicOffset = speedFactor * hitboxFactor

		return predSec + dynamicOffset
	end

	function ApplyRagebotPrediction(aimPosition, velocity, prediction, dt)
		local cfg = Config and Config.Ragebot
		if not cfg or cfg.UsePrediction == false then
			return aimPosition
		end
		if prediction ~= 0 then
			aimPosition = aimPosition + velocity * prediction
		end
		if cfg and cfg.JumpPrediction then
			local g = Workspace.Gravity
			local t = math.max(prediction, dt or 0)
			aimPosition = Vector3.new(
				aimPosition.X,
				aimPosition.Y - (0.5 * g * (t * t)),
				aimPosition.Z
			)
		end
		return aimPosition
	end

	function ResetRagebotAutoPrediction(target)
		RagebotState.ForgivenessOffset = 0
		RagebotState.LockedPrediction = nil
		RagebotState.LockedPredictionUntil = 0
		RagebotState.LastPredictionAdjust = 0
		RagebotState.LastForgivenessTarget = target
	end

	function RegisterRagebotDamageFeedback(targetCharacter, damage)
		if not RagebotState or not targetCharacter or targetCharacter ~= RagebotState.TargetCharacter then
			return
		end
		if not HasRecentShot() then return end

		RagebotState.LastConfirmedHit      = tick()
		RagebotState.LastDamageTarget      = targetCharacter
		RagebotState.LastDamagePrediction  = tonumber(RagebotState.CurrentPrediction) or 0

		-- Route into per-player resolver
		ResolverOnHit(targetCharacter)
	end

	-- Call this when you detect a shot didn't connect (health unchanged after shot window)
	-- Wire this up wherever you currently detect misses, or call from your hit detect loop
	function RegisterRagebotMissFeedback(targetCharacter)
		if not RagebotState or not targetCharacter then return end
		ResolverOnMiss(targetCharacter)
	end

	function GetForgivenessPrediction(targetPart, velocity)
		local cfg = Config and Config.Ragebot
		local basePrediction = tonumber(cfg and cfg.Prediction) or tonumber(Config.Combat.Prediction) or 0
		local forgiveness = math.max(0, tonumber(cfg and cfg.Forgiveness) or 0)
		local autoPredictionEnabled = Config and Config.Combat and Config.Combat.AutoPrediction == true
		local hitboxSize = GetRagebotHitboxSize(targetPart)
		local averageHitbox = math.max((hitboxSize.X + hitboxSize.Y + hitboxSize.Z) / 3, 0.5)
		local velocityMagnitude = (velocity or Vector3.new()).Magnitude
		local heuristicOffset = (velocityMagnitude / (averageHitbox * 12)) * 0.0015
		local startPrediction = math.max(0, basePrediction + heuristicOffset)

		if autoPredictionEnabled then
			if RagebotState.LastForgivenessTarget ~= targetPart then
				ResetRagebotAutoPrediction(targetPart)
			end

			local now = tick()
			local autoStep = math.max(basePrediction, forgiveness)
			if HasRecentShot() and autoStep > 0 then
				local adjustInterval = 0.05
				if (now - (RagebotState.LastPredictionAdjust or 0)) >= adjustInterval then
					RagebotState.LastPredictionAdjust = now
					RagebotState.ForgivenessOffset = (tonumber(RagebotState.ForgivenessOffset) or 0) + autoStep
				end
			end

			return math.max(0, tonumber(RagebotState.ForgivenessOffset) or 0)
		end

		if forgiveness <= 0 then
			return startPrediction
		end

		if RagebotState.LastForgivenessTarget ~= targetPart then
			ResetRagebotAutoPrediction(targetPart)
		end

		local now = tick()
		if RagebotState.LockedPrediction and now <= (RagebotState.LockedPredictionUntil or 0) then
			return RagebotState.LockedPrediction
		end
		if RagebotState.LockedPrediction and now > (RagebotState.LockedPredictionUntil or 0) then
			ResetRagebotAutoPrediction(targetPart)
		end

		if HasRecentShot() then
			local adjustInterval = 0.05
			if (now - (RagebotState.LastPredictionAdjust or 0)) >= adjustInterval then
				RagebotState.LastPredictionAdjust = now
				RagebotState.ForgivenessOffset = (tonumber(RagebotState.ForgivenessOffset) or 0) + forgiveness
			end
		end

		return startPrediction + (tonumber(RagebotState.ForgivenessOffset) or 0)
	end

	function IsCharacterKnocked(character)
		if not character or not character.Parent then
			return false
		end

		local bodyEffects = character:FindFirstChild("BodyEffects")
			or character:FindFirstChild("BodyEffects", true)
		if not bodyEffects then
			return false
		end

		local knocked = bodyEffects:FindFirstChild("K.O")
			or bodyEffects:FindFirstChild("KO")
			or bodyEffects:FindFirstChild("Knocked")
		if not knocked then
			return false
		end

		if knocked:IsA("BoolValue") then
			return knocked.Value == true
		end
		if knocked:IsA("IntValue") or knocked:IsA("NumberValue") then
			return tonumber(knocked.Value) == 1
		end
		return false
	end

	function GetCharacterHumanoid(character)
		if not character or not character.Parent then
			return nil
		end
		return character:FindFirstChildOfClass("Humanoid")
	end

	function IsCharacterDead(character)
		local humanoid = GetCharacterHumanoid(character)
		return humanoid ~= nil and humanoid.Health <= 0
	end

	function IsHumanoidLowHealth(humanoid, threshold)
		if not humanoid then
			return false
		end
		local limit = tonumber(threshold) or 25
		return humanoid.Health > 0 and humanoid.Health <= limit
	end

	function GetCharacterRootPart(character)
		if not character or not character.Parent then
			return nil
		end
		return character:FindFirstChild("HumanoidRootPart")
			or character:FindFirstChild("Torso")
			or GetBestBasePart(character, "HumanoidRootPart")
	end

	function ResolveReloadingValueFromObject(obj, depth)
		if not obj or depth > 2 then
			return nil
		end

		for _, name in ipairs({
			"Reloading", "reloading", "IsReloading", "isReloading",
			"Reload", "reload", "ReloadState", "reloadState"
		}) do
			local child = obj:FindFirstChild(name)
			if child then
				if child:IsA("BoolValue") then
					return child.Value == true
				end
				if child:IsA("StringValue") then
					local value = string.lower(tostring(child.Value))
					if value == "reload" or value == "reloading" then
						return true
					end
				end
				if child:IsA("IntValue") or child:IsA("NumberValue") then
					if tonumber(child.Value) == 1 then
						return true
					end
				end
			end
		end

		for _, attributeName in ipairs({
			"Reloading", "reloading", "IsReloading", "isReloading", "Reload"
		}) do
			local ok, value = pcall(function()
				return obj:GetAttribute(attributeName)
			end)
			if ok then
				if type(value) == "boolean" then
					return value
				end
				if type(value) == "string" then
					local lowerValue = string.lower(value)
					if lowerValue == "reload" or lowerValue == "reloading" then
						return true
					end
				end
				if type(value) == "number" and value == 1 then
					return true
				end
			end
		end

		for _, child in ipairs(obj:GetChildren()) do
			if child:IsA("Folder") or child:IsA("Configuration") or child:IsA("Tool") or child:IsA("Model") then
				local nested = ResolveReloadingValueFromObject(child, depth + 1)
				if nested ~= nil then
					return nested
				end
			end
		end

		return nil
	end

	function IsLocalReloading()
		local weaponObject = GetEquippedWeaponObject()
		if weaponObject then
			local value = ResolveReloadingValueFromObject(weaponObject, 0)
			if value ~= nil then
				return value
			end
		end

		local character = LocalPlayer and LocalPlayer.Character
		if character then
			local value = ResolveReloadingValueFromObject(character, 0)
			if value ~= nil then
				return value
			end
		end

		return false
	end

	function GetUsernameFromEntry(entry)
		if not entry then
			return ""
		end
		local username = tostring(entry):match("@([^)]+)")
		if username then
			return username
		end

		for _, player in ipairs(Players:GetPlayers()) do
			if player.DisplayName == entry or player.Name == entry then
				return player.Name
			end
		end

		return tostring(entry)
	end

	function NormalizeRagebotSelections(selected)
		local normalized = {}
		if type(selected) ~= "table" then
			return normalized
		end

		if #selected > 0 then
			for _, entry in ipairs(selected) do
				if entry ~= nil then
					normalized[#normalized + 1] = tostring(entry)
				end
			end
			return normalized
		end

		for key, value in pairs(selected) do
			if value then
				normalized[#normalized + 1] = tostring(key)
			end
		end

		table.sort(normalized)
		return normalized
	end

	function ClearRagebotTargetState()
		RagebotState.OverrideActive = false
		RagebotState.AimPosition = nil
		RagebotState.FollowPosition = nil
		RagebotState.TargetCharacter = nil
		RagebotState.TargetPart = nil
		RagebotState.CurrentVelocity = Vector3.new()
		RagebotState.CurrentPrediction = 0
		RagebotState.SelectionIndex = 1
		RagebotState.LastTargetSwitch = 0
		ResetRagebotAutoPrediction(nil)
	end

	function SaveRagebotEnableOrigin()
		local root = getroot()
		if not root then
			return false
		end

		RagebotState.EnableOriginCFrame = root.CFrame
		RagebotState.EnableOriginLinearVelocity = root.AssemblyLinearVelocity
		RagebotState.EnableOriginAngularVelocity = root.AssemblyAngularVelocity
		return true
	end

	function RestoreRagebotEnableOrigin()
		local root = getroot()
		local restoreCF = RagebotState.EnableOriginCFrame
		if root and restoreCF then
			local restoreLV = RagebotState.EnableOriginLinearVelocity or Vector3.new()
			local restoreAV = RagebotState.EnableOriginAngularVelocity or Vector3.new()
			root.CFrame = restoreCF
			root.AssemblyLinearVelocity = restoreLV
			root.AssemblyAngularVelocity = restoreAV
			QueueRestore(root, restoreCF, restoreLV, restoreAV, "xylo_ragebot_restore")
		end

		RagebotState.EnableOriginCFrame = nil
		RagebotState.EnableOriginLinearVelocity = nil
		RagebotState.EnableOriginAngularVelocity = nil
	end

	function UpdateRagebotTargetList()
		local newTargetList = {}
		local entryByUsername = {}
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				local entry = string.format("%s (@%s)", player.DisplayName, player.Name)
				newTargetList[#newTargetList + 1] = entry
				entryByUsername[player.Name] = entry
			end
		end

		table.sort(newTargetList)
		Config.TargetList = newTargetList

		if RagebotTargetDropdown and RagebotTargetDropdown.refresh_options then
			local currentSelections = NormalizeRagebotSelections(Config.MultiTargets)
			RagebotTargetDropdown:refresh_options(newTargetList)
			local validSelections = {}
			for _, selected in ipairs(currentSelections) do
				local username = GetUsernameFromEntry(selected)
				local updatedEntry = entryByUsername[username]
				if updatedEntry then
					validSelections[#validSelections + 1] = updatedEntry
				end
			end
			Config.MultiTargets = validSelections
			if RagebotState.SelectionIndex > #validSelections then
				RagebotState.SelectionIndex = 1
			end
			if RagebotTargetDropdown.set then
				RagebotTargetDropdown.set(validSelections)
			end
		end
	end

	function GetRagebotTargetPart(target)
		local cfg = Config and Config.Ragebot
		if not cfg or not target then
			return nil
		end
		if cfg.Hitbox == "Closest Part" then
			return getClosestPartToMouse(target, false)
		end
		return GetSelectedAimPart(target, cfg.Hitbox)
			or GetSelectedAimPart(target, Config.Combat.AimPart)
			or GetBestBasePart(target, "HumanoidRootPart")
			or target:FindFirstChild("Head", true)
	end

	function ShouldSkipRagebotTarget(target)
		local cfg = Config and Config.Ragebot
		if not cfg or not target or not target.Parent then
			return true
		end

		local humanoid = GetCharacterHumanoid(target)
		if cfg.TargetSkipIfDead and IsCharacterDead(target) then
			return true
		end
		if cfg.TargetSkipIfKnocked and IsCharacterKnocked(target) then
			return true
		end
		if cfg.TargetSkipIfNoGunEquipped and not GetEquippedWeaponObject() then
			return true
		end
		if cfg.TargetSkipIfReloading and IsLocalReloading() then
			return true
		end

		return false
	end

	function GetSelectedRagebotTarget()
		local selectedTargets = NormalizeRagebotSelections(Config.MultiTargets)
		local cfg = Config and Config.Ragebot

		if #selectedTargets > 0 then
			if cfg and cfg.TargetSwitchEnabled then
				local now = os.clock()
				local interval = math.clamp(tonumber(cfg.TargetSwitchInterval) or 0.5, 0.1, 3)
				local selectedCount = #selectedTargets
				if selectedCount <= 0 then
					return nil
				end

				if RagebotState.SelectionIndex < 1 or RagebotState.SelectionIndex > selectedCount then
					RagebotState.SelectionIndex = 1
				end

				if (now - (RagebotState.LastTargetSwitch or 0)) >= interval then
					RagebotState.SelectionIndex = (RagebotState.SelectionIndex % selectedCount) + 1
					RagebotState.LastTargetSwitch = now
				end

				for offset = 0, selectedCount - 1 do
					local idx = ((RagebotState.SelectionIndex - 1 + offset) % selectedCount) + 1
					local targetEntry = selectedTargets[idx]
					local username = GetUsernameFromEntry(targetEntry)
					local player = username ~= "" and Players:FindFirstChild(username) or nil
					local character = player and GetPlayerCharacter(player) or nil
					if character and isValidTarget(character) and not ShouldSkipRagebotTarget(character) then
						RagebotState.SelectionIndex = idx
						return character
					end
				end
			else
				local silentTarget = Config.Combat and Config.Combat.lockedTarget
				if silentTarget and silentTarget.Parent and isValidTarget(silentTarget) and not ShouldSkipRagebotTarget(silentTarget) then
					local silentPlayer = Players:GetPlayerFromCharacter(silentTarget)
					if silentPlayer then
						local silentEntry = string.format("%s (@%s)", silentPlayer.DisplayName, silentPlayer.Name)
						if table.find(selectedTargets, silentEntry) then
							return silentTarget
						end
					end
				end

				for _, targetEntry in ipairs(selectedTargets) do
					local username = GetUsernameFromEntry(targetEntry)
					local player = username ~= "" and Players:FindFirstChild(username) or nil
					local character = player and GetPlayerCharacter(player) or nil
					if character and isValidTarget(character) and not ShouldSkipRagebotTarget(character) then
						return character
					end
				end
			end
		end

		return nil
	end
	function UpdateRagebot(dt)
		local cfg = Config and Config.Ragebot
		if not cfg or not cfg.Enabled then
			ClearRagebotTargetState()
			return
		end

		local target = GetSelectedRagebotTarget()
		if not target then
			ClearRagebotTargetState()
			return
		end

		local targetPart = GetRagebotTargetPart(target)
		if not targetPart then
			ClearRagebotTargetState()
			return
		end

		local rawAimPosition = GetClosestPointOnExpandedPart(targetPart, Camera.CFrame.Position) or targetPart.Position
		local velocity       = GetSmoothedTargetVelocity(targetPart)
		local prediction     = ComputeRagebotPrediction(targetPart, velocity, target)
		local aimPosition    = ApplyRagebotPrediction(rawAimPosition, velocity, prediction, dt)

		RagebotState.AimPosition      = aimPosition
		RagebotState.FollowPosition   = rawAimPosition
		RagebotState.OverrideActive   = true
		RagebotState.TargetCharacter  = target
		RagebotState.TargetPart       = targetPart
		RagebotState.CurrentVelocity  = velocity
		RagebotState.CurrentPrediction = prediction

		local weaponObject = GetEquippedWeaponObject()
		if not weaponObject then return end
		if (os.clock() - (RagebotState.LastFire or 0)) < 0.08 then return end

		local tool = GetRagebotFireTool()
		if tool then
			RagebotState.LastFire = os.clock()
			RecordRagebotShot(target)   -- record shot here so resolver knows when we fired
			pcall(function() tool:Activate() end)
		end
	end
	function RestoreRagebotViewTarget()
		if not RagebotState.ViewTargetActive then
			return
		end

		RagebotState.ViewTargetActive = false
		local camera = Workspace and Workspace.CurrentCamera
		local character = LocalPlayer and LocalPlayer.Character
		local humanoid = character and character:FindFirstChildOfClass("Humanoid")
		if camera and humanoid then
			camera.CameraSubject = humanoid
		end
	end

	function UpdateRagebotViewTarget()
		local cfg = Config and Config.Ragebot
		local camera = Workspace and Workspace.CurrentCamera
		if not cfg or not cfg.Enabled or not cfg.ViewTarget or not camera then
			RestoreRagebotViewTarget()
			return
		end

		local target = RagebotState.TargetCharacter
		if not target or not target.Parent then
			RestoreRagebotViewTarget()
			return
		end
		if cfg.ViewTargetStopWhenKnocked and IsCharacterKnocked(target) then
			RestoreRagebotViewTarget()
			return
		end

		local head = target:FindFirstChild("Head") or target:FindFirstChild("Head", true)
		local humanoid = target:FindFirstChildOfClass("Humanoid")
		local subject = head or humanoid
		if subject then
			camera.CameraSubject = subject
			RagebotState.ViewTargetActive = true
			return
		end

		RestoreRagebotViewTarget()
	end

	function UpdateRagebotFollowTarget(dt)
		local cfg = Config and Config.Ragebot
		if not cfg or not cfg.Enabled or not cfg.FollowTarget then
			return
		end

		local target = RagebotState.TargetCharacter
		local aimPosition = RagebotState.FollowPosition or RagebotState.AimPosition
		local hrp = getroot()
		if not target or not target.Parent or not aimPosition or not hrp then
			return
		end
		local targetRoot = GetCharacterRootPart(target)

		if cfg.FollowTargetStopIfTargetKnocked and IsCharacterKnocked(target) then
			return
		end
		if cfg.FollowTargetStopIfNoGunEquipped and not GetEquippedWeaponObject() then
			return
		end
		if cfg.FollowTargetStopIfReloading and IsLocalReloading() then
			return
		end
		if cfg.FollowTargetStopIfTargetDead and IsCharacterDead(target) then
			return
		end
		if cfg.FollowTargetStopIfLowHealth then
			local localHumanoid = LocalPlayer and LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if IsHumanoidLowHealth(localHumanoid, cfg.FollowTargetLowHealthThreshold) then
				return
			end
		end

		local distance = math.max(0, tonumber(cfg.FollowTargetDistance) or 0)
		local randomDistance = math.max(0, math.floor(distance))
		local style = tostring(cfg.FollowTargetStyle or "Random Spam")
		local newCFrame = hrp.CFrame

		if style == "Random" then
			newCFrame = CFrame.new(aimPosition + Vector3.new(
				math.random(-randomDistance, randomDistance),
				math.random(-randomDistance, randomDistance),
				math.random(-randomDistance, randomDistance)
			))
			newCFrame = newCFrame * CFrame.Angles(
				math.rad(math.random(1, 359)),
				math.rad(math.random(1, 359)),
				math.rad(math.random(1, 359))
			)
		elseif style == "Random Spam" then
			local now = os.clock()
			local difference = now - (RagebotState.FollowAvoidLastTick or 0)
			local spamWindow = difference < 0.06
			if difference > 0.11 or spamWindow then
				newCFrame = CFrame.new(aimPosition + Vector3.new(
					math.random(-randomDistance, randomDistance),
					math.random(-randomDistance, randomDistance),
					math.random(-randomDistance, randomDistance)
				))
				if not spamWindow then
					RagebotState.FollowAvoidLastTick = now
				end
			else
				newCFrame = CFrame.new(
					math.random(-2147483647, 2147483647),
					math.random(-400, 2147483647),
					math.random(-2147483647, 2147483647)
				)
			end
			newCFrame = newCFrame * CFrame.Angles(
				math.rad(math.random(1, 359)),
				math.rad(math.random(1, 359)),
				math.rad(math.random(1, 359))
			)
		elseif style == "Behind" and targetRoot then
			local height = tonumber(cfg.FollowTargetHeight) or 0
			local offset = targetRoot.CFrame.LookVector * -distance
			newCFrame = CFrame.new(aimPosition + offset + Vector3.new(0, height, 0), aimPosition)
		elseif style == "Above" then
			local height = tonumber(cfg.FollowTargetHeight) or 0
			local finalHeight = height ~= 0 and height or math.max(distance, 3)
			newCFrame = CFrame.new(aimPosition + Vector3.new(0, finalHeight, 0), aimPosition)
		elseif style == "Side" and targetRoot then
			local height = tonumber(cfg.FollowTargetHeight) or 0
			local offset = targetRoot.CFrame.RightVector * distance
			newCFrame = CFrame.new(aimPosition + offset + Vector3.new(0, height, 0), aimPosition)
		else
			local speed = tonumber(cfg.FollowTargetSpeed) or 75
			local height = tonumber(cfg.FollowTargetHeight) or 0
			RagebotState.FollowOrbitAngle = (RagebotState.FollowOrbitAngle or 0) + math.rad(speed) * math.max(dt or 0, 1 / 240)
			local orbitOffset = CFrame.Angles(0, RagebotState.FollowOrbitAngle, 0) * CFrame.new(0, 0, distance)
			newCFrame = CFrame.new(aimPosition + Vector3.new(0, height, 0)) * orbitOffset
		end

		hrp.CFrame = newCFrame
	end

	function HideRagebotTracer()
		if ragebotTracerLine then
			ragebotTracerLine.Visible = false
		end
		if ragebotTracerOutline then
			ragebotTracerOutline.Visible = false
		end
	end

	function HideRagebotPredictionDisplay()
		if ragebotPredictionLabel then
			ragebotPredictionLabel.Visible = false
		end
	end

	function ProjectRagebotWorldPoint(worldPosition)
		if not Camera or not worldPosition then
			return nil
		end
		local screenPoint = Camera:WorldToViewportPoint(worldPosition)
		local viewport = Camera.ViewportSize
		local halfX = viewport.X * 0.5
		local halfY = viewport.Y * 0.5
		if screenPoint.Z < 0 then
			return Vector2.new(
				math.clamp(halfX + (halfX - screenPoint.X), 0, viewport.X),
				math.clamp(halfY + (halfY - screenPoint.Y), 0, viewport.Y)
			)
		end
		return Vector2.new(screenPoint.X, screenPoint.Y)
	end

	function GetRagebotTracerOrigin()
		local cfg = Config and Config.Ragebot
		if not cfg then
			return getMousePos and getMousePos() or nil
		end

		local originMode = tostring(cfg.TracerOrigin or "Gun")
		if originMode == "Gun" then
			local tool = GetRagebotFireTool()
			local handle = tool and (tool:FindFirstChild("Handle") or tool:FindFirstChildWhichIsA("BasePart", true))
			if handle and handle:IsA("BasePart") then
				return ProjectRagebotWorldPoint(handle.Position)
			end
		elseif originMode == "Character" then
			local hrp = getroot()
			if hrp then
				return ProjectRagebotWorldPoint(hrp.Position)
			end
		end

		return getMousePos and getMousePos() or nil
	end

	function UpdateRagebotTracer()
		local cfg = Config and Config.Ragebot
		if not cfg or not cfg.Enabled or not cfg.TracerEnabled or not RagebotState.OverrideActive or not RagebotState.AimPosition then
			HideRagebotTracer()
			return
		end

		local origin = GetRagebotTracerOrigin()
		local endPosition = RagebotState.AimPosition
		if tostring(cfg.TracerEnd or "Predicted Position") == "Target Part" and RagebotState.TargetPart then
			endPosition = RagebotState.TargetPart.Position
		end
		local destination = ProjectRagebotWorldPoint(endPosition)
		if not origin or not destination then
			HideRagebotTracer()
			return
		end

		ragebotTracerOutline.From = origin
		ragebotTracerOutline.To = destination
		ragebotTracerOutline.Thickness = 4
		ragebotTracerOutline.Color = cfg.TracerOutlineColor or UIColors.Outline
		ragebotTracerOutline.Transparency = 1
		ragebotTracerOutline.Visible = true

		ragebotTracerLine.From = origin
		ragebotTracerLine.To = destination
		ragebotTracerLine.Thickness = 2
		ragebotTracerLine.Color = cfg.TracerColor or UIColors.Accent
		ragebotTracerLine.Transparency = 1
		ragebotTracerLine.Visible = true
	end

	function UpdateRagebotPredictionDisplay()
		local cfg = Config and Config.Ragebot
		if not cfg or not cfg.Enabled or not cfg.PredictionDisplay or not RagebotState.OverrideActive or not Camera then
