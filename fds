		end
		return "Neutral"
	end
	function GetSavedPlayerPriorityStatus(targetPlayer)
		if not targetPlayer or type(Config.PlayerListPriorities) ~= "table" then
			return nil
		end
		local saved = Config.PlayerListPriorities[tostring(targetPlayer.UserId)]
			or Config.PlayerListPriorities[targetPlayer.Name]
		if saved == nil then
			return nil
		end
		return NormalizePlayerPriorityStatus(saved)
