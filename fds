			Config.Combat.orbitLoop:Disconnect()
			Config.Combat.orbitLoop = nil
		end
		workspace.CurrentCamera.CameraSubject = LocalPlayer.Character
	end

	function StartOrbit()
		StopOrbit()
		Config.Combat.orbitLoop = RunService.Heartbeat:Connect(function()
			if not Config.Combat.OrbitEnabled then
				return
			end

			local targetChar = Config.Combat.lockedTarget
			local localCharacter = LocalPlayer.Character
			local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
			local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

			if not localRoot or not targetRoot then
				workspace.CurrentCamera.CameraSubject = localCharacter
				return
			end

			workspace.CurrentCamera.CameraSubject = Config.Combat.orbitview and targetChar or localCharacter

			orbitAngle = orbitAngle + (Config.Combat.OrbitSpeed * 0.05)
			if orbitAngle > math.pi * 2 then
				orbitAngle = orbitAngle - (math.pi * 2)
			end

			local x
			local z
			local y = targetRoot.Position.Y + Config.Combat.OrbitHeight

			if Config.Combat.orbitmode == "random" then
				local randomAngle = math.rad(math.random(0, 360))
				local randomRadius = math.max(1, math.random() * Config.Combat.OrbitDistance)
				x = targetRoot.Position.X + math.cos(randomAngle) * randomRadius
				z = targetRoot.Position.Z + math.sin(randomAngle) * randomRadius
				y = y + math.random(-3, 3)
			else
				x = targetRoot.Position.X + math.cos(orbitAngle) * Config.Combat.OrbitDistance
				z = targetRoot.Position.Z + math.sin(orbitAngle) * Config.Combat.OrbitDistance
			end

			local newPosition = Vector3.new(x, y, z)
			localRoot.CFrame = CFrame.new(newPosition, targetRoot.Position)
		end)
	end

