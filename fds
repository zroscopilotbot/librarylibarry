function TrimHitEffects()
		while #HitEffectsState.numbers > HIT_EFFECTS_MAX_NUMBERS do
			local item = table.remove(HitEffectsState.numbers, 1)
			if item and item.drawing then
				item.drawing.Visible = false
				HitEffectPools.numbers[#HitEffectPools.numbers + 1] = item
			end
		end

		while #HitEffectsState.markers2d > HIT_EFFECTS_MAX_MARKERS_2D do
			local marker = table.remove(HitEffectsState.markers2d, 1)
			if marker then
				for _, line in pairs(marker.lines or {}) do line.Visible = false end
				for _, line in pairs(marker.outlines or {}) do line.Visible = false end
				HitEffectPools.markers2d[#HitEffectPools.markers2d + 1] = marker
			end
		end

		while #HitEffectsState.markers3d > HIT_EFFECTS_MAX_MARKERS_3D do
			local marker = table.remove(HitEffectsState.markers3d, 1)
			if marker then
				for _, line in pairs(marker.lines or {}) do line.Visible = false end
				for _, line in pairs(marker.outlines or {}) do line.Visible = false end
				HitEffectPools.markers3d[#HitEffectPools.markers3d + 1] = marker
			end
		end

		while #HitEffectsState.tracers > HIT_EFFECTS_MAX_TRACERS do
			local tracer = table.remove(HitEffectsState.tracers, 1)
			if tracer then
				if tracer.line then pcall(function() tracer.line:Remove() end) end
				if tracer.outline then pcall(function() tracer.outline:Remove() end) end
			end
		end

		while #HitEffectsState.chams > HIT_EFFECTS_MAX_CHAMS do
			local item = table.remove(HitEffectsState.chams, 1)
			if item and item.highlight then pcall(function() item.highlight:Destroy() end) end
		end
	end

