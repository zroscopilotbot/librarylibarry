	local function GetProximityAnchorPoint()
		local viewport = ESPFrameState.ViewportSize or (Camera and Camera.ViewportSize) or Vector2.new(1920, 1080)
		local localCharacter = LocalPlayer and LocalPlayer.Character
		if not localCharacter or not Camera then
			return Vector2.new(viewport.X * 0.5, viewport.Y * 0.12), false
		end

		local core = RefreshCharacterCoreCache(localCharacter)
		local head = (core and core.HeadPart) or localCharacter:FindFirstChild("Head")
		local root = (core and core.RootPart) or localCharacter:FindFirstChild("HumanoidRootPart")
		local anchorPart = head or root
		if not anchorPart then
			return Vector2.new(viewport.X * 0.5, viewport.Y * 0.12), false
		end

		local firstPerson = false
		if LocalPlayer.CameraMode == Enum.CameraMode.LockFirstPerson then
			firstPerson = true
		elseif head and (Camera.CFrame.Position - head.Position).Magnitude <= 1.2 then
			firstPerson = true
		end

		if firstPerson then
			return Vector2.new(viewport.X * 0.5, viewport.Y * 0.12), true
		end

		local worldOffset = Vector3.new(0, math.max(anchorPart.Size.Y * 1.75, 3.25), 0)
		local screenPos, onScreen = Camera:WorldToViewportPoint(anchorPart.Position + worldOffset)
		if not onScreen or screenPos.Z <= 0 then
			return nil, false
		end

		local x = math.clamp(screenPos.X, 50, viewport.X - 50)
		local y = math.clamp(screenPos.Y - 12, 20, viewport.Y - 80)
		return Vector2.new(x, y), false
	end

	local function LayoutProximityWidget(position)
		local state = EnsureProximityWidget()
		if not state or not position then
			return
		end

		local width = 54
		local height = 38
		local radius = 9
		local halfWidth = width * 0.5
		local halfHeight = height * 0.5
		local left = math.floor(position.X - halfWidth + 0.5)
		local top = math.floor(position.Y - halfHeight + 0.5)
		local right = left + width
		local bottom = top + height
		local borderColor = Config.ESP.Colors.Proximity or UIColors.Accent
		local backgroundColor = Color3.fromRGB(16, 20, 16)

		state.BackgroundA.Position = Vector2.new(left, top)
		state.BackgroundA.Size = Vector2.new(width, height)
		state.BackgroundA.Color = backgroundColor

		local lines = state.BorderLines
		lines[1].From = Vector2.new(left, top)
		lines[1].To = Vector2.new(right, top)
		lines[2].From = Vector2.new(right, top)
		lines[2].To = Vector2.new(right, bottom)
		lines[3].From = Vector2.new(left, bottom)
		lines[3].To = Vector2.new(right, bottom)
		lines[4].From = Vector2.new(left, top)
		lines[4].To = Vector2.new(left, bottom)
		for _, line in ipairs(lines) do
			line.Color = borderColor
		end

		state.Count.Position = Vector2.new(position.X, position.Y - 11)
	end

	function CreateSoundArc(key)
		local existing = _G.ESPSoundArcs[key]
		if existing then
			return existing
		end

		local arc = { Lines = {} }
		for i = 1, SOUND_ARC_SEGMENTS do
			local line = Drawing.new("Line")
			line.Visible = false
			line.Transparency = 1
			line.Thickness = SOUND_ESP_THICKNESS
			arc.Lines[i] = line
		end

		_G.ESPSoundArcs[key] = arc
		return arc
	end

	function HideSoundArc(arc)
		if not arc then
			return
		end
		for _, line in ipairs(arc.Lines or {}) do
			line.Visible = false
		end
	end

	function RemoveSoundArc(key)
		local arc = _G.ESPSoundArcs[key]
		if arc then
			for _, line in ipairs(arc.Lines or {}) do
				pcall(function() line:Remove() end)
			end
			_G.ESPSoundArcs[key] = nil
		end
		SoundESPEvents[key] = nil
	end

	function IsLocalFirstPersonView()
		local localCharacter = LocalPlayer and LocalPlayer.Character
		if not localCharacter or not Camera then
			return false
		end

		if LocalPlayer.CameraMode == Enum.CameraMode.LockFirstPerson then
			return true
		end

		local core = RefreshCharacterCoreCache(localCharacter)
		local head = (core and core.HeadPart) or localCharacter:FindFirstChild("Head")
		return head and (Camera.CFrame.Position - head.Position).Magnitude <= 1.2 or false
	end

	function GetSoundESPAnchorPoint(localRoot)
		local viewport = ESPFrameState.ViewportSize or (Camera and Camera.ViewportSize) or Vector2.new(1920, 1080)
		if IsLocalFirstPersonView() then
			local mousePos = getMousePos and getMousePos()
			if mousePos then
				return mousePos, true
			end
			return Vector2.new(viewport.X * 0.5, viewport.Y * 0.5), true
		end

		local localCharacter = LocalPlayer and LocalPlayer.Character
		local core = localCharacter and RefreshCharacterCoreCache(localCharacter)
		local anchorPart = (core and core.HeadPart) or localRoot
		if anchorPart and Camera then
			local screenPos, onScreen = Camera:WorldToViewportPoint(anchorPart.Position + Vector3.new(0, math.max(anchorPart.Size.Y * 1.35, 2.5), 0))
			if onScreen and screenPos.Z > 0 then
				return Vector2.new(screenPos.X, screenPos.Y), false
			end
		end

		return Vector2.new(viewport.X * 0.5, viewport.Y * 0.72), false
	end

	function GetActivePlayerSoundSource(character, rootPart)
		local bestSound = nil
		local bestLoudness = -1

		for _, desc in ipairs(character:GetDescendants()) do
			if desc:IsA("Sound") then
				local isPlaying = false
				pcall(function()
					isPlaying = desc.IsPlaying
				end)
				if isPlaying then
					local loudness = tonumber(desc.PlaybackLoudness) or 0
					if loudness > bestLoudness then
						bestLoudness = loudness
						bestSound = desc
					end
				end
			end
		end

		if not bestSound then
			return nil, nil
		end

		local parent = bestSound.Parent
		if parent and parent:IsA("Attachment") then
			parent = parent.Parent
		end
		if parent and parent:IsA("BasePart") then
			return parent.Position, bestLoudness
		end

		return rootPart and rootPart.Position or nil, bestLoudness
	end

	function RefreshSoundESPEvents(localRoot, currentTime)
		local range = SOUND_ESP_RANGE
		local lifetime = SOUND_ESP_LIFETIME

		for _, player in ipairs(GetPlayersListCached()) do
			if player ~= LocalPlayer then
				local shouldTrack = not ShouldHideESPForPlayer(player)
				if shouldTrack and Config.ESP.TeamCheck then
					shouldTrack = IsPlayerEnemy(player)
				end

				if not shouldTrack then
					SoundESPEvents[player] = nil
				else
					local character = GetPlayerCharacter(player)
					local core = character and RefreshCharacterCoreCache(character)
					local rootPart = core and core.RootPart
					local humanoid = core and core.Humanoid

					if rootPart and humanoid and humanoid.Health > 0 then
						local distance = (rootPart.Position - localRoot.Position).Magnitude
						if distance <= range then
							local sourcePos, loudness = GetActivePlayerSoundSource(character, rootPart)
							if sourcePos then
								local event = SoundESPEvents[player] or {}
								event.SourcePos = sourcePos
								event.Loudness = loudness or 0
								event.ExpiresAt = currentTime + lifetime
								SoundESPEvents[player] = event
							end
						end
					end
				end
			end
		end
	end

	function UpdateSoundESP(currentTime)
		currentTime = currentTime or tick()

		if not Config.ESP.Enabled or not Config.ESP.SoundsEnabled then
			for _, arc in pairs(_G.ESPSoundArcs) do
				HideSoundArc(arc)
			end
			return
		end

		local localRoot = type(GetLocalRootPartForESP) == "function" and GetLocalRootPartForESP()
		if not localRoot or not Camera then
			for _, arc in pairs(_G.ESPSoundArcs) do
				HideSoundArc(arc)
			end
			return
		end

		RefreshSoundESPEvents(localRoot, currentTime)

		local anchorPoint, useMouseAnchor = GetSoundESPAnchorPoint(localRoot)
		local cameraCFrame = ESPFrameState.CameraCFrame or Camera.CFrame
		local cameraPos = ESPFrameState.CameraPos or cameraCFrame.Position
		local radius = math.max(18, tonumber(Config.ESP.SoundsRange) or 54)
		local spread = math.rad(SOUND_ESP_ARC_DEGREES)
		local thickness = SOUND_ESP_THICKNESS
		local lifetime = SOUND_ESP_LIFETIME
		local color = Config.ESP.Colors.Sounds or UIColors.SoftAlt

		for _, player in ipairs(GetPlayersListCached()) do
			if player ~= LocalPlayer then
				local event = SoundESPEvents[player]
				if not event or currentTime > (event.ExpiresAt or 0) then
					SoundESPEvents[player] = nil
					HideSoundArc(_G.ESPSoundArcs[player])
				else
					local sourcePos = event.SourcePos
					local angle = nil
					if sourcePos then
						local sourceScreenPos, onScreen = Camera:WorldToViewportPoint(sourcePos)
						if onScreen and sourceScreenPos.Z > 0 then
							angle = math.atan2(sourceScreenPos.Y - anchorPoint.Y, sourceScreenPos.X - anchorPoint.X)
						else
							local toSource = sourcePos - cameraPos
							angle = math.atan2(
								-toSource:Dot(cameraCFrame.UpVector),
								toSource:Dot(cameraCFrame.RightVector)
							)
						end
					end

					if not angle then
						HideSoundArc(_G.ESPSoundArcs[player])
					else
						local arc = CreateSoundArc(player)
						local fade = math.clamp((event.ExpiresAt - currentTime) / lifetime, 0, 1)
						local arcRadius = useMouseAnchor and (radius * 0.9) or radius
						local startAngle = angle - (spread * 0.5)
						local step = spread / SOUND_ARC_SEGMENTS

						for i = 1, SOUND_ARC_SEGMENTS do
							local t0 = (i - 1) / SOUND_ARC_SEGMENTS
							local t1 = i / SOUND_ARC_SEGMENTS
							local a0 = startAngle + (step * (i - 1))
							local a1 = startAngle + (step * i)
							local r0 = arcRadius + math.sin(t0 * math.pi) * 5
							local r1 = arcRadius + math.sin(t1 * math.pi) * 5
							local line = arc.Lines[i]
							line.From = Vector2.new(
								anchorPoint.X + math.cos(a0) * r0,
								anchorPoint.Y + math.sin(a0) * r0
							)
							line.To = Vector2.new(
								anchorPoint.X + math.cos(a1) * r1,
								anchorPoint.Y + math.sin(a1) * r1
							)
							line.Color = color
							line.Thickness = thickness
							line.Transparency = fade
							line.Visible = true
						end
					end
				end
			end
		end

		for key, arc in pairs(_G.ESPSoundArcs) do
			if key == LocalPlayer or not SoundESPEvents[key] then
				HideSoundArc(arc)
			end
		end
	end

function GetOrCreateRadarBackground()
