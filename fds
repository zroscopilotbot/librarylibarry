function disable_freecam_ui()
		if FreecamUI.Cache then
			return
		end
		local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
		if not playerGui then
			return
		end
		FreecamUI.Cache = {}
		for _, gui in ipairs(playerGui:GetChildren()) do
			if gui:IsA("ScreenGui") then
				FreecamUI.Cache[gui] = gui.Enabled
				gui.Enabled = false
			end
		end
		if FreecamUI.Conn then
			FreecamUI.Conn:Disconnect()
			FreecamUI.Conn = nil
		end
		FreecamUI.Conn = playerGui.ChildAdded:Connect(function(child)
			if FreecamUI.Enabled and child:IsA("ScreenGui") then
				FreecamUI.Cache[child] = child.Enabled
				child.Enabled = false
			end
		end)
	end

function restore_freecam_ui()
		if FreecamUI.Conn then
			FreecamUI.Conn:Disconnect()
			FreecamUI.Conn = nil
		end
		if not FreecamUI.Cache then
			return
		end
		for gui, enabled in pairs(FreecamUI.Cache) do
			if gui and gui.Parent then
				gui.Enabled = enabled
			end
		end
		FreecamUI.Cache = nil
	end

function update_freecam_ui()
		if FreecamState.Enabled and FreecamUI.Enabled then
			disable_freecam_ui()
		else
			restore_freecam_ui()
		end
	end

function set_freecam(enabled)
		if enabled == FreecamState.Enabled then
			return
		end

		FreecamState.Enabled = enabled

		if enabled then
			local cam = workspace.CurrentCamera
			FreecamState.PrevCameraType = cam.CameraType
			FreecamState.PrevCameraSubject = cam.CameraSubject
			FreecamState.PrevCFrame = cam.CFrame
			FreecamState.PrevMouseBehavior = UserInputService.MouseBehavior
			FreecamState.PrevMouseIconEnabled = UserInputService.MouseIconEnabled

			local character = LocalPlayer.Character
			local humanoid = character and character:FindFirstChildOfClass("Humanoid")
			if humanoid then
				FreecamState.PrevHumanoid = humanoid
				FreecamState.PrevWalkSpeed = humanoid.WalkSpeed
				FreecamState.PrevJumpPower = humanoid.JumpPower
				FreecamState.PrevJumpHeight = humanoid.JumpHeight
				FreecamState.PrevAutoRotate = humanoid.AutoRotate
				humanoid.WalkSpeed = 0
				humanoid.JumpPower = 0
				humanoid.JumpHeight = 0
				humanoid.AutoRotate = false
			end

			local look = cam.CFrame.LookVector
			FreecamState.Pitch = math.asin(math.clamp(look.Y, -1, 1))
			FreecamState.Yaw = math.atan2(-look.X, -look.Z)
			FreecamState.Position = cam.CFrame.Position

			cam.CameraType = Enum.CameraType.Scriptable
			cam.CameraSubject = nil
			UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
			UserInputService.MouseIconEnabled = false

			local sensitivity = 0.002
			FreecamState.Connections.InputBegan = UserInputService.InputBegan:Connect(function(input, processed)
				if processed then return end
				local code = input.KeyCode
				if code == Enum.KeyCode.W then
					FreecamInput.F = 1
				elseif code == Enum.KeyCode.S then
					FreecamInput.B = 1
				elseif code == Enum.KeyCode.A then
					FreecamInput.L = 1
				elseif code == Enum.KeyCode.D then
					FreecamInput.R = 1
				elseif code == Enum.KeyCode.E or code == Enum.KeyCode.Space then
					FreecamInput.U = 1
				elseif code == Enum.KeyCode.Q or code == Enum.KeyCode.LeftControl then
					FreecamInput.D = 1
				elseif code == Enum.KeyCode.LeftShift then
					FreecamInput.Fast = true
				end
			end)

			FreecamState.Connections.InputEnded = UserInputService.InputEnded:Connect(function(input, processed)
				if processed then return end
				local code = input.KeyCode
				if code == Enum.KeyCode.W then
					FreecamInput.F = 0
				elseif code == Enum.KeyCode.S then
					FreecamInput.B = 0
				elseif code == Enum.KeyCode.A then
					FreecamInput.L = 0
				elseif code == Enum.KeyCode.D then
					FreecamInput.R = 0
				elseif code == Enum.KeyCode.E or code == Enum.KeyCode.Space then
					FreecamInput.U = 0
				elseif code == Enum.KeyCode.Q or code == Enum.KeyCode.LeftControl then
					FreecamInput.D = 0
				elseif code == Enum.KeyCode.LeftShift then
					FreecamInput.Fast = false
				end
			end)

			FreecamState.Connections.InputChanged = UserInputService.InputChanged:Connect(function(input, processed)
				if processed then return end
				if input.UserInputType == Enum.UserInputType.MouseMovement then
					local delta = input.Delta
					FreecamState.Yaw = FreecamState.Yaw - (delta.X * sensitivity)
					FreecamState.Pitch = math.clamp(
						FreecamState.Pitch - (delta.Y * sensitivity),
						math.rad(-89),
						math.rad(89)
					)
				end
			end)

			FreecamState.Connections.Render = RunService.RenderStepped:Connect(function(dt)
				local cam = workspace.CurrentCamera
				if not cam then return end
				local speed = FreecamState.Speed
				if FreecamInput.Fast then
					speed = speed * FreecamState.FastMultiplier
				end
				local move = Vector3.new(
					FreecamInput.R - FreecamInput.L,
					FreecamInput.U - FreecamInput.D,
					FreecamInput.F - FreecamInput.B
				)
				local cf = CFrame.new(FreecamState.Position)
					* CFrame.Angles(0, FreecamState.Yaw, 0)
					* CFrame.Angles(FreecamState.Pitch, 0, 0)
				if move.Magnitude > 0 then
					move = move.Unit * speed * dt
					FreecamState.Position = FreecamState.Position
						+ (cf.RightVector * move.X)
						+ (cf.UpVector * move.Y)
						+ (cf.LookVector * move.Z)
				end
				cam.CFrame = CFrame.new(FreecamState.Position)
					* CFrame.Angles(0, FreecamState.Yaw, 0)
					* CFrame.Angles(FreecamState.Pitch, 0, 0)
			end)

			update_freecam_ui()
		else
			for _, conn in pairs(FreecamState.Connections) do
				if conn then
					conn:Disconnect()
				end
			end
			FreecamState.Connections = {}
			FreecamInput = {F = 0, B = 0, L = 0, R = 0, U = 0, D = 0, Fast = false}

			local cam = workspace.CurrentCamera
			if cam then
				if FreecamState.PrevCameraType then
					cam.CameraType = FreecamState.PrevCameraType
				end
				if FreecamState.PrevCameraSubject ~= nil then
					cam.CameraSubject = FreecamState.PrevCameraSubject
				end
				if FreecamState.PrevCFrame then
					cam.CFrame = FreecamState.PrevCFrame
				end
			end
			if FreecamState.PrevMouseBehavior then
				UserInputService.MouseBehavior = FreecamState.PrevMouseBehavior
			else
				UserInputService.MouseBehavior = Enum.MouseBehavior.Default
			end
			if FreecamState.PrevMouseIconEnabled ~= nil then
				UserInputService.MouseIconEnabled = FreecamState.PrevMouseIconEnabled
			else
				UserInputService.MouseIconEnabled = true
			end

			if FreecamState.PrevHumanoid and FreecamState.PrevHumanoid.Parent then
				if FreecamState.PrevWalkSpeed ~= nil then
					FreecamState.PrevHumanoid.WalkSpeed = FreecamState.PrevWalkSpeed
				end
				if FreecamState.PrevJumpPower ~= nil then
					FreecamState.PrevHumanoid.JumpPower = FreecamState.PrevJumpPower
				end
				if FreecamState.PrevJumpHeight ~= nil then
					FreecamState.PrevHumanoid.JumpHeight = FreecamState.PrevJumpHeight
				end
				if FreecamState.PrevAutoRotate ~= nil then
					FreecamState.PrevHumanoid.AutoRotate = FreecamState.PrevAutoRotate
				end
			end
			FreecamState.PrevHumanoid = nil
			FreecamState.PrevWalkSpeed = nil
			FreecamState.PrevJumpPower = nil
			FreecamState.PrevJumpHeight = nil
			FreecamState.PrevAutoRotate = nil
			FreecamState.PrevMouseBehavior = nil
			FreecamState.PrevMouseIconEnabled = nil

			update_freecam_ui()
		end
	end

	function UpdateVelocity()
		local character = LocalPlayer.Character
		local rootPart = character and character:FindFirstChild("HumanoidRootPart")
		if not rootPart then
			return
		end

		local velocityVector = Config.Velocity.AutoZero and Vector3.new(0, 0, 0) or Config.Velocity.Vector
		local originalVelocity = rootPart.Velocity
		rootPart.Velocity = velocityVector or Vector3.new(0, 0, 0)
		task.defer(function(activeRoot, restoreVelocity)
			RunService.RenderStepped:Wait()
			if activeRoot and activeRoot.Parent then
				activeRoot.Velocity = restoreVelocity
			end
		end, rootPart, originalVelocity)
	end

	function StopOrbit()
