	function getScreenPos(character)
		if not character then return nil end
		local root = character:FindFirstChild("HumanoidRootPart")
			or (GetEncryptedHeadPart and GetEncryptedHeadPart(character))
			or GetBestBasePart(character, "HumanoidRootPart")
		if not root then return nil end
		local pos, onScreen = Camera:WorldToViewportPoint(root.Position)
		if not onScreen then return nil end
		return Vector2.new(pos.X, pos.Y)
	end

	function isInsideCircle(point, center, radius)
		if not point or not center then return false end
		local dx = point.X - center.X
		local dy = point.Y - center.Y
		return (dx * dx + dy * dy) <= (radius * radius)
	end

	function GetAimCandidateParts(character, mode)
		if not character or not character.Parent then
			return {}
		end

		local parts = {}
		local seen = {}
		local function addPart(part)
			if part and part:IsA("BasePart") and part.Parent and not seen[part] then
				seen[part] = true
				parts[#parts + 1] = part
			end
		end

		local selectedAimPartName = Config and Config.Combat and Config.Combat.AimPart or "Torso"
		addPart(GetSelectedAimPart(character, selectedAimPartName))
		addPart(character:FindFirstChild("HumanoidRootPart"))
		addPart(character:FindFirstChild("Head"))
		addPart(character:FindFirstChild("UpperTorso"))
		addPart(character:FindFirstChild("Torso"))
		addPart(GetBestBasePart and GetBestBasePart(character, "HumanoidRootPart"))
		if GetEncryptedHeadPart then
			addPart(GetEncryptedHeadPart(character))
		end

		if selectedAimPartName == "Closest Part" then
			local characterParts = GetCharacterPartsCached(character)
			if characterParts then
				for i = 1, math.min(#characterParts, 12) do
					addPart(characterParts[i])
				end
			end
		end

		return parts
	end

	function getClosestDistanceFromCandidateParts(parts, mousePos, useFov, radius, deadzoneRadius, deadzoneCenter)
		if not parts or #parts == 0 then
			return nil
		end

		local closestDistance2 = math.huge
		local foundAny = false
		local mx = mousePos.X
		local my = mousePos.Y
		local radius2 = (radius or 0) ^ 2
		local deadzone2 = (tonumber(deadzoneRadius) or 0) ^ 2
		local dzx = (deadzoneCenter and deadzoneCenter.X) or mx
		local dzy = (deadzoneCenter and deadzoneCenter.Y) or my

		for _, part in ipairs(parts) do
			if part and part.Parent then
				local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
				if onScreen and screenPos.Z > 0 then
					local dx = screenPos.X - mx
					local dy = screenPos.Y - my
					local dist2 = dx * dx + dy * dy
					if deadzone2 > 0 then
						local ddx = screenPos.X - dzx
						local ddy = screenPos.Y - dzy
						if (ddx * ddx + ddy * ddy) <= deadzone2 then
							return nil
						end
					end
					if (not useFov) or dist2 <= radius2 then
						if dist2 < closestDistance2 then
							closestDistance2 = dist2
						end
						foundAny = true
					end
				end
			end
		end

		if not foundAny then
			return nil
		end

		return math.sqrt(closestDistance2)
	end

