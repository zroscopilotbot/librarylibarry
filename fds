	function normalize_color(c)
			if typeof(c) == "Color3" then
				return c
			end
			if type(c) == "table" then
				local r = c.R or c.r
				local g = c.G or c.g
				local b = c.B or c.b
				if type(r) == "number" and type(g) == "number" and type(b) == "number" then
					return Color3.new(r, g, b)
				end
				if type(c.value) == "string" then
					local ok, p = pcall(Color3.fromHex, c.value)
					if ok and typeof(p) == "Color3" then return p end
				end
			end
			if type(c) == "string" then
				local ok, p = pcall(Color3.fromHex, c)
				if ok and typeof(p) == "Color3" then return p end
			end
			return UIColors.Accent
		end

