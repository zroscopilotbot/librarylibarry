function GetCachedHitSound(soundId)
		local sound = HitSoundCache[soundId]
		if sound and sound.Parent then
			return sound
		end
		sound = Instance.new("Sound")
		sound.SoundId = soundId
		sound.Volume = Config.Combat.HitSound.Volume
		sound.Parent = SoundService
		HitSoundCache[soundId] = sound
		return sound
	end

	function PlayHitSound()
		if not Config.Combat.HitSound.Enabled then
			return
		end

		local currentTime = tick()
		if currentTime - lastHitSoundTime < HIT_SOUND_COOLDOWN then
			return
		end

		local soundId = HitSoundId[Config.Combat.HitSound.SoundId]
		if not soundId then
			warn("HitSound: Invalid sound ID for", Config.Combat.HitSound.SoundId)
			return
		end

		local sound = GetCachedHitSound(soundId)
		sound.Volume = Config.Combat.HitSound.Volume

		if not sound.IsLoaded then
			if not HitSoundLoading[soundId] then
				HitSoundLoading[soundId] = true
				task.spawn(function()
					pcall(function()
						ContentProvider:PreloadAsync({ sound })
					end)
					HitSoundLoading[soundId] = nil
				end)
			end
			return
		end

		-- If currently playing, restart instead of creating new instances.
		if sound.Playing then
			sound.TimePosition = 0
		else
			sound:Play()
		end

		lastHitSoundTime = currentTime
	end

