	function set_ui_visibility(value)
		if type(value) == "boolean" then
			ui_is_visible = value
		else
			ui_is_visible = not ui_is_visible
		end
		window.set_menu_visibility(ui_is_visible)
	end

	function notify_keybind_feature(featureName, enabled)
		KeybindList.activeStates[featureName] = enabled or nil
		if silent_load_active then
			return
		end
		if flags and flags["notify_keybind_actions"] == false then
			return
		end
		library:notification({ text = featureName .. (enabled and " enabled" or " disabled") })
	end

	function sync_keybind_active_states()
		if type(KeybindList) ~= "table" then
			return
		end

		KeybindList.activeStates = {}

		local function set_state(name, enabled)
			KeybindList.activeStates[name] = enabled and true or nil
		end

		set_state("Fly", FLYING == true)
		set_state("Noclip", Config and Config.Movement and Config.Movement.Noclip and Config.Movement.Noclip.Enabled)
		set_state("Aimbot", isAimbotActive and isAimbotActive() or (Config and Config.Combat and Config.Combat.Aimbot and Config.Combat.Aimbot.Enabled))
		set_state("Silent Aim", isSilentActive and isSilentActive() or (Config and Config.Combat and Config.Combat.SilentAim and Config.Combat.SilentAim.Enabled))
		set_state("Trigger Bot", Config and Config.TriggerBot and Config.TriggerBot.Enabled)
		set_state("Flick Bot", Config and Config.Combat and Config.Combat.FlickBot and Config.Combat.FlickBot.Enabled)
		set_state("Desync", Config and Config.Desync and Config.Desync.Desyncenabled)
		set_state("Ragebot", Config and Config.Ragebot and Config.Ragebot.Enabled)
		set_state("Freecam", FreecamState and FreecamState.Enabled)
