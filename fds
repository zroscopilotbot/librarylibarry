	function update_keybind_list()
		if not KeybindList.visible or not KeybindList.initialized then return end

		local accentColor = normalize_color(
			(themes and themes.preset and themes.preset.accent)
			or (flags and flags["ui_accent"])
			or UIColors.Accent
		) or UIColors.Accent

		local font = ResolveESPFont and ResolveESPFont(
			(Config.Overlays and Config.Overlays.Font) or Config.ESP.TextFont
		) or 2

		-- collect visible entries
		local visibleEntries = {}
		for _, entry in ipairs(KeybindList.entries) do
			local isActive = get_keybind_list_entry_active(entry.key)
			KeybindList.activeStates[entry.key] = isActive and true or nil
			if KeybindList.showActiveOnly then
				if isActive then
					table.insert(visibleEntries, entry)
				end
			else
				table.insert(visibleEntries, entry)
			end
		end

		local padding = 8
		local width = KeybindList.width
		local dynamicHeight = KeybindList.titleHeight + #visibleEntries * KeybindList.lineHeight + padding
		if #visibleEntries == 0 then
			dynamicHeight = KeybindList.titleHeight + padding
		end

		KeybindList.box.Position = KeybindList.position
		KeybindList.box.Size = Vector2.new(width, dynamicHeight)
		KeybindList.box.Visible = true

		KeybindList.outline.Position = KeybindList.position
		KeybindList.outline.Size = Vector2.new(width, dynamicHeight)
		KeybindList.outline.Color = accentColor or UIColors.Accent
		KeybindList.outline.Visible = true

		KeybindList.title.Position = Vector2.new(
			KeybindList.position.X + width / 2,
			KeybindList.position.Y + 4
		)
		KeybindList.title.Font = font
		KeybindList.title.Visible = true

		for _, line in ipairs(KeybindList.lines) do
			if line then line.Visible = false end
		end

		for idx, entry in ipairs(visibleEntries) do
			repeat
				local line = KeybindList.lines[idx]
				if not line then break end

				local keybindText = ""
				if entry.getKeybind then
					local kb = entry.getKeybind()
					if kb then
						local name = tostring(kb)
							:gsub("Enum%.KeyCode%.", "")
							:gsub("Enum%.UserInputType%.", "")
						if name and name ~= "" and name ~= "nil" then
							keybindText = " [" .. name .. "]"
						end
					end
				end
				line.Text = entry.name .. keybindText
				if get_keybind_list_entry_active(entry.key) then
					line.Color = accentColor
				else
					line.Color = UIColors.Bright
				end
				line.Font = font
				line.Position = Vector2.new(
					KeybindList.position.X + 6,
					KeybindList.position.Y + KeybindList.titleHeight + (idx - 1) * KeybindList.lineHeight + 2
				)
				line.Visible = true
			until true
		end
	end

