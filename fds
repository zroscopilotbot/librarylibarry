	function HideVelocityIndicator()
		if velocityDot then
			velocityDot.Visible = false
		end
		if velocityDotOutline then
			velocityDotOutline.Visible = false
		end
	end

	function UpdateVelocityIndicator(worldPosition)
		local indicator = Config and Config.Combat and Config.Combat.VelocityIndicator
		if not indicator or not indicator.Enabled or not Camera or not worldPosition then
			HideVelocityIndicator()
			return
		end

		local screenPos, onScreen = Camera:WorldToViewportPoint(worldPosition)
		if not onScreen or screenPos.Z <= 0 then
			HideVelocityIndicator()
			return
		end

		local radius = math.max(1, tonumber(indicator.Size) or 5)
		local transparency = math.clamp(tonumber(indicator.Transparency) or 1, 0, 1)
		local center = Vector2.new(screenPos.X, screenPos.Y)

		if velocityDotOutline then
			velocityDotOutline.Position = center
			velocityDotOutline.Radius = radius + 2
			velocityDotOutline.Color = indicator.OutlineColor or UIColors.Outline
			velocityDotOutline.Filled = true
			velocityDotOutline.Transparency = transparency
			velocityDotOutline.Visible = true
		end

		if velocityDot then
			velocityDot.Position = center
			velocityDot.Radius = radius
			velocityDot.Color = indicator.Color or UIColors.Bright
			velocityDot.Filled = indicator.Filled ~= false
			velocityDot.Thickness = 1
			velocityDot.Transparency = transparency
			velocityDot.Visible = true
		end
	end

