function start_realistic_camera()
	stop_realistic_camera()
	local player = LocalPlayer
	if not player then return end
	local camera = Workspace.CurrentCamera
	if not camera then return end
	local instance = player.Character
	if not instance then return end

	local function get_humanoid()
		local char = player.Character
		return char and char:FindFirstChildOfClass("Humanoid")
	end

	local function updatechar()
		local char = player.Character
		if not char then return end
		for _, v in pairs(char:GetChildren()) do
			if v:IsA("BasePart") or v:IsA("MeshPart") or v:IsA("UnionOperation") then
				if v.Name == "Head" then
					v.LocalTransparencyModifier = 1 -- hide head (you'd clip through it)
				else
					v.LocalTransparencyModifier = 0 -- show rest of body
				end
			end
			if v:IsA("Accessory") or v:IsA("Hat") then
				local handle = v:FindFirstChild("Handle")
				if handle then
					handle.LocalTransparencyModifier = 1 -- hide head accessories too
				end
			end
		end
	end

	local func1, func2, func3, func4, val, val2 = 0, 0, 0, 0, 0, 0
	local int, int2 = 5, 5
	local vect3 = Vector3.new()

	RealisticCameraState.Connection = RunService.RenderStepped:Connect(function(deltaTime)
		deltaTime = deltaTime * 30
		local humanoid = get_humanoid()
		if not humanoid or humanoid.Health <= 0 then
			stop_realistic_camera()
			return
		end

		updatechar()

		local rootPart = humanoid.RootPart
		local rootVelocity = rootPart and rootPart.Velocity or Vector3.new()
		local rootMagnitude = Vector3.new(rootVelocity.X, 0, rootVelocity.Z).Magnitude
		local calcRootMagnitude = math.min(rootMagnitude, 25)

		if deltaTime > 1.5 then
			func1 = 0
			func2 = 0
		else
			func1 = realistic_camera_lerp(func1, math.cos(tick() * 0.5 * math.random(5, 7.5)) * (math.random(2.5, 10) / 100) * deltaTime, 0.05 * deltaTime)
			func2 = realistic_camera_lerp(func2, math.cos(tick() * 0.5 * math.random(2.5, 5)) * (math.random(1, 5) / 100) * deltaTime, 0.05 * deltaTime)
		end

		camera.CFrame = camera.CFrame * (CFrame.fromEulerAnglesXYZ(0, 0, math.rad(func3)) * CFrame.fromEulerAnglesXYZ(math.rad(func4 * deltaTime), math.rad(val * deltaTime), val2) * CFrame.Angles(0, 0, math.rad(func4 * deltaTime * (calcRootMagnitude / 5))) * CFrame.fromEulerAnglesXYZ(math.rad(func1), math.rad(func2), math.rad(func2 * 10)))

		val2 = math.clamp(realistic_camera_lerp(val2, -camera.CFrame:VectorToObjectSpace((rootPart and rootPart.Velocity or Vector3.new()) / math.max(humanoid.WalkSpeed, 0.01)).X * 0.04, 0.1 * deltaTime), -0.12, 0.1)
		func3 = realistic_camera_lerp(func3, math.clamp(UserInputService:GetMouseDelta().X, -2.5, 2.5), 0.25 * deltaTime)
		func4 = realistic_camera_lerp(func4, math.sin(tick() * int) / 5 * math.min(1, int2 / 10), 0.25 * deltaTime)

		if rootMagnitude > 1 then
			val = realistic_camera_lerp(val, math.cos(tick() * 0.5 * math.floor(int)) * (int / 200), 0.25 * deltaTime)
		else
			val = realistic_camera_lerp(val, 0, 0.05 * deltaTime)
		end

		if rootMagnitude > 6 then
			int = 10
			int2 = 9
		elseif rootMagnitude > 0.1 then
			int = 6
			int2 = 7
		else
			int2 = 0
		end

		player.CameraMaxZoomDistance = 128
		player.CameraMinZoomDistance = 0.5
		vect3 = realistic_camera_lerp(vect3, camera.CFrame.LookVector, 0.125 * deltaTime)
	end)
end

