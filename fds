function scale_color(c, mult)
		return Color3.new(
			math.clamp(c.R * mult, 0, 1),
			math.clamp(c.G * mult, 0, 1),
			math.clamp(c.B * mult, 0, 1)
		)
	end

function ApplyAuroraSettings()
		if not auroraParts or #auroraParts == 0 then return end
		local bright = math.clamp(tonumber(Config.Aurora.Brightness) or 1, 0, 3)
		local outerColor = scale_color(Config.Aurora.ColorOuter, bright)
		local innerColor = scale_color(Config.Aurora.ColorInner, bright)
		for _, entry in ipairs(auroraParts) do
			local outer = entry.BeamOuter
			local inner = entry.BeamInner
			if outer and inner then
				outer.Color = ColorSequence.new(outerColor, outerColor)
				inner.Color = ColorSequence.new(innerColor, innerColor)

				outer.Texture = Config.Aurora.Texture
				inner.Texture = Config.Aurora.Texture
				outer.TextureLength = Config.Aurora.TextureLength
				inner.TextureLength = Config.Aurora.TextureLength
				outer.TextureSpeed = Config.Aurora.TextureSpeed1
				inner.TextureSpeed = Config.Aurora.TextureSpeed2

				outer.TextureMode = Enum.TextureMode.Static
				inner.TextureMode = Enum.TextureMode.Static

				outer.CurveSize0 = Config.Aurora.CurveSize0
				outer.CurveSize1 = Config.Aurora.CurveSize1
				inner.CurveSize0 = Config.Aurora.CurveSize0
				inner.CurveSize1 = Config.Aurora.CurveSize1

				outer.Segments = Config.Aurora.Segments
				inner.Segments = Config.Aurora.Segments

				outer.Width0 = Config.Aurora.Width0
				outer.Width1 = Config.Aurora.Width1
				inner.Width0 = Config.Aurora.Width0
				inner.Width1 = Config.Aurora.Width1
			end
		end
	end

	function StopAurora()
		if auroraConn then
			auroraConn:Disconnect()
			auroraConn = nil
		end
		for _, entry in ipairs(auroraParts) do
			if entry.BeamOuter then entry.BeamOuter:Destroy() end
			if entry.BeamInner then entry.BeamInner:Destroy() end
			if entry.Attachment0 then entry.Attachment0:Destroy() end
			if entry.Attachment1 then entry.Attachment1:Destroy() end
			if entry.Part then entry.Part:Destroy() end
		end
		table.clear(auroraParts)
	end

	function StartAurora()
		StopAurora()
		local offsets = {
			{ pos = Vector3.new(0, 0, 0), rot = 0 },
			{ pos = Vector3.new(800, 70, 600), rot = 20 },
			{ pos = Vector3.new(-900, 30, -700), rot = -25 },
			{ pos = Vector3.new(1200, 110, -900), rot = 35 },
		}
		local rng = Random.new()
		local minRadius = 600
		local maxRadius = 2000
		local auroraLength = 2500

		local count = math.clamp(math.floor(tonumber(Config.Aurora.Count) or #offsets), 1, 12)
		local segmentsPerAurora = 5
		for i = 1, count do
			local base = offsets[((i - 1) % #offsets) + 1]
			local layer = math.floor((i - 1) / #offsets)
			local spread = 200 * layer
			local angle = rng:NextNumber(0, math.pi * 2)
			local radius = rng:NextNumber(minRadius, maxRadius) + spread
			local randX = math.cos(angle) * radius
			local randZ = math.sin(angle) * radius

			local previousSegmentOffset
			for segment = 1, segmentsPerAurora do
				local entry = {}
				entry.Part = Instance.new("Part")
				entry.Part.Name = "\0"
				entry.Part.Size = Vector3.new(10, 10, 10)
				entry.Part.Anchored = true
				entry.Part.CanCollide = false
				entry.Part.Transparency = 1
				entry.Part.CastShadow = false
				entry.Part.Parent = workspace

				entry.Attachment0 = Instance.new("Attachment")
				entry.Attachment0.Name = "one"
				entry.Attachment0.Position = Vector3.new(-auroraLength, 0, 0)
				entry.Attachment0.Parent = entry.Part

				entry.Attachment1 = Instance.new("Attachment")
				entry.Attachment1.Name = "two"
				entry.Attachment1.Position = Vector3.new(auroraLength, 0, 0)
				entry.Attachment1.Parent = entry.Part

				entry.BeamOuter = Instance.new("Beam")
				entry.BeamOuter.Attachment0 = entry.Attachment0
				entry.BeamOuter.Attachment1 = entry.Attachment1
				entry.BeamOuter.Parent = entry.Part

				entry.BeamInner = Instance.new("Beam")
				entry.BeamInner.Attachment0 = entry.Attachment0
				entry.BeamInner.Attachment1 = entry.Attachment1
				entry.BeamInner.Parent = entry.Part

				local desiredPos
				if segment == 1 then
					desiredPos = base.pos + Vector3.new(randX, 0, randZ)
				else
					local chainStep = math.floor((segment - 2) / 2) + 1
					local direction = (segment % 2 == 0) and 1 or -1
					local offsetDistance = auroraLength * 2 * chainStep
					desiredPos = base.pos + Vector3.new(randX + direction * offsetDistance, 0, randZ)
				end

				entry.Offset = {
					pos = desiredPos,
					rot = base.rot,
				}
				entry.CurrentPos = nil
				auroraParts[#auroraParts + 1] = entry
				previousSegmentOffset = entry.Offset
			end
		end

		ApplyAuroraSettings()

		auroraConn = RunService.RenderStepped:Connect(function()
			if not auroraParts or #auroraParts == 0 then return end
			local basePos
			local char = LocalPlayer and LocalPlayer.Character
			if char then
				local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
				if root then
					basePos = root.Position
				end
			end
			if not basePos then
				local cam = workspace.CurrentCamera
				if not cam then return end
				basePos = cam.CFrame.Position
			end
			local dt = last_frame_dt or (1 / 60)
			auroraTime = auroraTime + dt
			local alpha = 1 - math.exp(-dt / 40)
			local height = tonumber(Config.Aurora.Height) or 650
			local idx = 0
			for _, entry in ipairs(auroraParts) do
				idx = idx + 1
				local off = entry.Offset
				local driftX = math.sin(auroraTime * 0.02 + idx) * 30
				local driftZ = math.cos(auroraTime * 0.017 + idx * 1.3) * 30
				local target = basePos + Vector3.new(0, height, 0) + off.pos + Vector3.new(driftX, 0, driftZ)
				if not entry.CurrentPos then
					entry.CurrentPos = target
				else
					entry.CurrentPos = entry.CurrentPos:Lerp(target, alpha)
				end
				local rotX = math.rad(math.sin(auroraTime * 0.01 + idx) * 2)
				local rotZ = math.rad(math.cos(auroraTime * 0.012 + idx * 1.7) * 2)
				entry.Part.CFrame = CFrame.new(entry.CurrentPos) * CFrame.Angles(rotX, math.rad(off.rot), rotZ)
			end
		end)
	end

