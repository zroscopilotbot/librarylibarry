	lighting_core_section:toggle({
		name = "lighting",
		flag = "lighting_enabled",
		default = false,
		callback = function(value)
			lightingen = value
			if not value then
				for property, val in pairs(Defaults.Lighting) do
					lighting[property] = val
				end
				restoreeffectdefaults("SunRays")
				restoreeffectdefaults("Bloom")
				restoreeffectdefaults("ColorCorrection")
				restoreeffectdefaults("DepthOfField")
				restoreeffectdefaults("Blur")
				restoreeffectdefaults("Atmosphere")
			else
				lighting.Brightness = flags["lighting_brightness"] or LightingTheme.Brightness
				lighting.ClockTime = flags["lighting_time"] or LightingTheme.ClockTime
				lighting.Ambient = resolve_flag_color(flags["lighting_ambient"], LightingTheme.Ambient)
				lighting.OutdoorAmbient = resolve_flag_color(flags["lighting_outdoor_ambient"], LightingTheme.OutdoorAmbient)
				lighting.ExposureCompensation = flags["lighting_exposure"] or LightingTheme.Exposure
				lighting.ColorShift_Top = resolve_flag_color(flags["lighting_color_shift_top"], LightingTheme.ColorShiftTop)
				lighting.ColorShift_Bottom = resolve_flag_color(flags["lighting_color_shift_bottom"], LightingTheme.ColorShiftBottom)
				lighting.EnvironmentDiffuseScale = flags["lighting_diffuse_scale"] or LightingTheme.Diffuse
				lighting.EnvironmentSpecularScale = flags["lighting_specular_scale"] or LightingTheme.Specular
				lighting.GeographicLatitude = flags["lighting_latitude"] or LightingTheme.Latitude
				lighting.ShadowSoftness = flags["lighting_shadow_softness"] or LightingTheme.ShadowSoftness
				applylightingeffectsfromflags()
			end
		end
	})

