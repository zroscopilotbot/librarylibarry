	function GetAimValidationSignature()
		local combat = Config and Config.Combat
		local velocity = Config and Config.Velocity
		return table.concat({
			combat and combat.HealthCheck and 1 or 0,
			combat and combat.DistanceCheck and 1 or 0,
			tostring(combat and combat.MaxDistance or ""),
			combat and combat.ToolCheck and 1 or 0,
			combat and combat.WhitelistCheck and 1 or 0,
			combat and combat.FriendCheck and 1 or 0,
			combat and combat.TeamCheck and 1 or 0,
			combat and combat.WallCheck and 1 or 0,
			combat and combat.AimPart or "",
			velocity and velocity.Enabled and 1 or 0,
		}, "|")
	end

	function isValidTarget(character)
		if not character or not character.Parent then
			return false
		end

		local now = tick()
		local cacheEntry = AimTargetValidationCache[character]
		local validationSignature = GetAimValidationSignature()
		local function cache_and_return(value)
			AimTargetValidationCache[character] = {
				Stamp = now,
				Signature = validationSignature,
				Value = value == true,
			}
			return value == true
		end
		if cacheEntry
			and cacheEntry.Signature == validationSignature
			and (now - (cacheEntry.Stamp or 0)) < AIM_TARGET_VALIDATION_CACHE_TTL
		then
			return cacheEntry.Value == true
		end

		local localCharacter = LocalPlayer and LocalPlayer.Character
		local localRoot = localCharacter and localCharacter:FindFirstChild("HumanoidRootPart")
		local targetPart = character:FindFirstChild("HumanoidRootPart")
			or (GetEncryptedHeadPart and GetEncryptedHeadPart(character))
			or GetBestBasePart(character, "HumanoidRootPart")
		if not targetPart then
			return cache_and_return(false)
		end

		if Config.Combat.HealthCheck then
			local hp = GetModelHealthValues(character)
			if hp and hp <= 0 then
				return cache_and_return(false)
			end
		end

		if Config.Combat.DistanceCheck and localRoot then
			local maxDistance = tonumber(Config.Combat.MaxDistance) or 1000
			if (targetPart.Position - localRoot.Position).Magnitude > maxDistance then
				return cache_and_return(false)
			end
		end

		if Config.Combat.ToolCheck and not GetCharacterToolName(LocalPlayer.Character) then
			return cache_and_return(false)
		end

		local targetPlayer = Players:GetPlayerFromCharacter(character)
        if Config.Combat.WhitelistCheck and targetPlayer and IsWhitelistedPlayer(targetPlayer) then
            return cache_and_return(false)
        end

		if Config.Combat.FriendCheck and targetPlayer and IsFriendPlayer(targetPlayer) then
			return cache_and_return(false)
		end

		if Config.Combat.TeamCheck then
			if targetPlayer then
				if not IsPlayerEnemy(targetPlayer) then
					return cache_and_return(false)
				end
			else
				local targetTeamFolder = character.Parent
				local localTeamFolder = GetLocalWorkspaceTeamFolder()
				if localTeamFolder and targetTeamFolder == localTeamFolder then
					return cache_and_return(false)
				end
			end
		end

		if Config.Combat.WallCheck then
			local origin = Camera.CFrame.Position
			local targetPos = targetPart.Position
			local dir = targetPos - origin

			local params = RaycastParams.new()
			params.FilterType = Enum.RaycastFilterType.Exclude
			params.FilterDescendantsInstances = {LocalPlayer.Character}
			params.IgnoreWater = true

			local result = workspace:Raycast(origin, dir.Unit * dir.Magnitude, params)
			if result and not result.Instance:IsDescendantOf(character) then
				return cache_and_return(false)
			end
		end

		if Config.KnockCheck then
			local bodyEffects = character:FindFirstChild("BodyEffects")
			if bodyEffects then
				local ko = bodyEffects:FindFirstChild("K.O")
				if ko and ko.Value then
					return cache_and_return(false)
				end
			end
		end

		return cache_and_return(true)
	end

	getMousePos = function()
		local success, pos = pcall(function()
			return UserInputService:GetMouseLocation()
		end)

		if success and pos then
			return Vector2.new(pos.X, pos.Y)
		else
			return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
		end
