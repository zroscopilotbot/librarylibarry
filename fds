function IsVisibleToCamera(targetPart, targetModel)
		if not targetPart then return false end
		local origin = Camera and Camera.CFrame and Camera.CFrame.Position
		if not origin then return false end
		hitRaycastFilter[1] = LocalPlayer.Character
		hitRaycastParams.FilterDescendantsInstances = hitRaycastFilter
		local dir = targetPart.Position - origin
		local result = workspace:Raycast(origin, dir, hitRaycastParams)
		if not result or not result.Instance then
			return true
		end
		if targetModel and result.Instance:IsDescendantOf(targetModel) then
			return true
		end
		return false
	end

function GetHitEffectPart(character)
		if not character then return nil end
		local head = character:FindFirstChild("Head", true)
		if head and head:IsA("BasePart") then
			return head
		end
		local root = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
		if root and root:IsA("BasePart") then
			return root
		end
		return character:FindFirstChildWhichIsA("BasePart", true)
	end

function GetHitDetectTarget()
		local allowNPCs = (Config.Combat.TargetNPCs == true) or (Config.ESP and Config.ESP.TargetNPCs == true)
		local candidate = nil
		if Config.Combat.lockedTarget and Config.Combat.lockedTarget.Parent then
			candidate = Config.Combat.lockedTarget
		end

		if not candidate and mouse and mouse.Target then
			local part = mouse.Target
			local model = part and part:FindFirstAncestorOfClass("Model")
			if model and model ~= LocalPlayer.Character and isValidTarget(model) then
				candidate = model
			end
		end

		if not candidate then
			local useFov = Config.Combat.UseFov or Config.TriggerBot.UseFov
			local radius = (Config.TriggerBot.UseFov and Config.TriggerBot.FovSize) or Config.Combat.FovSize
			local closest = getClosestPlayerInFov(radius, useFov, true)
			if closest and isValidTarget(closest) then
				candidate = closest
			end
		end

		if not candidate and allowNPCs then
			for _, model in ipairs(GetNpcModelsCached()) do
				if model and isValidTarget(model) then
					candidate = model
					break
				end
			end
		end

		if not candidate then
			return nil, nil
		end

		local hitPart = GetHitEffectPart(candidate)
		if not hitPart then
			return nil, nil
		end

		if Config.Combat.WallCheck and not IsVisibleToCamera(hitPart, candidate) then
			return nil, nil
		end

		return candidate, hitPart
	end

function GetHitDetectTargets()
		local targets = {}
		local seen = {}
		local allowNPCs = (Config.Combat.TargetNPCs == true) or (Config.ESP and Config.ESP.TargetNPCs == true)

		local function addTarget(model)
			if model and not seen[model] and model.Parent and isValidTarget(model) then
				seen[model] = true
				targets[#targets + 1] = model
			end
		end

		if Config.Combat.lockedTarget then
			addTarget(Config.Combat.lockedTarget)
		end

		if mouse and mouse.Target then
			local part = mouse.Target
			local model = part and part:FindFirstAncestorOfClass("Model")
			addTarget(model)
		end

		local useFov = Config.Combat.UseFov or Config.TriggerBot.UseFov
		local radius = (Config.TriggerBot.UseFov and Config.TriggerBot.FovSize) or Config.Combat.FovSize
		local closest = getClosestPlayerInFov(radius, useFov, true)
		addTarget(closest)

		if allowNPCs then
			for _, model in ipairs(GetNpcModelsCached()) do
				addTarget(model)
			end
		end

		return targets
	end

