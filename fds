	function ValidateArguments(args, rayMethod)
		local matches = 0
		if #args < rayMethod.ArgCountRequired then
			return false
		end
		for pos, argument in next, args do
			if typeof(argument) == rayMethod.Args[pos] then
				matches = matches + 1
			end
		end
		return matches >= rayMethod.ArgCountRequired
	end

	function getDirection(origin, position)
		return (position - origin).Unit * 1000
	end

	function IsRagebotOverrideActive()
		return Config and Config.Ragebot and Config.Ragebot.Enabled
			and RagebotState and RagebotState.OverrideActive == true
			and typeof(RagebotState.AimPosition) == "Vector3"
	end

	function GetActiveAimOverrideCFrame()
		if isSilentActive() and Config.Combat.IsSettingPosition and Config.Combat.MousePosition ~= nil then
			return Config.Combat.MousePosition
		end
		if IsRagebotOverrideActive() then
			return CFrame.new(RagebotState.AimPosition)
		end
		return nil
	end

	function IsSilentAimOverrideActive()
		return GetActiveAimOverrideCFrame() ~= nil
	end

	pcall(function()
		local mouseMeta = getrawmetatable and getrawmetatable(mouse)
		if mouseMeta then
			setreadonly(mouseMeta, false)
			local oldMouseIndex = mouseMeta.__index
			if type(oldMouseIndex) == "function" then
				mouseMeta.__index = function(self, key)
					if key == "Hit" and IsSilentAimOverrideActive() then
						local aimCFrame = GetActiveAimOverrideCFrame()
						if aimCFrame then
							return aimCFrame
						end
					end
					return oldMouseIndex(self, key)
				end
			end
		end
	end)

	if hookmetamethod and newcclosure then
		pcall(function()
			local blockedNames = {
				PlayerScriptsLoader = true,
				PlayerModule = true,
				RbxCharacterSounds = true,
				CameraModule = true,
				ControlModule = true,
			}

			local oldNamecall
			oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(...)
				local method = getnamecallmethod()
				local arguments = {...}

				if IsSilentAimOverrideActive() then
					local aimCFrame = GetActiveAimOverrideCFrame()
					local aimPosition = aimCFrame and aimCFrame.Position

					if aimPosition then
						local callingScript = getcallingscript and getcallingscript() or nil
						local parentName = callingScript and callingScript.Parent and callingScript.Parent.Name or nil
						local grandParentName = callingScript and callingScript.Parent and callingScript.Parent.Parent and callingScript.Parent.Parent.Name or nil

						if callingScript and not blockedNames[callingScript.Name] and parentName ~= "CameraModule" and grandParentName ~= "ControlModule" then
							if method == "FindPartOnRayWithIgnoreList" then
								if ValidateArguments(arguments, Config.Combat.FindPartOnRayWithIgnoreList) then
									local activeRay = arguments[2]
									local origin = activeRay.Origin
									arguments[2] = Ray.new(origin, getDirection(origin, aimPosition))
									return oldNamecall(unpack(arguments))
								end
							elseif method == "FindPartOnRayWithWhitelist" then
								if ValidateArguments(arguments, Config.Combat.FindPartOnRayWithWhitelist) then
									local activeRay = arguments[2]
									local origin = activeRay.Origin
									arguments[2] = Ray.new(origin, getDirection(origin, aimPosition))
									return oldNamecall(unpack(arguments))
								end
							elseif method == "FindPartOnRay" or method == "findPartOnRay" then
								if ValidateArguments(arguments, Config.Combat.FindPartOnRay) then
									local activeRay = arguments[2]
									local origin = activeRay.Origin
									arguments[2] = Ray.new(origin, getDirection(origin, aimPosition))
									return oldNamecall(unpack(arguments))
								end
							elseif method == "Raycast" then
								if ValidateArguments(arguments, Config.Combat.Raycast) then
									local origin = arguments[2]
									arguments[3] = getDirection(origin, aimPosition)
									return oldNamecall(unpack(arguments))
								end
							end
						end
					end
				end

				return oldNamecall(...)
			end))
		end)
	end

	function ShouldHit()
		if not Config.Combat.UseHitChance then
			return true
		end

		local chance = Config.Combat.HitChance
		local roll = math.random(1, 100)

		lastHitChanceRoll = roll
		hitChanceHistory = Config.Combat.hitChanceHistory
		Config.Combat.lastHitChanceRoll = roll

		table.insert(Config.Combat.hitChanceHistory, {
			chance = chance,
			roll = roll,
			hit = roll <= chance,
			time = tick()
		})

		if #Config.Combat.hitChanceHistory > 10 then
			table.remove(Config.Combat.hitChanceHistory, 1)
		end

		return roll <= chance
	end

	function SaveOriginalAppearance()
		local character = LocalPlayer.Character
		if not character then
			return
		end

		OriginalAppearance = {Colors = {}, Materials = {}, Transparency = {}}
		for _, part in ipairs(character:GetDescendants()) do
			if part:IsA("BasePart") then
				OriginalAppearance.Colors[part] = part.Color
				OriginalAppearance.Materials[part] = part.Material
				OriginalAppearance.Transparency[part] = part.Transparency
			end
		end
	end

	function RestoreOriginalAppearance()
		local character = LocalPlayer.Character
		if not character then
			return
		end

		for part, color in pairs(OriginalAppearance.Colors) do
			if part and part:IsDescendantOf(character) then
				part.Color = color
			end
		end

		for part, material in pairs(OriginalAppearance.Materials) do
			if part and part:IsDescendantOf(character) then
				part.Material = material
			end
		end

		for part, transparency in pairs(OriginalAppearance.Transparency) do
			if part and part:IsDescendantOf(character) then
				part.Transparency = transparency
			end
		end
	end

