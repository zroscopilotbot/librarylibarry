	function update_keylogger(dt)
		-- FPS/Ping update works independently from keylogger state.
		if FPSPing.enabled then
			init_fps_ping_drawings()
			if FPSPing.fpsText and FPSPing.pingText then
				FPSPing.accum = FPSPing.accum + (dt or 0)
				FPSPing.count = FPSPing.count + 1
				if FPSPing.accum >= 1 then
					FPSPing.fps = FPSPing.count / FPSPing.accum
					FPSPing.count = 0
					FPSPing.accum = 0
				end

				local fpsValue = math.floor(FPSPing.fps + 0.5)
				local pingMs = 0
				if LocalPlayer and LocalPlayer.GetNetworkPing then
					local pingSeconds = LocalPlayer:GetNetworkPing()
					if pingSeconds and type(pingSeconds) == "number" then
						pingMs = math.floor(pingSeconds * 1000 + 0.5)
					end
				end

				local accent = normalize_color((themes and themes.preset and themes.preset.accent) or (flags and flags["ui_accent"]) or UIColors.Accent)

				local font = ResolveESPFont and ResolveESPFont(Config.ESP.TextFont) or 2

				FPSPing.fpsText.Text = string.format("FPS: %d", fpsValue)
				FPSPing.fpsText.Position = Vector2.new(FPSPing.position.X, FPSPing.position.Y)
				FPSPing.fpsText.Color = accent
				FPSPing.fpsText.Font = font
				FPSPing.fpsText.Visible = true

				FPSPing.pingText.Text = string.format("Ping: %d ms", pingMs)
				FPSPing.pingText.Position = Vector2.new(FPSPing.position.X, FPSPing.position.Y + 20)
				FPSPing.pingText.Color = accent
				FPSPing.pingText.Font = font
				FPSPing.pingText.Visible = true
			end
		else
			set_fps_ping_visibility(false)
		end

		if not KeyLogger.enabled then
			set_keylogger_visibility(false)
			return
		end

		init_keylogger_drawings()

		local enabled = KeyLogger.enabled and flags and flags["ui_keylogger"]
		if not enabled then
			set_keylogger_visibility(false)
			return
		end

		local screenWidth = Camera.ViewportSize.X
		local screenHeight = Camera.ViewportSize.Y
		local keySize = KeyLogger.keySize
		local spacing = KeyLogger.spacing

		KeyLogger.position = Vector2.new(
			(flags and flags["ui_keylogger_x"] and tonumber(flags["ui_keylogger_x"])) or KeyLogger.position.X or 20,
			(flags and flags["ui_keylogger_y"] and tonumber(flags["ui_keylogger_y"])) or KeyLogger.position.Y or (screenHeight - 240)
		)

		local baseX = math.clamp(KeyLogger.position.X, 0, math.max(screenWidth - (keySize * 3 + spacing * 2), 0))
		local layerStartY = math.clamp(KeyLogger.position.Y, 0, math.max(screenHeight - (keySize * 3 + spacing * 2), 0))

		local spaceWidth = keySize * 3 + spacing * 2
		local mouseKeyWidth = math.floor((spaceWidth - spacing) / 2)

		local layout = {
			W = {pos = Vector2.new(baseX + keySize + spacing, layerStartY - keySize - spacing), size = Vector2.new(keySize, keySize)},
			A = {pos = Vector2.new(baseX, layerStartY), size = Vector2.new(keySize, keySize)},
			S = {pos = Vector2.new(baseX + keySize + spacing, layerStartY), size = Vector2.new(keySize, keySize)},
			D = {pos = Vector2.new(baseX + (keySize + spacing) * 2, layerStartY), size = Vector2.new(keySize, keySize)},
			SPACE = {pos = Vector2.new(baseX, layerStartY + keySize + spacing), size = Vector2.new(spaceWidth, keySize)},
			M1 = {pos = Vector2.new(baseX, layerStartY + keySize * 2 + spacing * 2), size = Vector2.new(mouseKeyWidth, keySize)},
			M2 = {pos = Vector2.new(baseX + mouseKeyWidth + spacing, layerStartY + keySize * 2 + spacing * 2), size = Vector2.new(mouseKeyWidth, keySize)},
		}

		for keyName, entry in pairs(KeyLogger.entries) do
			repeat
				if not entry then
					break
				end

				if not entry.bg or not entry.outline or not entry.text then
					init_keylogger_drawings()
					entry = KeyLogger.entries[keyName]
					if not entry or not entry.bg or not entry.outline or not entry.text then
						break
					end
				end

				local layoutEntry = layout[keyName]
				if not layoutEntry then
					if entry.bg then entry.bg.Visible = false end
					if entry.outline then entry.outline.Visible = false end
					if entry.text then entry.text.Visible = false end
					if entry.divider then entry.divider.Visible = false end
					break
				end

				local delta = math.clamp((dt or 0) * 20, 0, 1)
				local target = entry.active and 1 or 0
				entry.value = entry.value + (target - entry.value) * delta

				local accentColor = normalize_color(
					(themes and themes.preset and themes.preset.accent)
						or (flags and flags["ui_accent"])
						or UIColors.Accent
				)

				local baseColor = Color3.fromRGB(10, 10, 10)
				local clickColor = accentColor
				local color = lerp_color(baseColor, clickColor, entry.value)

				entry.bg.Position = layoutEntry.pos
				entry.bg.Size = layoutEntry.size
				entry.bg.Color = color
				entry.bg.Transparency = 1
				entry.bg.Visible = true

				entry.outline.Position = layoutEntry.pos
				entry.outline.Size = layoutEntry.size
				entry.outline.Color = accentColor
				entry.outline.Transparency = 1
				entry.outline.Visible = true

				entry.text.Position = layoutEntry.pos + Vector2.new(layoutEntry.size.X / 2, layoutEntry.size.Y / 2 + (KeyLogger.textYOffset or 0))
				if keyName == "SPACE" then
					entry.text.Text = ""
				else
					entry.text.Text = entry.label
				end
				entry.text.Color = UIColors.Bright
				entry.text.Font = ResolveESPFont and ResolveESPFont(Config.ESP.TextFont) or 2
				entry.text.Transparency = 0.5 + entry.value * 0.5
				entry.text.Center = true
				entry.text.Visible = true

				if entry.divider then
					local y = layoutEntry.pos.Y + layoutEntry.size.Y / 2
					local padX = 18
					entry.divider.From = Vector2.new(layoutEntry.pos.X + padX, y)
					entry.divider.To = Vector2.new(layoutEntry.pos.X + layoutEntry.size.X - padX, y)
					entry.divider.Visible = true
				end
			until true
		end

		local now = tick()
		for button, stamps in pairs(KeyLogger.cps) do
			local i = 1
			while i <= #stamps do
				if now - stamps[i] > 1 then
					table.remove(stamps, i)
				else
					i = i + 1
				end
			end
		end

		local cps_m1 = #KeyLogger.cps.M1
		local cps_m2 = #KeyLogger.cps.M2
		if KeyLogger.cpsText then
			KeyLogger.cpsText.Center = true
			KeyLogger.cpsText.Position = Vector2.new(baseX + spaceWidth / 2, layerStartY + keySize * 3 + spacing * 3)
			KeyLogger.cpsText.Text = string.format("LMB: %d  RMB: %d", cps_m1, cps_m2)
			KeyLogger.cpsText.Color = UIColors.Bright
			KeyLogger.cpsText.Font = ResolveESPFont and ResolveESPFont(Config.ESP.TextFont) or 2
			KeyLogger.cpsText.Size = 12
			KeyLogger.cpsText.Transparency = 0.9
			KeyLogger.cpsText.Visible = true
		end
	end

